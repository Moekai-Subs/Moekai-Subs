Dialogue: 0,0:05:05.83,0:05:07.83,Default,,0,0,0,,พาฝ่าบาทไปที่ที่ปลอดภัย
Dialogue: 0,0:05:08.55,0:05:10.38,Default,,0,0,0,,พระราชินี
Dialogue: 0,0:05:12.75,0:05:14.51,Default,,0,0,0,,ทูลรายงานฝ่าบาท
Dialogue: 0,0:05:14.51,0:05:16.91,Default,,0,0,0,,เมื่อสักครู่นี้ องค์ชายริชาร์ดถูก...
Dialogue: 0,0:05:19.70,0:05:21.34,Default,,0,0,0,,เขาเป็นอย่างไรบ้าง
Dialogue: 0,0:05:21.34,0:05:25.35,Default,,0,0,0,,ถูกส่งไปโรงพยาบาลแล้วค่ะ แต่ไม่รู้ว่าเป็นตายร้ายดียังไง
Dialogue: 0,0:05:25.72,0:05:29.58,Default,,0,0,0,,คนร้ายหลบหนีไปตามหลังคา ตอนนี้กำลังค้นหาอยู่ค่ะ
Dialogue: 0,0:05:29.58,0:05:32.89,Default,,0,0,0,,ดี ถ้ามีความคืบหน้าให้มารายงานได้ตลอดเวลา
Dialogue: 0,0:05:33.36,0:05:34.46,Default,,0,0,0,,ออกไปได้
Dialogue: 0,0:05:34.46,0:05:35.36,Default,,0,0,0,,รับทราบ
Dialogue: 0,0:05:45.87,0:05:50.12,Default,,0,0,0,,ขอโทษที่เรียกทุกคนมาประชุมด่วนในคืนนี้นะครับ
Dialogue: 0,0:05:50.50,0:05:53.29,Default,,0,0,0,,ท่านลุงไม่ต้องขอโทษเรื่องนั้นหรอกครับ
Dialogue: 0,0:05:53.29,0:05:55.88,Default,,0,0,0,,แล้ว เด็กคนนั้นเป็นอย่างไรบ้าง
Dialogue: 0,0:05:56.38,0:06:01.55,Default,,0,0,0,,โชคดีที่กระสุนแค่เฉียดไหล่ขวา ไม่มีอันตรายถึงชีวิตครับ
Dialogue: 0,0:06:01.95,0:06:04.36,Default,,0,0,0,,อีกไม่นานก็คงไปเยี่ยมได้แล้ว
Dialogue: 0,0:06:05.22,0:06:08.51,Default,,0,0,0,,งั้นต่อไป ก็เหลือแค่การจับกุมคนร้าย
Dialogue: 0,0:06:08.51,0:06:11.42,Default,,0,0,0,,บางทีอาจจะเป็นพวกต่อต้านเหมือนครั้งที่แล้ว...
Dialogue: 0,0:06:11.42,0:06:13.24,Default,,0,0,0,,อย่าพูดเลย เอ็ดเวิร์ด
Dialogue: 0,0:06:14.06,0:06:15.70,Default,,0,0,0,,เด็ก ๆ กำลังฟังอยู่นะ
Dialogue: 0,0:06:20.01,0:06:22.40,Default,,0,0,0,,แต่ พวกเธอก็ควรจะตระหนักถึงความจริง
Dialogue: 0,0:06:22.40,0:06:26.10,Default,,0,0,0,,ในฐานะเชื้อพระวงศ์ ก็ยากที่จะหลีกเลี่ยงอันตรายแบบนี้
Dialogue: 0,0:06:26.49,0:06:29.37,Default,,0,0,0,,พ่อแม่ของพวกเธอก็โดนแบบนั้นไม่ใช่เหรอครับ
Dialogue: 0,0:06:32.37,0:06:33.69,Default,,0,0,0,,เอ็ดเวิร์ด
Dialogue: 0,0:06:35.29,0:06:40.92,Default,,0,0,0,,ตอนนี้ได้ตรวจสอบสถานที่ซุ่มยิง\Nและจับกุมผู้ต้องสงสัยได้หลายคน
Dialogue: 0,0:06:40.92,0:06:44.98,Default,,0,0,0,,หากมีองค์กรอยู่เบื้องหลัง ก็คงจะถูกเปิดโปงในที่สุด
Dialogue: 0,0:06:45.72,0:06:47.75,Default,,0,0,0,,เป็นฝีมือของสาธารณรัฐสินะ
Dialogue: 0,0:06:48.93,0:06:52.18,Default,,0,0,0,,ระหว่างการสอบสวนก็จะพิจารณาความเป็นไปได้นี้ด้วยครับ
Dialogue: 0,0:06:52.18,0:06:55.08,Default,,0,0,0,,อีกฝ่ายก็อาจจะยังก่อเหตุต่อไป
Dialogue: 0,0:06:55.56,0:06:59.57,Default,,0,0,0,,ทุกคนที่อยู่ที่นี่ \Nก็อาจจะกลายเป็นเป้าหมายของการลอบสังหาร
Dialogue: 0,0:06:59.57,0:07:02.07,Default,,0,0,0,,โปรดระมัดระวังให้มากด้วยนะครับ
Dialogue: 0,0:07:05.55,0:07:07.05,Default,,0,0,0,,ไม่ต้องกลัวนะ
Dialogue: 0,0:07:21.98,0:07:24.59,Default,,0,0,0,,ยังไม่ถึงเวลาเปิดร้านเลยนะ
Dialogue: 0,0:07:24.59,0:07:29.22,Default,,0,0,0,,ได้ยินมาว่าที่นี่มีวิสกี้ซิงเกิลเกรนของ ล็อครอยน่ะ
Dialogue: 0,0:07:31.46,0:07:33.60,Default,,0,0,0,,อยู่ที่ห้องด้านในสุดเลย
Dialogue: 0,0:07:46.25,0:07:50.58,Default,,0,0,0,,เรื่องเกี่ยวกับเหตุการณ์ลอบสังหาร\Nองค์ชายที่สามที่ไม่สำเร็จใช่ไหมคะ
Dialogue: 0,0:07:50.58,0:07:54.87,Default,,0,0,0,,ไม่ เรื่องนั้นไม่เกี่ยวข้องกับสาธารณรัฐ
Dialogue: 0,0:07:55.84,0:07:56.87,Default,,0,0,0,,นี่คือ?
Dialogue: 0,0:07:56.87,0:07:58.87,Default,,0,0,0,,\Nระเบิดคาโวไรต์
Dialogue: 0,0:07:59.43,0:08:03.38,Default,,0,0,0,,ทั้งอาณาจักรและสาธารณรัฐต่างก็กำลังดำเนินการพัฒนา
Dialogue: 0,0:08:03.38,0:08:06.88,Default,,0,0,0,,แต่ฝ่ายเราได้เข้าสู่ขั้นตอนการใช้งานได้จริงก่อน
Dialogue: 0,0:08:06.88,0:08:13.22,Default,,0,0,0,,\Nเมื่อสี่สัปดาห์ก่อน คาโวไรต์ที่สร้างเสร็จแล้วสามลูกถูกขโมยไป
Dialogue: 0,0:08:13.22,0:08:15.48,Default,,0,0,0,,ถูกขนส่งเข้าไปในอาณาจักรแล้ว
Dialogue: 0,0:08:15.90,0:08:18.64,Default,,0,0,0,,หลังจากนั้นก็ไม่ทราบแหล่งที่มา
Dialogue: 0,0:08:18.64,0:08:20.79,Default,,0,0,0,,เป็นฝีมือของอาณาจักรเหรอ
Dialogue: 0,0:08:21.15,0:08:22.90,Default,,0,0,0,,ยังไม่สามารถตัดสินได้
Dialogue: 0,0:08:22.90,0:08:27.03,Default,,0,0,0,,ตอนนี้ภายในกองทัพอาณาจักรก็ไม่มีความเคลื่อนไหวอะไร
Dialogue: 0,0:08:27.39,0:08:31.16,Default,,0,0,0,,สิ่งที่พวกเรากังวลคือคนที่ขโมยระเบิดไป
Dialogue: 0,0:08:31.16,0:08:36.66,Default,,0,0,0,,กับคนร้ายที่ลอบสังหารองค์ชายที่สาม \Nเป็นคนจากองค์กรเดียวกันหรือไม่
Dialogue: 0,0:08:36.66,0:08:42.08,Default,,0,0,0,,ถ้าระเบิดถูกใช้ในการลอบสังหาร สาธารณรัฐจะถูกสงสัย
Dialogue: 0,0:08:42.08,0:08:43.67,Default,,0,0,0,,เป็นอย่างนั้นจริง ๆ
Dialogue: 0,0:08:44.22,0:08:49.35,Default,,0,0,0,,เบื้องบนกังวลว่าระเบิดเหล่านี้จะจุดชนวนสงคราม
Dialogue: 0,0:08:51.97,0:08:52.91,Default,,0,0,0,,นี่คือ?
Dialogue: 0,0:08:52.91,0:08:57.48,Default,,0,0,0,,บุคคลที่คาดว่าอาจจะเกี่ยวข้องกับ\Nเรื่องที่ระเบิดถูกขนส่งเข้ามาในอาณาจักร
Dialogue: 0,0:08:58.44,0:09:01.79,Default,,0,0,0,,ตอนนี้ได้ตรวจสอบที่อยู่ของคน ๆ นี้แล้ว
Dialogue: 0,0:09:01.79,0:09:05.57,Default,,0,0,0,,แต่พวกเรายังสงสัยในข้อมูลนี้
Dialogue: 0,0:09:05.57,0:09:08.82,Default,,0,0,0,,เพราะว่าช่องโหว่มันชัดเจนเกินไป...ใช่ไหม
Dialogue: 0,0:09:08.82,0:09:10.45,Default,,0,0,0,,เป็นอย่างนั้นจริง ๆ
Dialogue: 0,0:09:10.45,0:09:15.48,Default,,0,0,0,,ภารกิจของพวกเธอคือค้นหา\N และชิงระเบิดรวมถึงอุปกรณ์ควบคุมกลับมา
Dialogue: 0,0:09:15.48,0:09:17.73,Default,,0,0,0,,เริ่มจากบ้านของคน ๆ นี้ก่อนเถอะ
Dialogue: 0,0:09:17.73,0:09:18.83,Default,,0,0,0,,เข้าใจแล้ว
Dialogue: 0,0:09:23.04,0:09:25.08,Default,,0,0,0,,หา ระเบิดเหรอ
Dialogue: 0,0:09:25.08,0:09:26.09,Default,,0,0,0,,อืม
Dialogue: 0,0:09:26.09,0:09:31.09,Default,,0,0,0,,คนพวกนั้นคงจะไม่คิดจะใช้ระเบิดนี่\Nไปทำร้ายองค์หญิงหรอกนะคะ
Dialogue: 0,0:09:31.09,0:09:34.06,Default,,0,0,0,,ภารกิจครั้งนี้ คือการป้องกันไม่ให้เกิดเรื่องแบบนั้นขึ้น
Dialogue: 0,0:09:35.91,0:09:38.54,Default,,0,0,0,,จอห์นสัน คาร์เตอร์ ผู้จัดการนักแสดง
Dialogue: 0,0:09:38.54,0:09:42.10,Default,,0,0,0,,\Nที่อยู่คือเชสต์นัทเลน บี-52
Dialogue: 0,0:09:42.10,0:09:46.05,Default,,0,0,0,,เขาดูเหมือนจะมีความเชื่อมโยงกับขโมยระเบิด
Dialogue: 0,0:09:46.05,0:09:48.87,Default,,0,0,0,,ตรวจสอบมาลึกมากเลยนี่นา
Dialogue: 0,0:09:48.87,0:09:52.23,Default,,0,0,0,,อืม แต่ นี่แหละคือจุดที่น่าสงสัย
Dialogue: 0,0:09:52.23,0:09:55.12,Default,,0,0,0,,\Nกลับทำให้คอนโทรลระมัดระวังมากยิ่งขึ้น
Dialogue: 0,0:09:55.12,0:09:58.57,Default,,0,0,0,,ในเมื่อรู้ที่อยู่แล้ว ก็ง่ายขึ้นแล้วไม่ใช่เหรอ
Dialogue: 0,0:09:58.57,0:10:00.75,Default,,0,0,0,,บุกเข้าไปบังคับให้เขาสารภาพก็สิ้นเรื่อง
Dialogue: 0,0:10:00.75,0:10:02.97,Default,,0,0,0,,แต่นั่นก็ต้องเป็นข้อมูลที่เป็นจริงด้วย
Dialogue: 0,0:10:03.46,0:10:07.34,Default,,0,0,0,,สรุปแล้วให้ฉัน จิเซะ และแองเจ ไปสืบดูก่อนดีกว่า
Dialogue: 0,0:10:07.34,0:10:08.38,Default,,0,0,0,,เข้าใจแล้ว
Dialogue: 0,0:10:09.07,0:10:12.10,Default,,0,0,0,,องค์หญิงและเบียทริซไม่ต้องออกปฏิบัติการในครั้งนี้
Dialogue: 0,0:10:12.47,0:10:14.25,Default,,0,0,0,,งั้นเหรอคะ…
Dialogue: 0,0:10:14.25,0:10:19.81,Default,,0,0,0,,จนกว่าเหตุการณ์ลอบสังหารจะคลี่คลาย\Nเชื้อพระวงศ์ทุกคนจะได้รับการคุ้มกันอย่างเข้มงวด
Dialogue: 0,0:10:19.81,0:10:22.87,Default,,0,0,0,,อย่าทำอะไรโดยพลการจะดีกว่า
Dialogue: 0,0:10:23.94,0:10:25.98,Default,,0,0,0,,อืม เป็นแบบนั้นแหละ
Dialogue: 0,0:10:26.25,0:10:30.35,Default,,0,0,0,,เบียทริซ ตอนที่พวกเราไม่อยู่ องค์หญิงฝากไว้กับเธอด้วยนะ
Dialogue: 0,0:10:30.35,0:10:32.24,Default,,0,0,0,,ไว้ใจฉันได้เลยค่ะ
Dialogue: 0,0:10:34.70,0:10:37.58,Default,,0,0,0,,โชคดีที่ดยุคแห่งอาร์คัมไม่เป็นอะไรมากนะคะ
Dialogue: 0,0:10:37.58,0:10:38.72,Default,,0,0,0,,อืม
Dialogue: 0,0:10:38.72,0:10:41.82,Default,,0,0,0,,ฉันยังไม่เคยเจอดยุคแห่งอาร์คัมเลยค่ะ
Dialogue: 0,0:10:41.82,0:10:44.54,Default,,0,0,0,,เขาเป็นคนแบบไหนเหรอคะ
Dialogue: 0,0:10:45.18,0:10:47.63,Default,,0,0,0,,เป็นคนที่อ่อนโยนและเป็นกันเองน่ะ
Dialogue: 0,0:10:47.92,0:10:52.46,Default,,0,0,0,,แต่ตั้งแต่ตอนที่ฉันยังเด็ก เขาก็ไปอยู่ต่างประเทศแล้ว
Dialogue: 0,0:10:52.46,0:10:55.47,Default,,0,0,0,,เลยไม่ค่อยได้เจอกันเท่าไหร่เหรอคะ
Dialogue: 0,0:10:55.47,0:10:56.55,Default,,0,0,0,,อืม
Dialogue: 0,0:10:57.26,0:11:00.47,Default,,0,0,0,,การเจอกันครั้งนี้ ก็ไม่รู้ว่าห่างกันไปนานแค่ไหนแล้ว
Dialogue: 0,0:11:00.88,0:11:05.27,Default,,0,0,0,,ปกติแล้วดำรงตำแหน่งเป็นผู้ว่าการในทวีปใหม่ \Nเป็นคนที่เก่งกาจมากนะ
Dialogue: 0,0:11:08.56,0:11:10.06,Default,,0,0,0,,ประมาทเกินไปนะ
Dialogue: 0,0:11:10.06,0:11:13.86,Default,,0,0,0,,นึกว่าจะได้เรียนรู้อะไรบ้างตอนไปอยู่ทวีปใหม่
Dialogue: 0,0:11:13.86,0:11:18.16,Default,,0,0,0,,เลยโดนแค่ไหล่ขวาไง ชมฉันหน่อยสิ
Dialogue: 0,0:11:18.16,0:11:19.23,Default,,0,0,0,,โอ๊ย
Dialogue: 0,0:11:19.23,0:11:21.37,Default,,0,0,0,,ไม่ได้นะครับ ฝ่าบาท
Dialogue: 0,0:11:21.37,0:11:24.32,Default,,0,0,0,,ยังคงหาข้ออ้างเก่งเหมือนเดิมเลยนะ
Dialogue: 0,0:11:24.32,0:11:29.34,Default,,0,0,0,,คุณย่าไม่ค่อยสบาย ให้ฉันมาส่งคำทักทายแทนท่าน
Dialogue: 0,0:11:29.82,0:11:35.09,Default,,0,0,0,,"ไม่เป็นอะไรก็ดีแล้ว พักผ่อนให้เต็มที่ก่อนนะ"
Dialogue: 0,0:11:35.09,0:11:37.29,Default,,0,0,0,,ขอบคุณนะ ชาร์ล็อตต์
Dialogue: 0,0:11:37.67,0:11:41.10,Default,,0,0,0,,ทำให้คุณย่าต้องเป็นห่วงฉันไปด้วยสินะ
Dialogue: 0,0:11:43.10,0:11:44.66,Default,,0,0,0,,ไง เมรี่
Dialogue: 0,0:11:44.96,0:11:46.46,Default,,0,0,0,,ไม่ได้เจอกันนานเลยนะ
Dialogue: 0,0:11:49.50,0:11:53.30,Default,,0,0,0,,เธอก็ยังขี้อายเหมือนเดิมเลยนะ
Dialogue: 0,0:11:54.62,0:11:57.49,Default,,0,0,0,,ขออภัยด้วยครับ องค์ชายริชาร์ด
Dialogue: 0,0:11:57.49,0:12:01.21,Default,,0,0,0,,ถ้ามาตรการรักษาความปลอดภัยที่ฉันจัดไว้มันสมบูรณ์กว่านี้
Dialogue: 0,0:12:01.21,0:12:03.15,Default,,0,0,0,,ก็คงจะไม่เกิดเรื่องแบบนี้ขึ้น…
Dialogue: 0,0:12:03.45,0:12:06.62,Default,,0,0,0,,แปลกจริง ๆ ท่านลุงจะเอ่ยปากขอโทษด้วย
Dialogue: 0,0:12:07.30,0:12:09.88,Default,,0,0,0,,คงไม่เกิดเรื่องไม่ดีขึ้นใช่ไหม
Dialogue: 0,0:12:10.83,0:12:12.67,Default,,0,0,0,,เฮ้ อย่าพูดจาเหลวไหล
Dialogue: 0,0:12:13.20,0:12:17.52,Default,,0,0,0,,ก็ใครใช้ให้ท่านลุงน่ากลัวอยู่เสมอล่ะ…ว่าไหม
Dialogue: 0,0:12:17.52,0:12:20.26,Default,,0,0,0,,ฮิฮิ ท่านพี่นี่จริง ๆ เลย
Dialogue: 0,0:12:20.26,0:12:23.95,Default,,0,0,0,,เพื่อไม่ให้เกิดเรื่องแบบนี้ขึ้นอีก
Dialogue: 0,0:12:23.95,0:12:28.58,Default,,0,0,0,,พวกเราจะเร่งติดตามคนร้าย \Nและเพิ่มมาตรการรักษาความปลอดภัย
Dialogue: 0,0:12:28.58,0:12:31.77,Default,,0,0,0,,งั้น ก็ถือว่าติดหนี้ฉันครั้งหนึ่งแล้วนะ
Dialogue: 0,0:12:32.30,0:12:33.48,Default,,0,0,0,,ริชาร์ด
Dialogue: 0,0:12:38.49,0:12:42.38,Default,,0,0,0,,ฝ่าบาท ตั้งแต่คืนนี้เป็นต้นไป\N จะเพิ่มกำลังเจ้าหน้าที่รักษาความปลอดภัย
Dialogue: 0,0:12:42.38,0:12:45.27,Default,,0,0,0,,อาจจะมีการรบกวนบ้าง โปรดอภัยให้ด้วย
Dialogue: 0,0:12:45.27,0:12:47.00,Default,,0,0,0,,ก็ช่วยไม่ได้นะ…
Dialogue: 0,0:12:50.62,0:12:51.80,Default,,0,0,0,,องค์หญิง
Dialogue: 0,0:12:51.80,0:12:53.77,Default,,0,0,0,,รอนานเลยนะ เบียทริซ
Dialogue: 0,0:12:53.77,0:12:56.26,Default,,0,0,0,,เป็นลางร้ายจริง ๆ
Dialogue: 0,0:12:56.26,0:13:00.56,Default,,0,0,0,,รวมถึงเรื่องของราชเลขาธิการด้วย ในราชวงศ์มีแต่ข่าวร้าย
Dialogue: 0,0:13:02.16,0:13:04.64,Default,,0,0,0,,รีบกลับห้องของตัวเองไปซะ
Dialogue: 0,0:13:15.27,0:13:16.34,Default,,0,0,0,,เมรี่
Dialogue: 0,0:13:17.53,0:13:20.08,Default,,0,0,0,,พี่จะกลับไปกับเธอนะ
Dialogue: 0,0:13:22.36,0:13:25.16,Default,,0,0,0,,ยังอยากคุยกับเธออีกหน่อยน่ะ
Dialogue: 0,0:13:25.79,0:13:26.92,Default,,0,0,0,,ค่ะ
Dialogue: 0,0:13:28.98,0:13:32.92,Default,,0,0,0,,ดูเหมือนความสัมพันธ์ระหว่างกันจะไม่ราบรื่นเท่าไหร่นะ
Dialogue: 0,0:13:32.92,0:13:35.92,Default,,0,0,0,,ฉันก็ไม่ได้คิดจะทำให้พวกเขาชอบฉันอยู่แล้ว
Dialogue: 0,0:13:36.94,0:13:39.92,Default,,0,0,0,,ยังคงเหมือนเดิมกับเมื่อ 40 ปีก่อนเลยนะ
Dialogue: 0,0:13:39.92,0:13:44.30,Default,,0,0,0,,ดูเหมือนว่าสาธารณรัฐจะพัฒนาของเล่นใหม่ ๆ ขึ้นมา
Dialogue: 0,0:13:44.30,0:13:46.68,Default,,0,0,0,,แต่พริบตาก็โดนขโมยซะแล้ว
Dialogue: 0,0:13:47.10,0:13:49.94,Default,,0,0,0,,สร้างความเดือดร้อนให้คนอื่นจริง ๆ
Dialogue: 0,0:13:49.94,0:13:52.19,Default,,0,0,0,,ท่านยังคงรับรู้ข่าวสารได้รวดเร็วเหมือนเดิมเลยนะ
Dialogue: 0,0:13:52.56,0:13:55.92,Default,,0,0,0,,ใคร ๆ ก็รู้ว่าฉันชอบฟังเรื่องซุบซิบนินทามากที่สุด
Dialogue: 0,0:13:55.92,0:14:02.20,Default,,0,0,0,,ว่าไปแล้ว ช่วงนี้ดูเหมือนจะมีแมลงที่มาจากไหนก็ไม่รู้ กำลังรบกวนสวนของราชวงศ์อยู่นะ
Dialogue: 0,0:14:02.20,0:14:07.13,Default,,0,0,0,,ฮิฮิ งั้นฉันจะลองไปตรวจสอบดูว่าพวกมันมาจากที่ไหน
Dialogue: 0,0:14:07.13,0:14:09.28,Default,,0,0,0,,และจู่โจมถึงรังเลยดีไหม
Dialogue: 0,0:14:10.12,0:14:14.17,Default,,0,0,0,,คนสนิทที่ไว้ใจได้อย่างท่าน หายากจริง ๆ
Dialogue: 0,0:14:14.17,0:14:18.32,Default,,0,0,0,,มีคนที่สามารถได้รับความไว้วางใจจากท่านได้ ทำให้ฉันประหลาดใจจริง ๆ นะ
Dialogue: 0,0:14:27.54,0:14:28.72,Default,,0,0,0,,เชิญค่ะ
Dialogue: 0,0:14:31.58,0:14:35.08,Default,,0,0,0,,คุณโอลิเวียและเบียทริซก็มาดื่มชาด้วยกันสิคะ
Dialogue: 0,0:14:36.07,0:14:36.99,Default,,0,0,0,,ค่ะ
Dialogue: 0,0:14:44.68,0:14:45.83,Default,,0,0,0,,อร่อย
Dialogue: 0,0:14:45.83,0:14:47.12,Default,,0,0,0,,ดีจังเลย
Dialogue: 0,0:14:48.72,0:14:51.66,Default,,0,0,0,,เมรี่กลัวท่านลุงเหรอคะ
Dialogue: 0,0:14:52.58,0:14:54.68,Default,,0,0,0,,ฉันกลัวเขานิดหน่อยค่ะ
Dialogue: 0,0:14:54.99,0:14:56.52,Default,,0,0,0,,ก็เลยจะประหม่า…
Dialogue: 0,0:15:04.63,0:15:05.69,Default,,0,0,0,,ท่านลุง…
Dialogue: 0,0:15:05.99,0:15:10.19,Default,,0,0,0,,รัฐมนตรีว่าการกระทรวงมหาดไทย\Nเป็นบุคคลสำคัญของประเทศ..
Dialogue: 0,0:15:10.85,0:15:15.73,Default,,0,0,0,,ด้วยความสามารถทางการเมืองและการทำงานจริง...
Dialogue: 0,0:15:15.73,0:15:17.67,Default,,0,0,0,,อาณาจักรถึงได้มีสันติภาพอยู่ในทุกวันนี้…
Dialogue: 0,0:15:17.67,0:15:18.48,Default,,0,0,0,,เมรี่?
Dialogue: 0,0:15:20.98,0:15:23.36,Default,,0,0,0,,เอ่อ ขอโทษด้วยนะคะ
Dialogue: 0,0:15:23.36,0:15:28.02,Default,,0,0,0,,พี่ไม่ได้พูดถึงเขาในแง่ร้ายนะ\Nทำให้คิดมากหรือเปล่า?
Dialogue: 0,0:15:28.82,0:15:33.00,Default,,0,0,0,,องค์หญิงเมรี่ \Nต่อหน้าองค์หญิงชาร์ล็อตต์ท่านไม่ต้องกังวลนะคะ
Dialogue: 0,0:15:34.09,0:15:35.33,Default,,0,0,0,,หนู…
Dialogue: 0,0:15:35.33,0:15:40.21,Default,,0,0,0,,ในฐานะองค์หญิงที่สอง ต่อความรู้และการอบรม…
Dialogue: 0,0:15:42.84,0:15:44.19,Default,,0,0,0,,ไม่ต้องกลัวอีกแล้ว
Dialogue: 0,0:15:44.60,0:15:47.34,Default,,0,0,0,,ที่นี่ไม่มีใครตำหนิเธอหรอก
Dialogue: 0,0:15:47.82,0:15:49.85,Default,,0,0,0,,เธอสามารถผ่อนคลายได้
Dialogue: 0,0:15:49.85,0:15:52.22,Default,,0,0,0,,มาคุยเรื่องที่ทำให้มีความสุขกันเถอะ
Dialogue: 0,0:16:12.24,0:16:13.59,Default,,0,0,0,,รอนานไหม
Dialogue: 0,0:16:13.99,0:16:15.28,Default,,0,0,0,,ไปกันเถอะ
Dialogue: 0,0:16:18.75,0:16:22.52,Default,,0,0,0,,ห้องนั้นดูเหมือนจะว่างมาหลายวันแล้ว
Dialogue: 0,0:16:22.52,0:16:24.81,Default,,0,0,0,,ทำไม ในนั้นไม่มีใครเหรอ
Dialogue: 0,0:16:24.81,0:16:27.10,Default,,0,0,0,,จิเซะ อย่าประมาท
Dialogue: 0,0:16:28.26,0:16:30.91,Default,,0,0,0,,เอาล่ะ เข้าไปก็รู้เอง
Dialogue: 0,0:16:35.48,0:16:37.61,Default,,0,0,0,,ที่นี่ซ่อนระเบิดไว้เหรอ
Dialogue: 0,0:16:37.61,0:16:39.55,Default,,0,0,0,,อันนี้ก็ไม่รู้เหมือนกัน
Dialogue: 0,0:16:41.02,0:16:44.03,Default,,0,0,0,,\Nคาโวไรต์มีขนาดใหญ่
Dialogue: 0,0:16:44.03,0:16:45.99,Default,,0,0,0,,คงไม่น่าเป็นไปได้มั้ง
Dialogue: 0,0:16:46.49,0:16:47.62,Default,,0,0,0,,งัดออกแล้ว
Dialogue: 0,0:16:56.54,0:16:58.86,Default,,0,0,0,,ดี ไปค้นหาเบาะแสกันเถอะ
Dialogue: 0,0:16:58.86,0:17:00.52,Default,,0,0,0,,ชั้น 2 ยกให้แองเจ
Dialogue: 0,0:17:00.90,0:17:02.50,Default,,0,0,0,,ฉันกับจิเซะรับผิดชอบชั้น 1
Dialogue: 0,0:17:02.50,0:17:04.39,Default,,0,0,0,,-อืม　-เข้าใจแล้ว
Dialogue: 0,0:17:27.13,0:17:29.75,Default,,0,0,0,,ไม่มีร่องรอยเลยนะ
Dialogue: 0,0:17:42.58,0:17:43.79,Default,,0,0,0,,จิเซะ
Dialogue: 0,0:17:43.79,0:17:45.27,Default,,0,0,0,,ฉันเข้าใจ
Dialogue: 0,0:17:54.18,0:17:56.00,Default,,0,0,0,,แองเจ มีกับดัก
Dialogue: 0,0:17:56.00,0:17:58.73,Default,,0,0,0,,อืม ติดตั้งไว้ที่ประตู
Dialogue: 0,0:18:11.59,0:18:13.00,Default,,0,0,0,,การเย็บเล่มแบบนี้…
Dialogue: 0,0:18:32.55,0:18:33.81,Default,,0,0,0,,ตรงนี้ก็มีเหมือนกัน
Dialogue: 0,0:18:33.81,0:18:38.31,Default,,0,0,0,,อืม อาจจะมีกลไกที่ซ่อนไว้แนบเนียนกว่านี้อีก
Dialogue: 0,0:18:39.11,0:18:41.85,Default,,0,0,0,,ไม่ว่าจะยังไงก็ตาม\N ดูเหมือนว่าจะเสียเที่ยวแล้ว
Dialogue: 0,0:18:42.40,0:18:44.19,Default,,0,0,0,,ที่นี่ไม่ใช่รังโจรเหรอ
Dialogue: 0,0:18:44.19,0:18:47.63,Default,,0,0,0,,ไม่ ในเมื่อมีกับดักมากมายขนาดนี้
Dialogue: 0,0:18:47.63,0:18:51.90,Default,,0,0,0,,อาจจะอพยพไปแล้ว หรือจงใจปล่อยข้อมูลปลอม
Dialogue: 0,0:18:51.90,0:18:54.99,Default,,0,0,0,,สรุปแล้ว ขนาดของกับดักไม่ธรรมดา
Dialogue: 0,0:18:54.99,0:18:56.40,Default,,0,0,0,,จะทำยังไงดี
Dialogue: 0,0:18:56.40,0:18:58.11,Default,,0,0,0,,ถอยทัพก่อนเถอะ
Dialogue: 0,0:18:59.40,0:19:01.22,Default,,0,0,0,,แองเจ จะถอยแล้ว
Dialogue: 0,0:19:01.22,0:19:02.72,Default,,0,0,0,,จำนวนกับดักเยอะเกินไป
Dialogue: 0,0:19:02.72,0:19:05.37,Default,,0,0,0,,เดี๋ยวก่อน ตรงนี้ฉันเจอบางอย่าง
Dialogue: 0,0:19:33.78,0:19:35.15,Default,,0,0,0,,แองเจ
Dialogue: 0,0:19:54.73,0:19:55.88,Default,,0,0,0,,หยุดนะ
Dialogue: 0,0:20:05.19,0:20:06.55,Default,,0,0,0,,น่าโมโหจริง
Dialogue: 0,0:20:08.65,0:20:10.92,Default,,0,0,0,,แองเจ จิเซะ
Dialogue: 0,0:20:18.36,0:20:20.42,Default,,0,0,0,,อยู่นี่ โดโรธี
Dialogue: 0,0:20:24.56,0:20:26.57,Default,,0,0,0,,พวกเธอไม่เป็นอะไรใช่ไหม
Dialogue: 0,0:20:26.57,0:20:27.40,Default,,0,0,0,,อืม
Dialogue: 0,0:20:27.40,0:20:29.44,Default,,0,0,0,,เสียเปรียบอย่างสิ้นเชิง
Dialogue: 0,0:20:29.44,0:20:32.17,Default,,0,0,0,,คนนั้น ไม่ใช่คนธรรมดาแน่นอน
Dialogue: 0,0:20:32.17,0:20:35.80,Default,,0,0,0,,ขอโทษที ดูเหมือนจะโดนข้อมูลปลอมหลอกเอาแล้ว
Dialogue: 0,0:20:35.80,0:20:38.22,Default,,0,0,0,,สุดท้ายก็โดนซุ่มโจมตี…
Dialogue: 0,0:20:38.22,0:20:41.92,Default,,0,0,0,,สรุปแล้วถอยก่อนเถอะ เดี๋ยวคนจะแห่กันมา
Dialogue: 0,0:20:42.72,0:20:45.92,Default,,0,0,0,,-เกิดอะไรขึ้น　-ไฟไหม้เหรอ　-ระเบิดเหรอ
Dialogue: 0,0:20:57.35,0:20:58.53,Default,,0,0,0,,จดหมาย?
Dialogue: 0,0:20:58.53,0:21:01.71,Default,,0,0,0,,อืม ถูกคั่นไว้ในหนังสือ
Dialogue: 0,0:21:01.71,0:21:03.11,Default,,0,0,0,,แปลกจริง
Dialogue: 0,0:21:03.11,0:21:07.52,Default,,0,0,0,,วางกับดัก แต่กลับทิ้งเบาะแสเอาไว้ มันผิดธรรมชาติจริง ๆ
Dialogue: 0,0:21:07.52,0:21:11.46,Default,,0,0,0,,เพราะลืมจัดการ เลยส่งคนมาแย่งชิงเหรอ
Dialogue: 0,0:21:11.46,0:21:14.99,Default,,0,0,0,,แน่นอน คน ๆ นั้นเหมือนจะมาเอาจดหมาย…
Dialogue: 0,0:21:15.56,0:21:19.08,Default,,0,0,0,,หรือว่านอกจากพวกเราแล้ว ยังมีคนอื่นกำลังหาระเบิดอยู่อีก?
Dialogue: 0,0:21:19.63,0:21:21.84,Default,,0,0,0,,ซับซ้อนซ่อนเงื่อนจริง ๆ
Dialogue: 0,0:21:21.84,0:21:26.68,Default,,0,0,0,,ถ้าสามารถรักษาจดหมายไว้ได้ \Nอย่างน้อยก็ยังมีก้าวต่อไปให้เดิน…
Dialogue: 0,0:21:26.68,0:21:28.02,Default,,0,0,0,,ไม่มีปัญหา
Dialogue: 0,0:21:38.07,0:21:40.31,Default,,0,0,0,,นี่คือเนื้อหาในจดหมาย
Dialogue: 0,0:21:40.31,0:21:43.49,Default,,0,0,0,,ในเวลาอันสั้นขนาดนั้น เธอก็จำได้หมดแล้วเหรอ?
Dialogue: 0,0:21:43.49,0:21:45.39,Default,,0,0,0,,เป็นคุณสมบัติพื้นฐานของสายลับ
Dialogue: 0,0:21:46.58,0:21:48.84,Default,,0,0,0,,เป็นทักษะพิเศษที่สะดวกสบายจริง ๆ นะ
Dialogue: 0,0:21:48.84,0:21:52.29,Default,,0,0,0,,จะต้องฝึกฝนแบบไหน ถึงจะเชี่ยวชาญเทคนิคแบบนี้ได้?
Dialogue: 0,0:21:52.29,0:21:54.66,Default,,0,0,0,,ฉันก็อยากรู้เหมือนกัน
Dialogue: 0,0:21:54.66,0:21:58.03,Default,,0,0,0,,ดังนั้น ถ้าในจดหมายเป็นข้อความที่เข้ารหัส…
Dialogue: 0,0:21:59.26,0:22:02.70,Default,,0,0,0,,องค์หญิง จำวิธีการเย็บเล่มแบบนี้ได้ไหม
Dialogue: 0,0:22:02.70,0:22:07.16,Default,,0,0,0,,นั่นมัน…เหมือนกับหนังสือบนโต๊ะทำงานของราชเลขาธิการ
Dialogue: 0,0:22:07.90,0:22:10.96,Default,,0,0,0,,อืม จดหมายถูกสอดไว้ในหนังสือเล่มนี้
Dialogue: 0,0:22:10.96,0:22:14.24,Default,,0,0,0,,\Nแสดงว่าคนนี้คือคู่ค้าของบิชอป
Dialogue: 0,0:22:14.70,0:22:16.25,Default,,0,0,0,,มาพิสูจน์ดูกันเถอะ
Dialogue: 0,0:22:16.25,0:22:17.77,Default,,0,0,0,,จะทำยังไงละ?
Dialogue: 0,0:22:18.04,0:22:23.18,Default,,0,0,0,,ตารางรหัสของราชเลขาธิการ\Nที่เราเคยทำไว้สามารถใช้ถอดรหัสได้
Dialogue: 0,0:22:23.18,0:22:23.99,Default,,0,0,0,,ก็จะได้คําตอบ
Dialogue: 0,0:22:35.60,0:22:36.60,Default,,0,0,0,,เสร็จแล้ว
Dialogue: 0,0:22:37.50,0:22:38.97,Default,,0,0,0,,ไหนดูหน่อยซิ
Dialogue: 0,0:22:39.50,0:22:42.17,Default,,0,0,0,,"บริษัท แอนดี้ & เดวิด
Dialogue: 0,0:22:42.17,0:22:45.40,Default,,0,0,0,,ราชินีแห่งภูตและดราก้อนภูเขาไฟ
Dialogue: 0,0:22:45.40,0:22:47.99,Default,,0,0,0,,กล่องใหญ่ 3 กล่องกลาง 3"
Dialogue: 0,0:22:47.99,0:22:51.08,Default,,0,0,0,,"วันพฤหัสบดีที่สาม เวลา 6 โมงเช้า
Dialogue: 0,0:22:51.08,0:22:53.77,Default,,0,0,0,,ท่าเรือเทมส์ ท่าเทียบเรือที่ 8"
Dialogue: 0,0:22:53.77,0:22:55.76,Default,,0,0,0,,หมายความว่ายังไงกันคะ
Dialogue: 0,0:22:56.84,0:22:59.92,Default,,0,0,0,,นี่คือบริษัทที่เชี่ยวชาญด้านการออกแบบโรงละครไม่ใช่เหรอ
Dialogue: 0,0:22:59.92,0:23:01.08,Default,,0,0,0,,งั้นเหรอ
Dialogue: 0,0:23:01.54,0:23:04.20,Default,,0,0,0,,\Nระเบิดคาโวไรต์ค่อนข้างสะดุดตา
Dialogue: 0,0:23:04.20,0:23:07.77,Default,,0,0,0,,เลยใช้ชื่ออุปกรณ์ประกอบฉากบังหน้าขนย้ายสินะ
Dialogue: 0,0:23:08.41,0:23:10.04,Default,,0,0,0,,หรือก็คือ…
Dialogue: 0,0:23:10.66,0:23:15.04,Default,,0,0,0,,แค่สำรวจดูว่ามีโรงละครที่ไหน\Nในลอนดอนที่ใช้ชื่อรายการแบบนี้...
Dialogue: 0,0:23:26.50,0:23:29.39,Default,,0,0,0,,สิ่งมีชีวิตประหลาดนั่นมันอะไรกันนะ
Dialogue: 0,0:23:29.39,0:23:31.02,Default,,0,0,0,,นั่นคือไดโนเสาร์
Dialogue: 0,0:23:31.02,0:23:35.23,Default,,0,0,0,,มีชีวิตอยู่เมื่อนานมาแล้ว เป็นบรรพบุรุษของมนุษย์ดาวจิ้งจกดำ
Dialogue: 0,0:23:36.79,0:23:39.30,Default,,0,0,0,,อย่าไปเชื่อเธอนะ คุณจิเซะ
Dialogue: 0,0:23:41.67,0:23:45.53,Default,,0,0,0,,องค์หญิง ยินดีต้อนรับสู่การมาเยือนของท่านครับ
Dialogue: 0,0:23:45.53,0:23:47.86,Default,,0,0,0,,ทั้ง ๆ ที่เป็นการร้องขอแบบกะทันหัน
Dialogue: 0,0:23:47.86,0:23:51.79,Default,,0,0,0,,แต่ก็ยังช่วยเตรียมที่นั่งให้ ขอบคุณมากจริง ๆ ค่ะ
Dialogue: 0,0:23:51.79,0:23:56.18,Default,,0,0,0,,ไม่หรอก เรื่องเล็กน้อยแค่นี้ไม่เป็นไรหรอกครับ
Dialogue: 0,0:23:56.18,0:23:57.94,Default,,0,0,0,,เชิญทางนี้ครับ
Dialogue: 0,0:24:00.04,0:24:04.15,Default,,0,0,0,,สมกับที่เป็นองค์หญิง\N ราชวงศ์ไม่ธรรมดาจริง ๆ
Dialogue: 0,0:24:04.43,0:24:05.59,Default,,0,0,0,,แน่นอนอยู่แล้ว
Dialogue: 0,0:24:05.90,0:24:09.47,Default,,0,0,0,,แม้แต่ในดาวจิ้งจกดำ องค์หญิงก็มีชื่อเสียงโด่งดัง
Dialogue: 0,0:24:09.47,0:24:12.96,Default,,0,0,0,,ฉันหมายถึงประเทศนี้น่ะ
Dialogue: 0,0:24:12.96,0:24:15.22,Default,,0,0,0,,บังเอิญจัง ฉันก็ด้วย
Dialogue: 0,0:24:20.78,0:24:23.42,Default,,0,0,0,,ดราก้อนไอน้ำต้องคำสาป
Dialogue: 0,0:24:23.42,0:24:25.83,Default,,0,0,0,,ฉันจะแทงทะลุเหล็กแผ่นที่น่ารังเกียจนั่น
Dialogue: 0,0:24:25.83,0:24:28.59,Default,,0,0,0,,ผู้จัดการ นั่นก็เป็นสิ่งมีชีวิตที่เรียกว่า "ไดโนเสาร์" ด้วยเหรอ
Dialogue: 0,0:24:25.83,0:24:28.59,Default,,0,0,0,,{\an8}ดึงอวัยวะภายในที่ร้อนระอุของแกออกมา
Dialogue: 0,0:24:28.59,0:24:29.38,Default,,0,0,0,,ผู้จัดการ นั่นก็เป็นสิ่งมีชีวิตที่เรียกว่า "ไดโนเสาร์" ด้วยเหรอ
Dialogue: 0,0:24:28.94,0:24:29.58,Default,,0,0,0,,{\an8}เปลวไฟจากการเผาไหม้ก๊าซ และกำมะถันที่พ่นออกมาจากปาก
Dialogue: 0,0:24:29.58,0:24:29.85,Default,,0,0,0,,{\an8}เปลวไฟจากการเผาไหม้ก๊าซ และกำมะถันที่พ่นออกมาจากปาก
Dialogue: 0,0:24:29.85,0:24:31.82,Default,,0,0,0,,\Nไม่ครับ นั่นเรียกว่า "ดราก้อน" ครับ
Dialogue: 0,0:24:29.85,0:24:31.82,Default,,0,0,0,,{\an8}เปลวไฟจากการเผาไหม้ก๊าซ และกำมะถันที่พ่นออกมาจากปาก
Dialogue: 0,0:24:31.82,0:24:32.64,Default,,0,0,0,,ไม่ครับ นั่นเรียกว่า "ดราก้อน" ครับ
Dialogue: 0,0:24:31.82,0:24:32.64,Default,,0,0,0,,{\an8}ไม่สามารถทำอะไรฉันได้
Dialogue: 0,0:24:32.64,0:24:33.67,Default,,0,0,0,,ดราก้อน…
Dialogue: 0,0:24:32.64,0:24:33.67,Default,,0,0,0,,{\an8}ไม่สามารถทำอะไรฉันได้
Dialogue: 0,0:24:33.67,0:24:33.96,Default,,0,0,0,,ดราก้อน…\N
Dialogue: 0,0:24:34.49,0:24:38.65,Default,,0,0,0,,นักรบของประเทศนี้ \Nเคยต่อสู้กับสิ่งมีชีวิตแบบนั้นจริง ๆ เหรอ
Dialogue: 0,0:24:34.49,0:24:38.65,Default,,0,0,0,,{\an8}วัลฮัลลาอันงดงามกำลังรอคอยฉันอยู่
Dialogue: 0,0:24:38.65,0:24:38.69,Default,,0,0,0,,นักรบของประเทศนี้ เคยต่อสู้กับสิ่งมีชีวิตแบบนั้นจริง ๆ เหรอ
Dialogue: 0,0:24:38.69,0:24:40.64,Default,,0,0,0,,{\an8}ร่างของฉัน…
Dialogue: 0,0:24:45.95,0:24:50.27,Default,,0,0,0,,ขอร้องล่ะ กินข้าวด้วยกันหน่อยไม่ได้เหรอ ฉันเลี้ยงเอง
Dialogue: 0,0:24:50.27,0:24:51.89,Default,,0,0,0,,พอแค่นี้เถอะ
Dialogue: 0,0:24:51.89,0:24:57.21,Default,,0,0,0,,เป็นหนี้เป็นสินอยู่แท้ ๆ ยังกล้ามาจีบสาวอีกนะ
Dialogue: 0,0:24:58.02,0:24:59.31,Default,,0,0,0,,โอ้ เกิดอะไรขึ้น ทะเลาะกันเรื่องความรักเหรอ\N
Dialogue: 0,0:24:58.02,0:24:59.31,Default,,0,0,0,,{\an8}เธอรู้ได้ยังไง…
Dialogue: 0,0:24:59.31,0:24:59.54,Default,,0,0,0,,โอ้ เกิดอะไรขึ้น ทะเลาะกันเรื่องความรักเหรอ
Dialogue: 0,0:24:59.54,0:25:01.68,Default,,0,0,0,,โอ้ เกิดอะไรขึ้น ทะเลาะกันเรื่องความรักเหรอ
Dialogue: 0,0:24:59.54,0:25:01.68,Default,,0,0,0,,{\an8}ก่อนหน้านี้พวกทวงหนี้ตามมาถึงหลังเวทีเลยนะ
Dialogue: 0,0:25:01.68,0:25:02.68,Default,,0,0,0,,{\an8}ก่อนหน้านี้พวกทวงหนี้ตามมาถึงหลังเวทีเลยนะ
Dialogue: 0,0:25:01.68,0:25:02.68,Default,,0,0,0,,ยุ่งแล้ว
Dialogue: 0,0:25:02.68,0:25:02.69,Default,,0,0,0,,ยุ่งแล้ว
Dialogue: 0,0:25:02.69,0:25:02.94,Default,,0,0,0,,ชอบสร้างความเดือดร้อนให้คนอื่นจริง ๆ เลยนะ
Dialogue: 0,0:25:02.94,0:25:05.73,Default,,0,0,0,,\Nชอบสร้างความเดือดร้อนให้คนอื่นจริง ๆ เลยนะ
Dialogue: 0,0:25:02.94,0:25:05.73,Default,,0,0,0,,{\an8}นั่นเป็นทางผ่านไปโกดังนะ
Dialogue: 0,0:25:05.73,0:25:08.96,Default,,0,0,0,,หลีกทางไป ฉันต้องขึ้นแสดงแล้ว
Dialogue: 0,0:25:08.96,0:25:10.36,Default,,0,0,0,,เมรี่~
Dialogue: 0,0:25:16.29,0:25:18.80,Default,,0,0,0,,เฮ้อ น่าสงสารจัง
Dialogue: 0,0:25:19.20,0:25:20.67,Default,,0,0,0,,ไปกันเถอะ โดโรธี
Dialogue: 0,0:25:20.94,0:25:22.02,Default,,0,0,0,,ได้จ้ะ
Dialogue: 0,0:25:38.18,0:25:40.31,Default,,0,0,0,,ที่นี่ใช้ได้นานแค่ไหน
Dialogue: 0,0:25:40.31,0:25:43.81,Default,,0,0,0,,นานแค่ไหนก็ได้ ไม่มีใครสังเกตหรอก
Dialogue: 0,0:25:44.17,0:25:47.46,Default,,0,0,0,,ปกติก็เอาไว้กองของทิ้งอยู่แล้ว
Dialogue: 0,0:25:47.46,0:25:50.43,Default,,0,0,0,,จริงเหรอ ดีเลย
Dialogue: 0,0:25:50.43,0:25:52.01,Default,,0,0,0,,ฉันก็ไม่ได้จะอยู่นาน
Dialogue: 0,0:25:52.45,0:25:54.14,Default,,0,0,0,,เฮ้ คน ๆ นั้น…
Dialogue: 0,0:25:54.40,0:25:54.80,Default,,0,0,0,,อืม เป็นคนในรูป
Dialogue: 0,0:25:54.80,0:25:56.31,Default,,0,0,0,,\Nอืม เป็นคนในรูป
Dialogue: 0,0:25:54.80,0:25:56.31,Default,,0,0,0,,{\an8}เปิดหีบตรวจสอบสินค้า
Dialogue: 0,0:25:56.31,0:25:56.40,Default,,0,0,0,,เปิดหีบตรวจสอบสินค้า
Dialogue: 0,0:25:56.40,0:25:57.45,Default,,0,0,0,,ครับ
Dialogue: 0,0:26:07.84,0:26:09.34,Default,,0,0,0,,เข้าเป้า
Dialogue: 0,0:26:09.34,0:26:11.67,Default,,0,0,0,,ก็ยังดีที่เจอทั้งสามลูกอยู่ที่นี่
Dialogue: 0,0:26:11.98,0:26:14.26,Default,,0,0,0,,กล่องมีขนาดเล็กกลางใหญ่ อย่างละสามกล่องใช่ไหม
Dialogue: 0,0:26:14.60,0:26:16.60,Default,,0,0,0,,กลับไปตรวจสอบอีกทีดีกว่า
Dialogue: 0,0:26:16.60,0:26:18.11,Default,,0,0,0,,หัวหน้า
Dialogue: 0,0:26:19.10,0:26:21.36,Default,,0,0,0,,อ้าว กำลังยุ่งอยู่เหรอ
Dialogue: 0,0:26:21.36,0:26:23.73,Default,,0,0,0,,บิลลี่ มาทำอะไร
Dialogue: 0,0:26:23.73,0:26:27.35,Default,,0,0,0,,คือว่า…ผมอยากจะมาเบิกล่วงหน้าหน่อยครับ
Dialogue: 0,0:26:27.35,0:26:28.48,Default,,0,0,0,,อะไรนะ
Dialogue: 0,0:26:28.48,0:26:32.33,Default,,0,0,0,,รู้ตัวหน่อยสิ บอกแล้วว่าที่เหลือจะจ่ายให้หลังขนเสร็จ
Dialogue: 0,0:26:32.33,0:26:33.56,Default,,0,0,0,,แกนี่…
Dialogue: 0,0:26:33.91,0:26:35.21,Default,,0,0,0,,ไม่เป็นไร
Dialogue: 0,0:26:35.21,0:26:36.99,Default,,0,0,0,,ชื่อบิลลี่ใช่ไหม
Dialogue: 0,0:26:36.99,0:26:40.38,Default,,0,0,0,,เอาล่ะ มาคุยกับฉันหน่อย
Dialogue: 0,0:26:41.08,0:26:43.31,Default,,0,0,0,,ฮิฮิ แบบนี้สิถึงจะถูก
Dialogue: 0,0:26:43.31,0:26:47.68,Default,,0,0,0,,D รายงานมาว่าพบระเบิดและอุปกรณ์ควบคุมแล้วค่ะ
Dialogue: 0,0:26:47.68,0:26:50.47,Default,,0,0,0,,ระเบิดที่ถูกขโมยทั้งสามลูกอยู่ครบ
Dialogue: 0,0:26:50.47,0:26:53.87,Default,,0,0,0,,เป้าหมายในการตรวจสอบก็ปรากฏตัวที่หน้างานแล้วค่ะ
Dialogue: 0,0:26:53.87,0:26:56.45,Default,,0,0,0,,\Nโรงละครวิคเกอร์สสตรีมเหรอครับ
Dialogue: 0,0:26:56.45,0:27:00.11,Default,,0,0,0,,ซ่อนอยู่ในที่แบบนั้นได้ ฝ่ายตรงข้ามก็ทุ่มเทไม่น้อยเลยนะ
Dialogue: 0,0:27:00.11,0:27:03.18,Default,,0,0,0,,ในเมื่อรู้แล้ว ก็รีบส่งคนไปชิงกลับมาสิ
Dialogue: 0,0:27:03.18,0:27:08.05,Default,,0,0,0,,หากอุปกรณ์ควบคุมถูกศึกษาจนหมด \Nสาธารณรัฐจะเสียเปรียบ
Dialogue: 0,0:27:08.05,0:27:11.14,Default,,0,0,0,,การนำกลับคืนอย่างลับ ๆ \Nผ่านทางโรงงานในอาณาจักรเป็นเรื่องยาก
Dialogue: 0,0:27:11.14,0:27:12.94,Default,,0,0,0,,ขนาดใหญ่เกินไป
Dialogue: 0,0:27:12.94,0:27:14.87,Default,,0,0,0,,ควรจะทำลายมันทิ้ง
Dialogue: 0,0:27:14.87,0:27:19.08,Default,,0,0,0,,คำสั่งจากเบื้องบนคือชิงกลับมา ไม่ใช่ทำลาย
Dialogue: 0,0:27:21.06,0:27:24.71,Default,,0,0,0,,พวกเรารู้ดีถึงคำสั่งของทหาร
Dialogue: 0,0:27:25.15,0:27:27.52,Default,,0,0,0,,ตรวจสอบตารางการแสดงของโรงละคร
Dialogue: 0,0:27:28.41,0:27:31.30,Default,,0,0,0,,ฉันจะจัดทีมชิงระเบิดกลับมา
Dialogue: 0,0:27:31.30,0:27:32.65,Default,,0,0,0,,รับทราบ
Dialogue: 0,0:27:44.73,0:27:49.20,Default,,0,0,0,,คุณโดโรธี การเฝ้าสังเกตครั้งนี้จะต้องดำเนินไปนานแค่ไหนกันคะ
Dialogue: 0,0:27:49.20,0:27:53.74,Default,,0,0,0,,พอการแสดงจบลงในอีกหนึ่งสัปดาห์ ก็จะเริ่มเตรียมงานสำหรับการแสดงรอบต่อไป
Dialogue: 0,0:27:53.74,0:27:58.60,Default,,0,0,0,,เมื่อถึงตอนนั้นหลายทีมจะรวมตัวกัน \Nเพื่อเริ่มปฏิบัติการชิงกลับคืน
Dialogue: 0,0:27:58.96,0:28:01.37,Default,,0,0,0,,นั่น…จะไม่มีปัญหาเหรอคะ
Dialogue: 0,0:28:01.37,0:28:06.87,Default,,0,0,0,,ดูเหมือนเบื้องบนจะยอมทำทุกวิถีทางเพื่อชิงระเบิดกลับคืนมา
Dialogue: 0,0:28:07.47,0:28:10.39,Default,,0,0,0,,พวกคุณโดโรธีคงไม่ต้องไปใช่ไหมคะ?
Dialogue: 0,0:28:12.27,0:28:13.60,Default,,0,0,0,,นี่…
Dialogue: 0,0:28:22.70,0:28:23.71,Default,,0,0,0,,ใครน่ะ
Dialogue: 0,0:28:23.71,0:28:25.51,Default,,0,0,0,,\Nบริษัทประกันเวดจ์วูด
Dialogue: 0,0:28:26.32,0:28:28.41,Default,,0,0,0,,สามีของฉันไม่อยู่บ้าน
Dialogue: 0,0:28:28.74,0:28:31.37,Default,,0,0,0,,งั้น ให้พวกเราเข้าไปรอข้างในได้ไหม
Dialogue: 0,0:28:36.94,0:28:38.34,Default,,0,0,0,,ถึงเวลาเปลี่ยนเวรแล้ว
Dialogue: 0,0:28:38.34,0:28:39.53,Default,,0,0,0,,ค่ะ…
Dialogue: 0,0:28:46.00,0:28:49.80,Default,,0,0,0,,องค์รัชทายาท อีก 30 นาทีจะเป็น…
Dialogue: 0,0:28:50.28,0:28:51.75,Default,,0,0,0,,ฉันเข้าใจ
Dialogue: 0,0:28:51.75,0:28:55.92,Default,,0,0,0,,ต่อไปจะต้องไปพูดคุยกับสมาคมลูกเรือ \Nและพิธีมอบเหรียญเกียรติยศ
Dialogue: 0,0:28:55.92,0:28:58.65,Default,,0,0,0,,ช่วงเย็นยังมีงานเลี้ยงรับรองพระราชาแห่งแซนซิบาร์
Dialogue: 0,0:29:00.08,0:29:03.74,Default,,0,0,0,,เรื่องที่ริชาร์ดถูกยิง ทำให้ประเทศค่อนข้างปั่นป่วนเลยล่ะ
Dialogue: 0,0:29:04.57,0:29:07.14,Default,,0,0,0,,สถานการณ์ไม่อนุญาตให้ฉันบ่นอะไรได้
Dialogue: 0,0:29:07.16,0:29:11.09,Default,,0,0,0,,เรื่องสมาคมลูกเรือ อาจจะยกให้เมรี่ไปทำแทนก็ได้
Dialogue: 0,0:29:11.09,0:29:12.40,Default,,0,0,0,,ไม่สิ
Dialogue: 0,0:29:12.40,0:29:15.58,Default,,0,0,0,,ให้เธอเรียนรู้งานไปพลาง ๆ เริ่มจากพิธีบนเรือในอีก 3 วัน
Dialogue: 0,0:29:16.07,0:29:19.28,Default,,0,0,0,,ครั้งนี้ให้ผมจัดการตามกำหนดการเดิม
Dialogue: 0,0:29:19.75,0:29:24.78,Default,,0,0,0,,เมื่อเทียบกับการเรียนรู้เพื่อเป็นจักรพรรดิ\Nที่ท่านลุงเคยเจอมา เรื่องนี้ถือว่าเล็กน้อยมาก
Dialogue: 0,0:29:24.78,0:29:28.92,Default,,0,0,0,,โชคดีที่นายเป็นคนเข้มแข็งนะ เอ็ดเวิร์ด
Dialogue: 0,0:29:29.68,0:29:31.79,Default,,0,0,0,,งั้นอีก 30 นาทีเจอกัน
Dialogue: 0,0:29:34.79,0:29:39.77,Default,,0,0,0,,ย่าขอโทษด้วยนะ ทั้ง ๆ ที่สภาพของเธอแย่กว่า
Dialogue: 0,0:29:39.77,0:29:42.30,Default,,0,0,0,,เรื่องแค่นี้ไม่เป็นอะไรหรอกครับ
Dialogue: 0,0:29:42.30,0:29:44.38,Default,,0,0,0,,แค่ปวดไหล่นิดหน่อยเอง
Dialogue: 0,0:29:44.68,0:29:48.31,Default,,0,0,0,,คุณย่าต่างหากที่ควรดูแลตัวเองให้ดีนะครับ
Dialogue: 0,0:29:48.31,0:29:51.13,Default,,0,0,0,,ช่วงนี้ย่ารู้สึกกระปรี้กระเปร่ามาก
Dialogue: 0,0:29:51.43,0:29:54.18,Default,,0,0,0,,อาจจะเป็นเพราะได้เจอเธอก็ได้นะ
Dialogue: 0,0:29:54.36,0:29:57.97,Default,,0,0,0,,ถ้าอย่างนั้นก็ดีครับ\N การกลับประเทศครั้งนี้ของผมก็คุ้มค่าแล้ว
Dialogue: 0,0:29:58.30,0:30:02.17,Default,,0,0,0,,จริง ๆ แล้วย่าไม่อยากส่งเธอไปทวีปใหม่เลย
Dialogue: 0,0:30:02.43,0:30:06.33,Default,,0,0,0,,ช่วยไม่ได้ นี่เป็นการตัดสินใจของท่านลุงครับ
Dialogue: 0,0:30:07.10,0:30:10.31,Default,,0,0,0,,ผมได้เชิญชาร์ล็อตต์ให้มาร่วมงานเลี้ยงอาหารค่ำ
Dialogue: 0,0:30:10.31,0:30:14.83,Default,,0,0,0,,การที่ให้เธอมาแบกรับเรื่องยุ่งยากเหล่านี้อยู่เสมอ\N ทำให้ผมรู้สึกไม่ดีเลย
Dialogue: 0,0:30:14.83,0:30:18.73,Default,,0,0,0,,เพราะมันเป็นช่วงเวลาที่พิเศษ เธอจะต้องเข้าใจ
Dialogue: 0,0:30:20.55,0:30:23.84,Default,,0,0,0,,อย่างที่ท่านลุงพูด เรื่องที่ผมเจอมานั้น
Dialogue: 0,0:30:23.84,0:30:26.01,Default,,0,0,0,,คงจะไม่จบลงแค่นี้หรอกครับ
Dialogue: 0,0:30:26.60,0:30:28.81,Default,,0,0,0,,ก็ไม่รู้ว่าคนร้ายคือใคร…
Dialogue: 0,0:30:29.21,0:30:31.50,Default,,0,0,0,,ไม่แน่ว่าอาจจะเล็งเป้าหมายไปที่คนอื่น ๆ
Dialogue: 0,0:30:32.24,0:30:35.10,Default,,0,0,0,,นั่นเป็นงานของวิลเลียม
Dialogue: 0,0:30:35.10,0:30:37.85,Default,,0,0,0,,เธอไม่ต้องกังวลเรื่องนั้นนะ
Dialogue: 0,0:30:38.56,0:30:43.04,Default,,0,0,0,,ใต้บังคับบัญชาของผมมีกองทัพที่ปราบทวีปใหม่มาแล้ว
Dialogue: 0,0:30:44.62,0:30:48.70,Default,,0,0,0,,หากมีใครคิดจะทำร้ายประเทศนี้ และครอบครัวของผม
Dialogue: 0,0:30:49.12,0:30:52.87,Default,,0,0,0,,ผมจะใช้สิทธิทางทหารโดยไม่ลังเล
Dialogue: 0,0:30:56.64,0:30:58.45,Default,,0,0,0,,น่าหวาดเสียวจริง ๆ
Dialogue: 0,0:30:58.45,0:30:59.63,Default,,0,0,0,,อืม
Dialogue: 0,0:31:00.63,0:31:02.01,Default,,0,0,0,,องค์หญิงชาร์ล็อตต์คะ
Dialogue: 0,0:31:05.13,0:31:06.42,Default,,0,0,0,,เมรี่เหรอ
Dialogue: 0,0:31:06.74,0:31:08.01,Default,,0,0,0,,ใช่ค่ะ
Dialogue: 0,0:31:08.01,0:31:10.85,Default,,0,0,0,,ตั้งแต่เกิดเรื่องขององค์ชายริชาร์ด
Dialogue: 0,0:31:10.85,0:31:13.79,Default,,0,0,0,,เธอก็ซึมเศร้ากว่าเมื่อก่อนมาก
Dialogue: 0,0:31:14.52,0:31:17.26,Default,,0,0,0,,และยังมีงานราชการที่ต้องจัดการคนเดียวเพิ่มขึ้นอีก
Dialogue: 0,0:31:17.26,0:31:20.41,Default,,0,0,0,,ฉันไม่สามารถอยู่เคียงข้างเธอได้เลย
Dialogue: 0,0:31:24.57,0:31:28.41,Default,,0,0,0,,จะไปร่วมงานพิธีบนเรือสำราญหลวงในวันพรุ่งนี้ด้วยกันไหม
Dialogue: 0,0:31:28.41,0:31:29.36,Default,,0,0,0,,ค่ะ
Dialogue: 0,0:31:29.91,0:31:35.85,Default,,0,0,0,,ยังไงซะก็ไม่มีตารางอื่นอยู่แล้ว ฉันก็อยากจะเข้าร่วมพิธีด้วย
Dialogue: 0,0:31:35.85,0:31:37.93,Default,,0,0,0,,เป็นยังไงบ้างคะ ได้ไหม
Dialogue: 0,0:31:38.59,0:31:40.43,Default,,0,0,0,,ดี…ดีเลยค่ะ
Dialogue: 0,0:31:42.60,0:31:44.04,Default,,0,0,0,,เข้าใจแล้วค่ะ
Dialogue: 0,0:31:44.04,0:31:47.30,Default,,0,0,0,,พรุ่งนี้จะเพิ่มกำลังเจ้าหน้าที่\Nรักษาความปลอดภัยบนเรือให้เหมาะสม
Dialogue: 0,0:31:47.30,0:31:52.00,Default,,0,0,0,,{\an8}งั้น ให้ฉันอธิบายขั้นตอนของพิธี\Nบนเรือสำราญก่อนนะคะ เชิญนั่งค่ะ
Dialogue: 0,0:31:52.00,0:31:52.99,Default,,0,0,0,,ค่ะ
Dialogue: 0,0:31:56.89,0:32:00.60,Default,,0,0,0,,จู่ ๆ ก็ตัดสินใจจะไปงานบนเรือหลวงเลยเหรอเนี่ย
Dialogue: 0,0:32:01.40,0:32:04.49,Default,,0,0,0,,ขอโทษด้วยนะ ที่ตัดสินใจไปเอง
Dialogue: 0,0:32:04.49,0:32:05.93,Default,,0,0,0,,ไม่เป็นไร
Dialogue: 0,0:32:06.72,0:32:08.99,Default,,0,0,0,,เรื่องการเฝ้าสังเกต พวกเราสามารถรับมือได้
Dialogue: 0,0:32:08.99,0:32:10.89,Default,,0,0,0,,ขอบคุณนะ แองเจ
Dialogue: 0,0:32:11.74,0:32:14.75,Default,,0,0,0,,ฉันอดเป็นห่วงเมรี่ไม่ได้จริง ๆ
Dialogue: 0,0:32:15.42,0:32:17.45,Default,,0,0,0,,เด็กคนนั้นก็สูญเสียพ่อแม่ไปเหมือนกัน
Dialogue: 0,0:32:17.72,0:32:21.98,Default,,0,0,0,,ต้องแบกรับหน้าที่และข้อกำหนด\Nของการเป็นเชื้อพระวงศ์มาโดยตลอด
Dialogue: 0,0:32:22.57,0:32:25.42,Default,,0,0,0,,เหมือนกับเธอในอดีตนั่นแหละ
Dialogue: 0,0:32:26.64,0:32:29.44,Default,,0,0,0,,สำหรับเด็กแล้ว โลกนั้นมันยากลำบากจริง ๆ
Dialogue: 0,0:32:31.51,0:32:34.93,Default,,0,0,0,,ถ้าตอนนั้นฉัน มีพี่สาวแบบเธอ
Dialogue: 0,0:32:34.93,0:32:37.77,Default,,0,0,0,,บางทีฉันคงจะทนอยู่ในเมืองนั้นได้
Dialogue: 0,0:32:39.44,0:32:43.59,Default,,0,0,0,,พี่สาวคนนี้…ไม่ได้ดีอย่างที่เธอคิดหรอกนะ
Dialogue: 0,0:32:57.21,0:32:59.60,Default,,0,0,0,,มากันอีกแล้วสินะ พวกนั้น
Dialogue: 0,0:33:01.32,0:33:03.11,Default,,0,0,0,,ถึงเวลาเปลี่ยนเวรแล้ว
Dialogue: 0,0:33:25.71,0:33:29.61,Default,,0,0,0,,เจ้าหน้าที่ภาคสนามที่ประจำการอยู่ ไม่ได้ติดต่อมาตามกำหนด
Dialogue: 0,0:33:29.61,0:33:35.12,Default,,0,0,0,,สถานที่เฝ้าสังเกตโรงละครทั้งหมด อาจจะถูกใครบางคนโจมตี
Dialogue: 0,0:33:35.12,0:33:38.60,Default,,0,0,0,,ฉันบอกแล้วว่าตอนนั้นควรรีบไปชิงกลับมา
Dialogue: 0,0:33:38.60,0:33:40.16,Default,,0,0,0,,คราวนี้จะทำยังไงดี
Dialogue: 0,0:33:40.65,0:33:43.71,Default,,0,0,0,,ติดต่อทีมกู้คืน ให้เริ่มภารกิจเร็วขึ้น
Dialogue: 0,0:33:43.71,0:33:46.61,Default,,0,0,0,,แต่ยังไม่ทราบความสามารถในการต่อสู้ของอีกฝ่ายเลยนะคะ
Dialogue: 0,0:33:46.61,0:33:49.80,Default,,0,0,0,,ถ้านานไป จะยากที่จะจับร่องรอยของอีกฝ่ายได้
Dialogue: 0,0:33:49.80,0:33:53.62,Default,,0,0,0,,\Nหากคาโวไรต์ถูกจุดระเบิดในอาณาจักร
Dialogue: 0,0:33:53.62,0:33:55.31,Default,,0,0,0,,จะก่อให้เกิดสงครามขึ้นทันที
Dialogue: 0,0:33:55.61,0:33:59.81,Default,,0,0,0,,สิ่งที่เราต้องการคือการควบคุม ไม่ใช่เปลวไฟ
Dialogue: 0,0:33:59.81,0:34:02.89,Default,,0,0,0,,พอเตรียมการเสร็จแล้ว ให้เริ่มปฏิบัติการทันที
Dialogue: 0,0:34:03.46,0:34:06.19,Default,,0,0,0,,การชิงระเบิดกลับมาต้องมาก่อนสิ่งอื่นใด
Dialogue: 0,0:34:32.34,0:34:34.36,Default,,0,0,0,,จิเซะ มีคำสั่งเรียกตัว
Dialogue: 0,0:34:40.23,0:34:42.33,Default,,0,0,0,,สถานที่เฝ้าสังเกตถูกทำลายทั้งหมดเหรอ…
Dialogue: 0,0:34:42.60,0:34:43.35,Default,,0,0,0,,อืม
Dialogue: 0,0:34:43.35,0:34:45.74,Default,,0,0,0,,ยากที่จะเข้าใจจริง ๆ
Dialogue: 0,0:34:45.74,0:34:48.46,Default,,0,0,0,,\Nคอนโทรลกำลังตรวจสอบเรื่องนี้อยู่
Dialogue: 0,0:34:48.46,0:34:51.87,Default,,0,0,0,,งั้น จะชิงระเบิดกลับมายังไงดี
Dialogue: 0,0:34:52.49,0:34:54.62,Default,,0,0,0,,ทีมอื่น ๆ รับผิดชอบในการล่อ
Dialogue: 0,0:34:54.62,0:34:58.37,Default,,0,0,0,,พวกเราใช้โอกาสนั้นในการตรวจสอบว่าระเบิดยังอยู่ที่เดิมหรือไม่
Dialogue: 0,0:34:58.37,0:35:02.24,Default,,0,0,0,,ถ้ายังอยู่ในนั้น ให้ขนออกมา
Dialogue: 0,0:35:02.24,0:35:04.62,Default,,0,0,0,,แผนนี้ดูจะหุนหันพลันแล่นไปหน่อยนะ
Dialogue: 0,0:35:04.91,0:35:06.87,Default,,0,0,0,,เพราะเป็นเรื่องใหญ่
Dialogue: 0,0:35:06.87,0:35:10.20,Default,,0,0,0,,สาธารณรัฐไม่สามารถคำนึงถึงหน้าตาได้อีกต่อไปแล้ว
Dialogue: 0,0:35:13.64,0:35:14.76,Default,,0,0,0,,เริ่มแล้ว
Dialogue: 0,0:35:26.62,0:35:28.15,Default,,0,0,0,,
Dialogue: 0,0:35:32.47,0:35:34.65,Default,,0,0,0,,อ้าว บิลลี่
Dialogue: 0,0:35:34.65,0:35:37.53,Default,,0,0,0,,ดูเหมือนว่าวันนี้แกจะอารมณ์ดีนะ
Dialogue: 0,0:35:37.92,0:35:40.92,Default,,0,0,0,,กระเป๋าคงจะตุงด้วยสินะ
Dialogue: 0,0:35:41.80,0:35:45.49,Default,,0,0,0,,งั้นวันนี้ จ่ายทั้งต้นทั้งดอกเลยนะ
Dialogue: 0,0:35:45.49,0:35:47.32,Default,,0,0,0,,กุหลาบ?
Dialogue: 0,0:35:47.61,0:35:49.49,Default,,0,0,0,,น่าโมโหจริง คราวนี้อย่าหวังว่าจะหนีไปได้อีก
Dialogue: 0,0:35:49.49,0:35:52.16,Default,,0,0,0,,-เจ็บนะ　-อย่าหนีนะ
Dialogue: 0,0:35:54.26,0:35:56.38,Default,,0,0,0,,นั่นแหละคน ๆ นั้น จับตัวเขาไว้
Dialogue: 0,0:35:57.55,0:35:59.07,Default,,0,0,0,,เกิดอะไรขึ้นเนี่ย
Dialogue: 0,0:35:59.07,0:36:00.97,Default,,0,0,0,,โอ้ สวรรค์ ทำไมมีแต่ลูกปืน
Dialogue: 0,0:36:26.87,0:36:28.77,Default,,0,0,0,,หายไปหนึ่งกล่อง
Dialogue: 0,0:36:28.77,0:36:31.42,Default,,0,0,0,,สรุปแล้วถูกขนออกไปแล้วเหรอ
Dialogue: 0,0:36:32.31,0:36:33.38,Default,,0,0,0,,หัว…หัวหน้า
Dialogue: 0,0:36:33.38,0:36:35.75,Default,,0,0,0,,ด้านหลังมีพวกถือปืน
Dialogue: 0,0:36:35.75,0:36:37.13,Default,,0,0,0,,อะไรนะ
Dialogue: 0,0:36:38.31,0:36:40.30,Default,,0,0,0,,หัวหน้า…ไปไหน
Dialogue: 0,0:36:40.30,0:36:42.05,Default,,0,0,0,,เขาบอกว่าจะจ่ายเงินให้ผม…
Dialogue: 0,0:36:42.05,0:36:44.10,Default,,0,0,0,,ที่ประตูหน้าเกิดความวุ่นวาย เขาไปทางนั้น
Dialogue: 0,0:36:45.23,0:36:46.60,Default,,0,0,0,,เดี๋ยวสิ
Dialogue: 0,0:36:46.60,0:36:49.03,Default,,0,0,0,,แกบอกว่าใครจะจ่ายเงินให้แกนะ?
Dialogue: 0,0:36:49.03,0:36:50.10,Default,,0,0,0,,นี่…
Dialogue: 0,0:36:50.10,0:36:52.08,Default,,0,0,0,,เกิดอะไรขึ้นที่นี่
Dialogue: 0,0:36:52.08,0:36:53.31,Default,,0,0,0,,นี่…
Dialogue: 0,0:36:54.11,0:36:56.06,Default,,0,0,0,,เป็นฝีมือของสาธารณรัฐเหรอครับ
Dialogue: 0,0:36:56.06,0:36:58.86,Default,,0,0,0,,ใครจะรู้ ใครก็ช่าง
Dialogue: 0,0:36:58.86,0:37:01.37,Default,,0,0,0,,รอคำสั่งจากฝ่าบาทต่อไปไม่ได้แล้ว
Dialogue: 0,0:37:01.63,0:37:04.02,Default,,0,0,0,,รีบไปขนย้ายระเบิดที่เหลือออกไป
Dialogue: 0,0:37:04.02,0:37:05.24,Default,,0,0,0,,ครับ
Dialogue: 0,0:37:08.59,0:37:10.23,Default,,0,0,0,,หัวหน้า
Dialogue: 0,0:37:11.27,0:37:14.00,Default,,0,0,0,,หัวหน้า มีพวกถือปืนบุกเข้ามา
Dialogue: 0,0:37:14.00,0:37:15.00,Default,,0,0,0,,อะไรนะ
Dialogue: 0,0:37:15.00,0:37:17.40,Default,,0,0,0,,ข้างล่างกำลังยิงกันอย่างดุเดือดเลย
Dialogue: 0,0:37:17.40,0:37:18.48,Default,,0,0,0,,จะทำยังไงดีเหรอครับ
Dialogue: 0,0:37:18.48,0:37:19.78,Default,,0,0,0,,ถอยทัพ
Dialogue: 0,0:37:20.73,0:37:23.65,Default,,0,0,0,,เป้าหมายของเราไม่ใช่การปกป้องระเบิด
Dialogue: 0,0:37:23.65,0:37:25.11,Default,,0,0,0,,ให้ลูกน้องถอยไป
Dialogue: 0,0:37:25.11,0:37:26.15,Default,,0,0,0,,ครับ
Dialogue: 0,0:37:27.04,0:37:28.64,Default,,0,0,0,,คือว่า...
Dialogue: 0,0:37:28.64,0:37:30.22,Default,,0,0,0,,{\an8}เดี๋ยวก่อนครับ
Dialogue: 0,0:37:28.64,0:37:30.22,Default,,0,0,0,,ท่าทางจะไม่ได้เงินสินะ
Dialogue: 0,0:37:30.22,0:37:30.95,Default,,0,0,0,,ท่าทางจะไม่ได้เงินสินะ
Dialogue: 0,0:37:30.95,0:37:32.37,Default,,0,0,0,,หรือไม่ก็เอาไว้\Nคราวหน้าค่อยมาเอา?
Dialogue: 0,0:37:32.37,0:37:33.71,Default,,0,0,0,,พูดอะไรโง่ ๆ
Dialogue: 0,0:37:33.71,0:37:36.26,Default,,0,0,0,,สิ่งที่ควรจะได้ ก็ต้องได้มาสิ
Dialogue: 0,0:37:40.40,0:37:42.62,Default,,0,0,0,,เดี๋ยวก่อนครับ
Dialogue: 0,0:37:42.62,0:37:48.20,Default,,0,0,0,,ถ้าจะถอยก็จ่ายเงินมาก่อนได้ไหม ของผมส่งถึงที่แล้วนะครับ
Dialogue: 0,0:37:48.20,0:37:51.50,Default,,0,0,0,,จะจ่ายค่าตอบแทนให้หลังจากที่ภารกิจสำเร็จ
Dialogue: 0,0:37:51.50,0:37:52.88,Default,,0,0,0,,ทำไมถึงเป็นแบบนี้…
Dialogue: 0,0:37:52.88,0:37:53.99,Default,,0,0,0,,ไปกันเถอะ
Dialogue: 0,0:38:00.54,0:38:04.54,Default,,0,0,0,,แกชื่อจอห์นสัน คาร์เตอร์สินะ \Nดูไม่เหมือนผู้จัดการนักแสดงเลยนี่นา
Dialogue: 0,0:38:06.08,0:38:09.39,Default,,0,0,0,,ระเบิดที่อยู่ใต้ดินหายไปลูกหนึ่ง ไปไหนแล้ว
Dialogue: 0,0:38:13.65,0:38:15.87,Default,,0,0,0,,ฮึ่ม ฮึ่ม อย่างนี้นี่เอง
Dialogue: 0,0:38:15.87,0:38:18.56,Default,,0,0,0,,พวกที่มาค้นรังของฉันเหรอ
Dialogue: 0,0:38:19.28,0:38:20.37,Default,,0,0,0,,แล้วยังไง
Dialogue: 0,0:38:20.54,0:38:25.21,Default,,0,0,0,,พวกแกเป็นคนของอาณาจักร หรือคนของสาธารณรัฐ
Dialogue: 0,0:38:29.28,0:38:30.49,Default,,0,0,0,,แกหยุดเดี๋ยวนี้
Dialogue: 0,0:38:32.62,0:38:36.09,Default,,0,0,0,,แกไอ้โง่ เงินฉันไปไหนหมด
Dialogue: 0,0:38:36.09,0:38:39.46,Default,,0,0,0,,หัวหน้าถูกผู้หญิงถือปืนจับตัวไป
Dialogue: 0,0:38:39.46,0:38:42.09,Default,,0,0,0,,ฉันไม่มีเงินให้แล้วเฟ้ย
Dialogue: 0,0:38:42.09,0:38:46.85,Default,,0,0,0,,ให้ทีมกู้คืนพาตัวเขาไป หลังจากนั้นก็ปล่อยให้เป็นเรื่องของผู้ใหญ่
Dialogue: 0,0:38:46.85,0:38:49.46,Default,,0,0,0,,โอ้ เป็นหัวหน้าของพวกแกเหรอ
Dialogue: 0,0:38:49.87,0:38:52.48,Default,,0,0,0,,หวังว่าจะเป็นคนที่พูดจากันรู้เรื่องนะ
Dialogue: 0,0:38:53.69,0:38:55.98,Default,,0,0,0,,แกรักษาสีหน้าได้ใจเย็นดีจริง ๆ
Dialogue: 0,0:39:07.49,0:39:09.11,Default,,0,0,0,,นั่นอะไร
Dialogue: 0,0:39:14.42,0:39:15.75,Default,,0,0,0,,หยุดนะ
Dialogue: 0,0:39:19.38,0:39:20.40,Default,,0,0,0,,แย่แล้ว
Dialogue: 0,0:39:26.80,0:39:28.39,Default,,0,0,0,,เหอ ๆ ไอ้เวร
Dialogue: 0,0:39:38.15,0:39:41.03,Default,,0,0,0,,ห้ามขยับ คราวหน้าไม่พลาดแน่
Dialogue: 0,0:39:42.74,0:39:45.91,Default,,0,0,0,,คราวนี้มันอะไรอีกเนี่ย…
Dialogue: 0,0:39:48.03,0:39:49.29,Default,,0,0,0,,แกจะทำอะไร…
Dialogue: 0,0:40:01.58,0:40:03.10,Default,,0,0,0,,กำลังจะหนีออกไปแล้ว
Dialogue: 0,0:40:03.10,0:40:04.33,Default,,0,0,0,,รู้แล้ว
Dialogue: 0,0:40:05.97,0:40:07.52,Default,,0,0,0,,หลบไป
Dialogue: 0,0:40:18.23,0:40:20.47,Default,,0,0,0,,เป็นทีมที่เข้ามาจากประตูหลัง
Dialogue: 0,0:40:20.47,0:40:22.78,Default,,0,0,0,,ที่นี่ให้พวกนั้นจัดการ พวกเรากลับกัน
Dialogue: 0,0:40:24.28,0:40:26.23,Default,,0,0,0,,-เธอไปก่อนเลย　-โอเค
Dialogue: 0,0:40:33.58,0:40:34.99,Default,,0,0,0,,เป็นยังไงบ้าง จัดการหมดแล้วเหรอ
Dialogue: 0,0:40:34.99,0:40:35.87,Default,,0,0,0,,ไอ้บ้าเอ๊ย
Dialogue: 0,0:40:35.87,0:40:37.00,Default,,0,0,0,,ไอ้บ้าเอ๊ย
Dialogue: 0,0:40:35.87,0:40:37.00,Default,,0,0,0,,{\an8}โอ๊ย
Dialogue: 0,0:40:37.00,0:40:39.93,Default,,0,0,0,,แค่ขายหน้าพวกแกก็พอแล้ว
Dialogue: 0,0:40:39.93,0:40:41.51,Default,,0,0,0,,รีบหนีไป…
Dialogue: 0,0:40:42.84,0:40:45.96,Default,,0,0,0,,ไม่ต้องให้ฉันไปหาถึงบ้านเลยนะ
Dialogue: 0,0:40:45.96,0:40:49.29,Default,,0,0,0,,ฉันก็ยังมีเรื่องที่จะถามแกอีกเยอะเลย
Dialogue: 0,0:40:50.44,0:40:52.18,Default,,0,0,0,,-โอ๊ย แม่เจ้า　-หัวหน้า
Dialogue: 0,0:40:52.18,0:40:54.25,Default,,0,0,0,,เรื่องนี้ไม่เกี่ยวกับผมใช่ไหม
Dialogue: 0,0:40:55.70,0:40:57.71,Default,,0,0,0,,ระเบิดถูกส่งไปที่ไหน
Dialogue: 0,0:40:57.73,0:40:59.80,Default,,0,0,0,,ผ…ผมจะรู้ได้ยังไง…
Dialogue: 0,0:41:00.73,0:41:04.23,Default,,0,0,0,,เมื่อกี้แกไม่ได้บอกเหรอว่าของถูกส่งถึงที่แล้ว
Dialogue: 0,0:41:04.23,0:41:07.34,Default,,0,0,0,,ถ้ารีบตอบ จะไว้ชีวิตแก
Dialogue: 0,0:41:08.32,0:41:11.88,Default,,0,0,0,,แกก็รีบทำตามที่เขาบอกสิ
Dialogue: 0,0:41:11.88,0:41:13.56,Default,,0,0,0,,ที่…ที่ท่าเรือ
Dialogue: 0,0:41:13.56,0:41:15.57,Default,,0,0,0,,ของถูกส่งไปที่ท่าเรือ
Dialogue: 0,0:41:15.57,0:41:16.75,Default,,0,0,0,,ท่าไหน
Dialogue: 0,0:41:16.75,0:41:21.16,Default,,0,0,0,,ท่าเรือลอนดอน บอกว่าจะเอาไปใช้ในงาน
Dialogue: 0,0:41:21.92,0:41:23.32,Default,,0,0,0,,คืองานบนเรือ
Dialogue: 0,0:41:24.13,0:41:24.99,Default,,0,0,0,,รีบไป
Dialogue: 0,0:41:25.48,0:41:28.42,Default,,0,0,0,,งั้น…งั้นพวกเราล่ะ
Dialogue: 0,0:41:31.31,0:41:33.56,Default,,0,0,0,,น่าจะสังเกตให้เร็วกว่านี้
Dialogue: 0,0:41:34.10,0:41:36.49,Default,,0,0,0,,เป้าหมายของพวกมันคือองค์หญิงเมรี่
Dialogue: 0,0:41:36.49,0:41:39.92,Default,,0,0,0,,เก็บระเบิดมานานขนาดนี้ สิ่งที่รอคอยก็คืองานพิธี
Dialogue: 0,0:41:39.92,0:41:41.22,Default,,0,0,0,,หมายความว่ายังไง
Dialogue: 0,0:41:41.22,0:41:44.06,Default,,0,0,0,,\Nพลังของคาโวไรต์นั้นแข็งแกร่งเกินไป
Dialogue: 0,0:41:44.06,0:41:47.58,Default,,0,0,0,,เลยอยากจะรอให้เรือแล่นออกไปในทะเลแล้วค่อยจุดระเบิด
Dialogue: 0,0:41:47.58,0:41:50.87,Default,,0,0,0,,รวมถึงผู้โดยสารด้วย…ช่างต่ำช้าจริง ๆ
Dialogue: 0,0:41:54.39,0:41:57.38,Default,,0,0,0,,ผู้โดยสารมีข้าราชการสำคัญจากหลายประเทศ 300 คน
Dialogue: 0,0:41:57.38,0:42:00.02,Default,,0,0,0,,สำหรับพวกเรา นี่ก็เป็นช่วงเวลาที่แย่ที่สุดเช่นกัน
Dialogue: 0,0:42:00.02,0:42:01.26,Default,,0,0,0,,หมายความว่ายังไง
Dialogue: 0,0:42:01.26,0:42:04.99,Default,,0,0,0,,องค์หญิงและเบียทริซอยู่บนเรือลอนดินิม
Dialogue: 0,0:42:18.79,0:42:20.82,Default,,0,0,0,,ความเร็วของเรือสำราญคือ 16 น็อต
Dialogue: 0,0:42:20.82,0:42:23.63,Default,,0,0,0,,เหลือเวลาอีกไม่ถึงชั่วโมงก็จะแล่นออกไปนอกชายฝั่งแล้ว
Dialogue: 0,0:42:23.63,0:42:25.15,Default,,0,0,0,,โดโรธี ขับให้เร็วกว่านี้
Dialogue: 0,0:42:25.15,0:42:26.24,Default,,0,0,0,,เข้าใจแล้ว
Dialogue: 0,0:42:34.42,0:42:36.66,Default,,0,0,0,,ไม่รู้ว่าเมรี่จะทำได้ดีแค่ไหน
Dialogue: 0,0:42:37.06,0:42:40.16,Default,,0,0,0,,น่าจะถึงทิบเบอรี่แล้วสินะ
Dialogue: 0,0:42:40.16,0:42:41.90,Default,,0,0,0,,ท่านเป็นห่วงเหรอ
Dialogue: 0,0:42:42.30,0:42:44.49,Default,,0,0,0,,ต่อไปงานราชการก็จะเพิ่มขึ้น
Dialogue: 0,0:42:44.49,0:42:46.89,Default,,0,0,0,,เธอจะต้องเรียนรู้วิธีรับมือให้ได้
Dialogue: 0,0:42:47.24,0:42:51.38,Default,,0,0,0,,คราวนี้องค์หญิงชาร์ล็อตต์ก็อยู่ด้วย ไม่น่าจะมีปัญหาอะไร
Dialogue: 0,0:42:51.88,0:42:53.53,Default,,0,0,0,,ชาร์ล็อตต์เหรอ
Dialogue: 0,0:42:53.93,0:42:57.30,Default,,0,0,0,,จริง ๆ เลย ทุกคนก็เอาแต่โอ๋เมรี่
Dialogue: 0,0:43:12.40,0:43:13.55,Default,,0,0,0,,นั่นไงเรือลำนั้น
Dialogue: 0,0:43:13.55,0:43:15.14,Default,,0,0,0,,เรือยังไม่จม
Dialogue: 0,0:43:15.14,0:43:16.90,Default,,0,0,0,,อีกไม่นานก็จะออกไปนอกชายฝั่งแล้ว
Dialogue: 0,0:43:17.21,0:43:18.99,Default,,0,0,0,,ฉันจะกระโดดจากตรงนี้ไป
Dialogue: 0,0:43:18.99,0:43:20.93,Default,,0,0,0,,จิเซะ พวกเราไปกันเถอะ
Dialogue: 0,0:43:20.93,0:43:22.08,Default,,0,0,0,,พร้อมเสมอ
Dialogue: 0,0:43:31.84,0:43:33.51,Default,,0,0,0,,จะไปหาจากที่ไหน
Dialogue: 0,0:43:33.51,0:43:36.20,Default,,0,0,0,,\Nคาโวไรต์จะใช้ไอน้ำ
Dialogue: 0,0:43:36.20,0:43:37.93,Default,,0,0,0,,น่าจะอยู่ใกล้ ๆ หม้อต้ม
Dialogue: 0,0:43:51.90,0:43:53.05,Default,,0,0,0,,นั่นไง
Dialogue: 0,0:43:55.90,0:43:58.96,Default,,0,0,0,,งานก็ใกล้จะจบลงด้วยดีแล้ว
Dialogue: 0,0:43:58.96,0:43:59.73,Default,,0,0,0,,อืม
Dialogue: 0,0:43:59.73,0:44:00.99,Default,,0,0,0,,พี่สาว
Dialogue: 0,0:44:01.39,0:44:03.15,Default,,0,0,0,,อ้าว เมรี่
Dialogue: 0,0:44:03.15,0:44:07.67,Default,,0,0,0,,คือว่า…ขอบคุณนะคะที่วันนี้อยู่เป็นเพื่อนหนู
Dialogue: 0,0:44:07.67,0:44:10.86,Default,,0,0,0,,ถ้าหนูอยู่คนเดียวอาจจะประหม่าได้
Dialogue: 0,0:44:11.26,0:44:12.78,Default,,0,0,0,,ไม่ต้องเกรงใจ
Dialogue: 0,0:44:13.12,0:44:16.49,Default,,0,0,0,,ตอนที่พี่อายุเท่าเธอ พี่ก็เป็นกังวลเหมือนกันนะ
Dialogue: 0,0:44:16.49,0:44:17.68,Default,,0,0,0,,พี่ก็เป็นด้วยเหรอคะ
Dialogue: 0,0:44:17.68,0:44:18.83,Default,,0,0,0,,อืม
Dialogue: 0,0:44:19.61,0:44:21.64,Default,,0,0,0,,งั้น…คือว่า องค์หญิง
Dialogue: 0,0:44:28.17,0:44:29.81,Default,,0,0,0,,ขอโทษนะ เมรี่
Dialogue: 0,0:44:29.81,0:44:32.34,Default,,0,0,0,,พี่ขอตัวไปแป๊บนึงนะ
Dialogue: 0,0:44:33.06,0:44:33.85,Default,,0,0,0,,เบียทริซ
Dialogue: 0,0:44:33.85,0:44:34.90,Default,,0,0,0,,คะ
Dialogue: 0,0:44:38.82,0:44:40.78,Default,,0,0,0,,บนเรือลำนี้มีระเบิ…
Dialogue: 0,0:44:41.90,0:44:44.00,Default,,0,0,0,,มีคนติดระเบิดไว้เหรอคะ
Dialogue: 0,0:44:44.00,0:44:46.32,Default,,0,0,0,,อยู่เหนือห้องเครื่องต้มน้ำ
Dialogue: 0,0:44:46.32,0:44:48.90,Default,,0,0,0,,อุปกรณ์จับเวลาก็เริ่มทำงานแล้ว
Dialogue: 0,0:44:48.90,0:44:50.00,Default,,0,0,0,,เป็นไปได้ยังไง…
Dialogue: 0,0:44:50.00,0:44:52.87,Default,,0,0,0,,หลังจากแล่นออกจากชายฝั่ง 20 นาที ก็จะระเบิด
Dialogue: 0,0:44:52.87,0:44:57.34,Default,,0,0,0,,เพราะฉะนั้น จะใช้ ซีบอลล์\Nส่งพวกเธอสองคนกลับไปที่พื้นดินก่อน
Dialogue: 0,0:44:57.34,0:44:58.76,Default,,0,0,0,,ไม่ได้นะ แองเจ
Dialogue: 0,0:44:58.76,0:45:00.57,Default,,0,0,0,,ฉันก็จะอยู่ที่นี่ด้วย
Dialogue: 0,0:45:00.57,0:45:02.64,Default,,0,0,0,,จะดื้อไม่ได้แล้ว ไม่มีเวลาแล้ว
Dialogue: 0,0:45:02.64,0:45:06.02,Default,,0,0,0,,หม้อต้มต่อตรงกับระเบิด ดับไม่ได้
Dialogue: 0,0:45:06.02,0:45:09.98,Default,,0,0,0,,ถึงจะปิดเครื่องจับเวลา ก็ไม่แน่ว่าจะหยุดการระเบิดได้
Dialogue: 0,0:45:11.05,0:45:14.02,Default,,0,0,0,,งั้นก็หลบภัยและกู้ระเบิดไปพร้อม ๆ กันเลย
Dialogue: 0,0:45:17.90,0:45:18.96,Default,,0,0,0,,เธอจะทำอะไร
Dialogue: 0,0:45:19.53,0:45:23.22,Default,,0,0,0,,ฉันจะไปเจรจากับกัปตันเรือ ให้ผู้โดยสารไปหลบภัย
Dialogue: 0,0:45:23.22,0:45:27.28,Default,,0,0,0,,จะพูดยังไงดี จะบอกว่าบนเรือมีระเบิดก็ไม่ได้
Dialogue: 0,0:45:27.28,0:45:30.54,Default,,0,0,0,,เรื่องนี้ ก็ฝากคุณจิเซะด้วยนะคะ
Dialogue: 0,0:45:34.48,0:45:36.17,Default,,0,0,0,,เมรี่ รอนานไหม
Dialogue: 0,0:45:36.55,0:45:40.55,Default,,0,0,0,,ขอโทษที เรือมันใหญ่เกินไป หลงทางเลย
Dialogue: 0,0:45:40.55,0:45:43.99,Default,,0,0,0,,ว้าว พี่สาวก็มีเรื่องแบบนี้ด้วยเหรอ
Dialogue: 0,0:45:50.12,0:45:52.16,Default,,0,0,0,,จะมากเกินไปไหมนะ
Dialogue: 0,0:45:56.90,0:45:57.93,Default,,0,0,0,,ควันอะไรน่ะ
Dialogue: 0,0:45:57.93,0:45:58.79,Default,,0,0,0,,{\an8}-ไฟไหม้เหรอ　-น่ากลัวจัง จะจมไหมเนี่ย
Dialogue: 0,0:45:57.93,0:45:58.79,Default,,0,0,0,,ควันอะไรน่ะ
Dialogue: 0,0:45:58.79,0:46:01.14,Default,,0,0,0,,-ไฟไหม้เหรอ　-น่ากลัวจัง จะจมไหมเนี่ย
Dialogue: 0,0:46:01.14,0:46:03.41,Default,,0,0,0,,ทุกท่านครับ โปรดอย่ากังวล
Dialogue: 0,0:46:03.41,0:46:07.45,Default,,0,0,0,,พวกเรากำลังตรวจสอบสาเหตุ โปรดใจเย็น ๆ
Dialogue: 0,0:46:07.45,0:46:08.57,Default,,0,0,0,,พาองค์หญิงเมรี่และองค์หญิงชาร์ล็อตต์ลงจากเรือ
Dialogue: 0,0:46:08.57,0:46:10.35,Default,,0,0,0,,พาองค์หญิงเมรี่และองค์หญิงชาร์ล็อตต์ลงจากเรือ
Dialogue: 0,0:46:08.57,0:46:10.35,Default,,0,0,0,,{\an8}ลูกเรือกำลังจะไปปิดเครื่องส่งสัญญาณเตือนภัย
Dialogue: 0,0:46:10.35,0:46:11.76,Default,,0,0,0,,รีบไปเตรียม…
Dialogue: 0,0:46:10.35,0:46:11.76,Default,,0,0,0,,{\an8}ลูกเรือกำลังจะไปปิดเครื่องส่งสัญญาณเตือนภัย
Dialogue: 0,0:46:11.76,0:46:11.79,Default,,0,0,0,,รีบไปเตรียม…
Dialogue: 0,0:46:11.79,0:46:13.42,Default,,0,0,0,,พูดอะไรน่ะคะ
Dialogue: 0,0:46:13.42,0:46:17.97,Default,,0,0,0,,เชื้อพระวงศ์ก็อยู่บนเรือด้วยนะคะ ถ้าเกิดอะไรขึ้นมา…
Dialogue: 0,0:46:17.97,0:46:19.35,Default,,0,0,0,,นั่น…
Dialogue: 0,0:46:19.35,0:46:20.80,Default,,0,0,0,,องค์หญิงคะ
Dialogue: 0,0:46:20.80,0:46:22.33,Default,,0,0,0,,ฉันจะเตรียมเรือให้เองค่ะ
Dialogue: 0,0:46:22.33,0:46:24.98,Default,,0,0,0,,โปรดพาองค์หญิงเมรี่ไปหลบภัยก่อนค่ะ
Dialogue: 0,0:46:25.60,0:46:29.06,Default,,0,0,0,,ไม่ ให้เมรี่และผู้โดยสารไปหลบภัยก่อน
Dialogue: 0,0:46:29.06,0:46:31.62,Default,,0,0,0,,หลังจากนั้น ฉันค่อยออกไป
Dialogue: 0,0:46:34.72,0:46:35.76,Default,,0,0,0,,เกิดอะไรขึ้น
Dialogue: 0,0:46:36.69,0:46:39.15,Default,,0,0,0,,-เสียงอะไรน่ะ　-ชนอะไรหรือเปล่า
Dialogue: 0,0:46:39.15,0:46:41.88,Default,,0,0,0,,-อย่าล้อเล่นน่า　-จะไม่เป็นอะไรจริง ๆ เหรอ
Dialogue: 0,0:46:44.19,0:46:45.40,Default,,0,0,0,,สถานการณ์เป็นยังไงบ้าง
Dialogue: 0,0:46:45.40,0:46:46.66,Default,,0,0,0,,นี่มัน…
Dialogue: 0,0:46:58.71,0:46:59.63,Default,,0,0,0,,แองเจ
Dialogue: 0,0:47:05.23,0:47:07.58,Default,,0,0,0,,-เกิดอะไรขึ้น　-ไฟไหม้เหรอ
Dialogue: 0,0:47:07.58,0:47:09.53,Default,,0,0,0,,ไม่ใช่เรื่องล้อเล่นแล้วนะ
Dialogue: 0,0:47:09.53,0:47:11.48,Default,,0,0,0,,ต้องหนีตายแล้วใช่ไหม
Dialogue: 0,0:47:38.40,0:47:39.38,Default,,0,0,0,,แองเจ
Dialogue: 0,0:47:39.38,0:47:41.99,Default,,0,0,0,,ไม่ได้ แรงดันไม่ลดลงเลย
Dialogue: 0,0:47:41.99,0:47:44.05,Default,,0,0,0,,ไม่มีวิธีอื่นแล้วเหรอ
Dialogue: 0,0:47:52.14,0:47:53.53,Default,,0,0,0,,เธอจะทำอะไร
Dialogue: 0,0:47:53.53,0:47:56.39,Default,,0,0,0,,เอาไปพันรอบระเบิด แล้วดึงมันออกมาให้หมด
Dialogue: 0,0:47:56.89,0:48:00.26,Default,,0,0,0,,พวกเราจะไปดูสถานการณ์ พวกนายทำงานต่อไป
Dialogue: 0,0:48:14.91,0:48:16.79,Default,,0,0,0,,เกิดอะไรขึ้น
Dialogue: 0,0:48:16.79,0:48:18.64,Default,,0,0,0,,ท่อแตกเหรอ
Dialogue: 0,0:48:18.64,0:48:20.40,Default,,0,0,0,,ต้องปิดหม้อต้มแล้วล่ะ
Dialogue: 0,0:48:28.01,0:48:31.04,Default,,0,0,0,,เอาสายท่อไปพันกับเฟือง\N แล้วให้มันดึงระเบิดออกมา
Dialogue: 0,0:48:31.64,0:48:33.27,Default,,0,0,0,,ระเบิดเหรอ?
Dialogue: 0,0:48:36.77,0:48:38.18,Default,,0,0,0,,เกิดอะไรขึ้น
Dialogue: 0,0:48:39.77,0:48:41.54,Default,,0,0,0,,เฮ้ย จะทําไร
Dialogue: 0,0:48:52.67,0:48:54.74,Default,,0,0,0,,หลบไปซะ ระเบิดจะลอยมาหาแล้ว
Dialogue: 0,0:49:18.40,0:49:20.77,Default,,0,0,0,,อพยพทุกคนเสร็จเรียบร้อยแล้วค่ะ
Dialogue: 0,0:49:20.77,0:49:22.83,Default,,0,0,0,,ขอให้องค์หญิงรีบออกจากเรือสำราญด้วยค่ะ
Dialogue: 0,0:49:22.83,0:49:23.95,Default,,0,0,0,,ค่ะ
Dialogue: 0,0:49:40.72,0:49:44.92,Default,,0,0,0,,ชิงระเบิดที่ถูกขโมยมาได้สำเร็จแล้วค่ะ
Dialogue: 0,0:49:44.92,0:49:47.57,Default,,0,0,0,,จะเรียกว่าสำเร็จได้เหรอเนี่ย
Dialogue: 0,0:49:47.57,0:49:49.26,Default,,0,0,0,,สภาพเละเทะขนาดนี้
Dialogue: 0,0:49:49.26,0:49:53.26,Default,,0,0,0,,แต่อย่างน้อยเทคนิคก็ไม่ถูกขโมยไปนะครับ
Dialogue: 0,0:49:53.86,0:49:58.22,Default,,0,0,0,,แจ้งทุกทีมว่าทุกคนทำได้ดีมากให้ด้วยนะ!
Dialogue: 0,0:49:58.92,0:50:01.52,Default,,0,0,0,,ตอนแรกก็ไม่รู้ว่าจะจบลงยังไงเลยนะคะ
Dialogue: 0,0:50:01.52,0:50:04.59,Default,,0,0,0,,แต่ก็ดีที่เรื่องไม่บานปลายค่ะ
Dialogue: 0,0:50:04.59,0:50:06.02,Default,,0,0,0,,นั่นสินะ
Dialogue: 0,0:50:06.64,0:50:11.03,Default,,0,0,0,,ถ้ามีเรื่องอะไรที่กังวลใจอีก สามารถมาหาพี่ได้เสมอนะ
Dialogue: 0,0:50:11.03,0:50:13.40,Default,,0,0,0,,พี่จะช่วยเธอแน่นอน
Dialogue: 0,0:50:13.40,0:50:14.43,Default,,0,0,0,,ค่ะ
Dialogue: 0,0:50:23.55,0:50:24.04,Default,,0,0,0,,คะ…
Dialogue: 0,0:50:28.66,0:50:30.01,Default,,0,0,0,,องค์หญิงชาร์ล็อตต์
Dialogue: 0,0:50:30.01,0:50:32.43,Default,,0,0,0,,โอลิเวีย เกิดอะไรขึ้น
Dialogue: 0,0:50:32.43,0:50:33.94,Default,,0,0,0,,คือ…
Dialogue: 0,0:50:34.39,0:50:39.58,Default,,0,0,0,,เมื่อกี้ตำรวจมาที่นี่ บอกว่าองค์รัชทายาทเอ็ดเวิร์ด
Dialogue: 0,0:50:39.58,0:50:42.52,Default,,0,0,0,,ถูกคนร้ายไม่ทราบชื่อโจมตี และเสียชีวิตแล้ว
Dialogue: 0,0:50:44.60,0:50:48.71,Default,,0,0,0,,ถูกซุ่มโจมตีในขณะที่กำลังปฏิบัติภารกิจส่วนตัว
Dialogue: 0,0:50:49.11,0:50:52.11,Default,,0,0,0,,ตอนที่เลขานุการมาพบ ก็ได้…
Dialogue: 0,0:50:53.38,0:50:54.73,Default,,0,0,0,,พี่สาว?
Dialogue: 0,0:50:55.87,0:51:00.05,Default,,0,0,0,,ขอโทษด้วยนะ เมรี่ไปที่ห้องกับโอลิเวียก่อนนะ
Dialogue: 0,0:51:00.05,0:51:02.12,Default,,0,0,0,,เบียทริซก็ไปด้วยกัน
Dialogue: 0,0:51:02.12,0:51:03.62,Default,,0,0,0,,ค่ะ…
Dialogue: 0,0:51:04.03,0:51:06.32,Default,,0,0,0,,โอลิเวีย ฝากด้วยนะ
Dialogue: 0,0:51:06.32,0:51:07.16,Default,,0,0,0,,ค่ะ
Dialogue: 0,0:51:10.39,0:51:12.83,Default,,0,0,0,,ไม่ได้เข้าใจผิดใช่ไหม
Dialogue: 0,0:51:13.37,0:51:15.85,Default,,0,0,0,,ไม่ครับ ขอแสดงความเสียใจด้วย…
Dialogue: 0,0:51:16.47,0:51:17.96,Default,,0,0,0,,เป็นไปได้ยังไง…
Dialogue: 0,0:51:29.29,0:51:30.81,Default,,0,0,0,,พี่ชายริชาร์ด
Dialogue: 0,0:51:33.65,0:51:35.58,Default,,0,0,0,,แย่แล้วสิ
Dialogue: 0,0:51:35.58,0:51:38.16,Default,,0,0,0,,ประมาทเลินเล่อไปหน่อย
Dialogue: 0,0:51:38.16,0:51:43.17,Default,,0,0,0,,ในเมื่อชาร์ล็อตต์อยู่ที่นี่ ก็แสดงว่าเมรี่ไม่เป็นอะไรใช่ไหม
Dialogue: 0,0:51:43.17,0:51:45.69,Default,,0,0,0,,ก็ดีเหมือนกัน อย่าโลภมากเกินไปเลย
Dialogue: 0,0:51:46.64,0:51:49.71,Default,,0,0,0,,พี่ชาย…ท่านกำลังพูดอะไร
Dialogue: 0,0:51:49.71,0:51:54.48,Default,,0,0,0,,ได้ยินมาว่าเธอจะไปกับเมรี่ด้วย ฉันก็ตกใจไปเหมือนกัน
Dialogue: 0,0:51:54.92,0:51:58.06,Default,,0,0,0,,ก็ฉันให้คะแนนเธอไว้สูงนี่นา
Dialogue: 0,0:51:58.43,0:52:00.93,Default,,0,0,0,,ดีจริง ๆ ที่ไม่ได้เสียเธอไป
Dialogue: 0,0:52:02.34,0:52:03.63,Default,,0,0,0,,พี่ชาย…
Dialogue: 0,0:52:14.88,0:52:18.09,Default,,0,0,0,,รู้สึกถึงลมนั้นไหม
Dialogue: 0,0:52:18.09,0:52:21.15,Default,,0,0,0,,ลมที่นำพาการเปลี่ยนแปลงมาสู่อาณาจักร
Dialogue: 0,0:52:21.66,0:52:26.71,Default,,0,0,0,,แต่…ที่นี่มีกำแพงสูงที่ปฏิเสธมันอยู่
Dialogue: 0,0:52:26.71,0:52:30.96,Default,,0,0,0,,กำแพงที่ยึดมั่นในการสืบทอดอาณาจักร กำแพงที่ล้าสมัย
Dialogue: 0,0:52:32.21,0:52:37.02,Default,,0,0,0,,ส่วนฉันคือลมแห่งการปฏิรูปที่ปรารถนาในการพัฒนาอย่างต่อเนื่อง
Dialogue: 0,0:52:37.87,0:52:41.69,Default,,0,0,0,,ชาร์ล็อตต์ เธอเลือกข้างใคร?

Dialogue: 0,0:06:05.83,0:06:08.99,Default,,0,0,0,,ของของพวกเธออยู่ในกระเป๋าใบนั้น
Dialogue: 0,0:06:09.80,0:06:11.54,Default,,0,0,0,,พวกเธอจงกลับไปที่หอพัก
Dialogue: 0,0:06:11.54,0:06:13.36,Default,,0,0,0,,แล้วทำตัวตามปกติเหมือนที่ผ่านมา
Dialogue: 0,0:06:14.35,0:06:17.74,Default,,0,0,0,,จากนี้ไป พวกเธอต้องทำตัวให้เป็นประโยชน์ในฐานะสปายสองหน้า
Dialogue: 0,0:06:17.74,0:06:19.48,Default,,0,0,0,,ถ้าพวกเธอหายตัวไป
Dialogue: 0,0:06:19.48,0:06:21.45,Default,,0,0,0,,ฉันจะฆ่าเบียทริซที่เป็นสาวใช้
Dialogue: 0,0:06:22.36,0:06:24.82,Default,,0,0,0,,ส่วนพรินเซสก็คงจะถูกกำจัดเหมือนกัน
Dialogue: 0,0:06:25.46,0:06:28.36,Default,,0,0,0,,ถ้ามีธุระอะไร ทางนี้จะติดต่อไปเอง
Dialogue: 0,0:06:28.70,0:06:29.53,Default,,0,0,0,,ออกรถ
Dialogue: 0,0:06:36.75,0:06:38.39,Default,,0,0,0,,จากนี้ไปจะทำยังไงต่อล่ะ
Dialogue: 0,0:06:38.39,0:06:39.51,Default,,0,0,0,,ก็อย่างที่เขาบอก
Dialogue: 0,0:06:39.51,0:06:41.71,Default,,0,0,0,,ไม่มีทางเลือกอื่นนอกจากทำตัวตามปกติ
Dialogue: 0,0:06:42.64,0:06:44.38,Default,,0,0,0,,ฉันขอไปเปลี่ยนชุดก่อน
Dialogue: 0,0:06:44.38,0:06:46.39,Default,,0,0,0,,แล้วจะไปรายงานคอนโทรล
Dialogue: 0,0:06:46.39,0:06:47.72,Default,,0,0,0,,จะไหวเหรอ
Dialogue: 0,0:06:47.72,0:06:49.97,Default,,0,0,0,,เธอจะรายงานว่าอะไรล่ะ
Dialogue: 0,0:06:49.97,0:06:53.64,Default,,0,0,0,,ได้ข้อมูลสำหรับเตี๊ยมกันมาจากดยุกนอร์มังดีแล้ว
Dialogue: 0,0:06:54.10,0:06:57.66,Default,,0,0,0,,ที่เหลือก็แค่ด้นสดให้มันผ่าน ๆ ไปนั่นแหละ
Dialogue: 0,0:06:57.98,0:06:59.08,Default,,0,0,0,,ไปกันเถอะ
Dialogue: 0,0:07:03.78,0:07:05.47,Default,,0,0,0,,เชื่อได้เหรอ
Dialogue: 0,0:07:05.47,0:07:07.17,Default,,0,0,0,,พวกเธออยู่บนหอคอย
Dialogue: 0,0:07:07.17,0:07:10.41,Default,,0,0,0,,มีรายงานว่าถูกทหารล้อมเอาไว้
Dialogue: 0,0:07:10.41,0:07:11.59,Default,,0,0,0,,จากสถานการณ์นั้น
Dialogue: 0,0:07:11.59,0:07:13.54,Default,,0,0,0,,พวกเธอหนีรอดมาได้ยังไงกัน
Dialogue: 0,0:07:13.54,0:07:16.42,Default,,0,0,0,,เรื่องนั้นได้ยื่นรายงานไปแล้วค่ะ
Dialogue: 0,0:07:16.42,0:07:19.19,Default,,0,0,0,,เรื่องโกหกน่ะจะเขียนเท่าไหร่ก็ได้
Dialogue: 0,0:07:19.19,0:07:21.66,Default,,0,0,0,,ไปตกลงอะไรกับทางราชอาณาจักรมาหรือเปล่า
Dialogue: 0,0:07:21.66,0:07:22.82,Default,,0,0,0,,เปล่าค่ะ
Dialogue: 0,0:07:23.55,0:07:25.14,Default,,0,0,0,,คำให้การของเธอ
Dialogue: 0,0:07:25.14,0:07:28.43,Default,,0,0,0,,ตรงกับรายงานภายในของกองทัพราชอาณาจักรค่ะ
Dialogue: 0,0:07:32.10,0:07:34.43,Default,,0,0,0,,ทำไมถึงอุตส่าห์มาที่นี่
Dialogue: 0,0:07:34.43,0:07:37.48,Default,,0,0,0,,ถ้าไม่มาก็จะถูกสงสัยโดยใช่เหตุค่ะ
Dialogue: 0,0:07:38.06,0:07:40.09,Default,,0,0,0,,ฉันยอมรับคำตำหนิเรื่องความผิดพลาด
Dialogue: 0,0:07:40.09,0:07:43.21,Default,,0,0,0,,แต่ไม่คิดจะยอมรับในสิ่งที่ไม่ได้ทำค่ะ
Dialogue: 0,0:07:44.17,0:07:46.20,Default,,0,0,0,,เข้าใจที่พูดแล้ว
Dialogue: 0,0:07:46.20,0:07:49.77,Default,,0,0,0,,กลับไปที่หอพักแล้วรอคำสั่งต่อไป
Dialogue: 0,0:08:01.78,0:08:04.72,Default,,0,0,0,,คิดว่าแค่นั้นจะพิสูจน์ความบริสุทธิ์ได้เหรอ
Dialogue: 0,0:08:04.72,0:08:05.60,Default,,0,0,0,,แต่ว่า
Dialogue: 0,0:08:05.60,0:08:08.47,Default,,0,0,0,,ที่พูดมาก็ไม่มีอะไรขัดแย้งกันนี่นา
Dialogue: 0,0:08:08.62,0:08:11.68,Default,,0,0,0,,ก็แค่ในรายงานไม่มีอะไรขัดแย้งกันเท่านั้นค่ะ
Dialogue: 0,0:08:11.68,0:08:15.65,Default,,0,0,0,,เรามองข้ามความเป็นไปได้ที่เธอจะถูกปล่อยตัวมาเป็นสปายสองหน้าไม่ได้ค่ะ
Dialogue: 0,0:08:15.85,0:08:17.42,Default,,0,0,0,,พวกเราตั้งแต่แรกแล้ว
Dialogue: 0,0:08:17.42,0:08:20.49,Default,,0,0,0,,ไม่ได้มองว่าพรินเซสเป็นพวกเดียวกัน
Dialogue: 0,0:08:23.59,0:08:29.01,Default,,0,0,0,,จะปล่อยให้พวกเธอเคลื่อนไหว\Nโดยคำนึงว่าพวกเธอติดต่อกับดยุกนอร์มังดีอยู่
Dialogue: 0,0:08:29.40,0:08:31.83,Default,,0,0,0,,ให้พวกเธอรอจนกว่าจะมีคำสั่ง
Dialogue: 0,0:08:31.83,0:08:33.02,Default,,0,0,0,,รับทราบค่ะ
Dialogue: 0,0:08:39.92,0:08:42.88,Default,,0,0,0,,ได้เวลายอมรับความจริงแล้วหรือยังครับ
Dialogue: 0,0:08:42.88,0:08:45.20,Default,,0,0,0,,ถึงจะให้ยอมรับก็เถอะนะ
Dialogue: 0,0:08:45.20,0:08:47.29,Default,,0,0,0,,ผมเองก็โดนยิงเหมือนกันนะ
Dialogue: 0,0:08:47.29,0:08:50.23,Default,,0,0,0,,ทำไมผมต้องฆ่าพี่เอ็ดเวิร์ดด้วยล่ะ
Dialogue: 0,0:08:50.23,0:08:52.51,Default,,0,0,0,,ถ้าอย่างนั้น ลักษณะของมือปืนคนนั้น
Dialogue: 0,0:08:52.75,0:08:55.15,Default,,0,0,0,,ทำไมถึงตรงกับลูกน้องของคุณล่ะครับ
Dialogue: 0,0:08:55.15,0:08:57.89,Default,,0,0,0,,ชาวต่างชาติที่ใส่ชุดดำน่ะ
Dialogue: 0,0:08:57.89,0:08:59.76,Default,,0,0,0,,ไม่ใช่เรื่องแปลกสักหน่อยนี่
Dialogue: 0,0:08:59.76,0:09:00.90,Default,,0,0,0,,ฝ่าบาท
Dialogue: 0,0:09:00.90,0:09:02.54,Default,,0,0,0,,เรามีพยานรู้เห็นนะครับ
Dialogue: 0,0:09:02.54,0:09:04.52,Default,,0,0,0,,ถ้าพูดความจริงออกมาจะดีกว่า...
Dialogue: 0,0:09:04.52,0:09:06.53,Default,,0,0,0,,น่าผิดหวังจังเลยนะ
Dialogue: 0,0:09:06.87,0:09:09.49,Default,,0,0,0,,อุตส่าห์ทำมาถึงขนาดนี้แล้ว ไม่น่าเลย
Dialogue: 0,0:09:09.49,0:09:12.53,Default,,0,0,0,,นึกว่าจะสร้างหลักฐานปลอมขึ้นมาซะอีก
Dialogue: 0,0:09:13.63,0:09:16.54,Default,,0,0,0,,ไม่ได้อะไรมาจากคุณลุงเลยเหรอ
Dialogue: 0,0:09:16.54,0:09:18.82,Default,,0,0,0,,อย่างอาวุธที่ใช้ฆ่าคน
Dialogue: 0,0:09:18.82,0:09:21.08,Default,,0,0,0,,หรือรอยเท้าของคนร้ายอะไรแบบนั้น
Dialogue: 0,0:09:21.08,0:09:22.82,Default,,0,0,0,,เกมเนี่ยนะ
Dialogue: 0,0:09:22.82,0:09:25.46,Default,,0,0,0,,มันต้องเอาจริงเอาจังกันจนถึงที่สุดสิ
Dialogue: 0,0:09:26.03,0:09:28.55,Default,,0,0,0,,ทางนี้ก็คิดอะไรไว้ตั้งเยอะแยะ
Dialogue: 0,0:09:28.55,0:09:30.87,Default,,0,0,0,,แต่ถ้ามาทำชุ่ย ๆ กันตรงนี้
Dialogue: 0,0:09:30.87,0:09:32.26,Default,,0,0,0,,มันก็หมดสนุกกันพอดี
Dialogue: 0,0:09:38.33,0:09:39.79,Default,,0,0,0,,ขอโทษนะคะ
Dialogue: 0,0:09:39.79,0:09:41.95,Default,,0,0,0,,เป็นเพราะหนู ท่านพี่เลยต้อง...
Dialogue: 0,0:09:42.56,0:09:44.56,Default,,0,0,0,,ไม่ใช่นะ แมรี่
Dialogue: 0,0:09:44.56,0:09:47.25,Default,,0,0,0,,นั่นเป็นสิ่งที่พวกเราต้องการจะทำเอง
Dialogue: 0,0:09:48.57,0:09:50.19,Default,,0,0,0,,ท่านพี่
Dialogue: 0,0:09:50.19,0:09:51.17,Default,,0,0,0,,แมรี่
Dialogue: 0,0:09:54.57,0:09:55.66,Default,,0,0,0,,โอลิเวีย
Dialogue: 0,0:09:56.58,0:09:58.10,Default,,0,0,0,,ฝากดูแลแมรี่ด้วยนะคะ
Dialogue: 0,0:09:58.58,0:10:00.18,Default,,0,0,0,,ไปเถอะ แมรี่
Dialogue: 0,0:10:14.59,0:10:15.84,Default,,0,0,0,,งั้นสินะ
Dialogue: 0,0:10:15.84,0:10:18.19,Default,,0,0,0,,แมรี่ต้องไปอยู่สำนักชี
Dialogue: 0,0:10:19.44,0:10:21.27,Default,,0,0,0,,ช่างน่าสมเพชจริง ๆ
Dialogue: 0,0:10:21.27,0:10:24.26,Default,,0,0,0,,แค่ครอบครัวยังปกป้องไว้ไม่ได้เลย
Dialogue: 0,0:10:26.79,0:10:29.88,Default,,0,0,0,,ทำให้เธอต้องลำบากไปด้วยเลยนะ
Dialogue: 0,0:10:29.88,0:10:31.62,Default,,0,0,0,,ท่านย่า อย่าพูดอย่างนั้นสิคะ...
Dialogue: 0,0:10:33.56,0:10:37.45,Default,,0,0,0,,ถ้ามีเรื่องทุกข์ใจเมื่อไหร่ก็มาพึ่งพาได้เสมอนะ
Dialogue: 0,0:10:37.79,0:10:40.62,Default,,0,0,0,,เพราะพวกเราเป็นครอบครัวเดียวกันนะ
Dialogue: 0,0:10:48.33,0:10:49.52,Default,,0,0,0,,องค์หญิงเพคะ!
Dialogue: 0,0:10:53.88,0:10:55.26,Default,,0,0,0,,พวกเรา
Dialogue: 0,0:10:55.26,0:10:57.95,Default,,0,0,0,,จากนี้ไปจะเป็นยังไงต่อเหรอคะ
Dialogue: 0,0:10:57.95,0:11:01.38,Default,,0,0,0,,ฉันว่าคงยังไม่มีอะไรเกิดขึ้นในเร็ว ๆ นี้หรอก
Dialogue: 0,0:11:01.86,0:11:03.01,Default,,0,0,0,,ท่านลุงน่ะ
Dialogue: 0,0:11:03.01,0:11:05.47,Default,,0,0,0,,คงอยากจะใช้ประโยชน์จากพวกเรา
Dialogue: 0,0:11:06.98,0:11:09.13,Default,,0,0,0,,ใช้ประโยชน์เหรอคะ
Dialogue: 0,0:11:09.54,0:11:10.65,Default,,0,0,0,,ไม่เป็นไร
Dialogue: 0,0:11:11.85,0:11:13.70,Default,,0,0,0,,เพราะฉันตัดสินใจแล้ว
Dialogue: 0,0:11:14.35,0:11:16.65,Default,,0,0,0,,ว่าจะปกป้องทุกคนให้ได้
Dialogue: 0,0:11:16.65,0:11:19.81,Default,,0,0,0,,ฉันน่ะ ถนัดเรื่องเจรจาต่อรองอยู่แล้ว
Dialogue: 0,0:11:36.04,0:11:39.04,Default,,0,0,0,,มีแต่ผลงานที่ยอดเยี่ยมทั้งนั้นเลย
Dialogue: 0,0:11:39.04,0:11:43.33,Default,,0,0,0,,การแลกเปลี่ยนทางวัฒนธรรมแบบนี้เป็นสิ่งที่อยากจะรักษาไว้จริง ๆ
Dialogue: 0,0:11:43.33,0:11:45.17,Default,,0,0,0,,ท่านดยุกนอร์มังดี
Dialogue: 0,0:11:48.41,0:11:52.23,Default,,0,0,0,,ไม่ได้ยินเลยว่าท่านรัฐมนตรีมหาดไทยจะมาด้วย
Dialogue: 0,0:11:52.23,0:11:54.00,Default,,0,0,0,,ไม่ได้เจอกันนานเลยนะ
Dialogue: 0,0:11:54.00,0:11:58.15,Default,,0,0,0,,ตอนนี้เป็นผู้อำนวยการสำนักงานกิจการวัฒนธรรมสมิธคัมมิงแล้วสินะ
Dialogue: 0,0:11:58.15,0:12:00.16,Default,,0,0,0,,12 ปีแล้วครับ
Dialogue: 0,0:12:00.16,0:12:04.06,Default,,0,0,0,,ถ้าท่านติดต่อมา ผมจะได้ต้อนรับท่านแท้ ๆ
Dialogue: 0,0:12:04.06,0:12:07.33,Default,,0,0,0,,ไม่เป็นไรหรอก แค่แวะมาทักทายเฉย ๆ
Dialogue: 0,0:12:07.33,0:12:13.33,Default,,0,0,0,,แต่พอคิดว่ามีศิลปินมากความสามารถขนาดนี้ไปอยู่ฝั่งโน้นของกำแพงแล้ว
Dialogue: 0,0:12:13.33,0:12:18.46,Default,,0,0,0,,ในฐานะคนของราชอาณาจักรก็อดรู้สึกถ่อมตนไม่ได้เลยนะ
Dialogue: 0,0:12:18.46,0:12:19.39,Default,,0,0,0,,ท่านครับ
Dialogue: 0,0:12:19.39,0:12:21.98,Default,,0,0,0,,ขออนุญาตถ่ายรูปได้ไหมครับ
Dialogue: 0,0:12:21.98,0:12:23.88,Default,,0,0,0,,อ้อ ได้สิ
Dialogue: 0,0:12:23.88,0:12:25.16,Default,,0,0,0,,ดีเลยครับ
Dialogue: 0,0:12:25.16,0:12:26.73,Default,,0,0,0,,ท่านผู้อำนวยการด้วยนะครับ
Dialogue: 0,0:12:28.20,0:12:31.05,Default,,0,0,0,,งั้น ทั้งสองท่านยิ้มนะครับ
Dialogue: 0,0:12:31.05,0:12:33.45,Default,,0,0,0,,สาม สอง หนึ่ง
Dialogue: 0,0:12:37.25,0:12:38.74,Default,,0,0,0,,ขอบคุณมากครับ
Dialogue: 0,0:12:40.12,0:12:43.44,Default,,0,0,0,,เอาล่ะ งั้นฉันขอตัวก่อนนะ แต่ว่า
Dialogue: 0,0:12:43.44,0:12:45.13,Default,,0,0,0,,ขอถามอีกเรื่องหนึ่ง
Dialogue: 0,0:12:45.76,0:12:48.13,Default,,0,0,0,,คนที่ขโมยระเบิดของสาธารณรัฐไป
Dialogue: 0,0:12:48.13,0:12:53.68,Default,,0,0,0,,และวางแผนลอบสังหารราชวงศ์น่าจะถูกจับกุมตัวอยู่ทางนั้นนะ
Dialogue: 0,0:12:54.75,0:12:58.02,Default,,0,0,0,,ผมยังไม่เห็นข่าวในหนังสือพิมพ์เลยนะครับ
Dialogue: 0,0:12:58.02,0:13:01.98,Default,,0,0,0,,จะปล่อยให้คนที่มุ่งร้ายต่อราชอาณาจักรลอยนวลไม่ได้
Dialogue: 0,0:13:01.98,0:13:06.00,Default,,0,0,0,,ถ้าส่งตัวมาให้ \Nฉันจะทำเป็นมองไม่เห็นความผิดพลาดของสาธารณรัฐ
Dialogue: 0,0:13:06.00,0:13:07.36,Default,,0,0,0,,ต้องขออภัยด้วยครับ
Dialogue: 0,0:13:07.36,0:13:11.60,Default,,0,0,0,,แต่ด้วยตำแหน่งของผมแล้ว\N จะให้เชื่อคำพูดนั้นทั้งหมดก็คงไม่ได้
Dialogue: 0,0:13:15.05,0:13:16.53,Default,,0,0,0,,นี่คือ
Dialogue: 0,0:13:16.53,0:13:19.50,Default,,0,0,0,,จะแนะนำศิลปินฝีมือดีให้รู้จัก
Dialogue: 0,0:13:19.87,0:13:23.94,Default,,0,0,0,,ถึงจะเป็นพวกนอกกฎหมาย แต่เป็นคนที่ฉันยอมรับในฝีมือ
Dialogue: 0,0:13:27.74,0:13:29.71,Default,,0,0,0,,จะรับไว้พิจารณาครับ
Dialogue: 0,0:13:30.16,0:13:34.25,Default,,0,0,0,,ไม่รู้ว่าพวกนายรู้แผนการไปถึงไหนแล้ว
Dialogue: 0,0:13:34.25,0:13:38.29,Default,,0,0,0,,วินสตันที่ให้ความร่วมมือคงจะเสียใจน่าดู
Dialogue: 0,0:13:39.87,0:13:43.16,Default,,0,0,0,,ฉันเองก็ไม่อยากจะซ้ำเติมคนตายหรอก
Dialogue: 0,0:13:43.16,0:13:45.92,Default,,0,0,0,,เพื่อเกียรติของเขาด้วย
Dialogue: 0,0:14:01.20,0:14:03.20,Default,,0,0,0,,เกรแฮม เทอร์เนอร์
Dialogue: 0,0:14:03.20,0:14:08.83,Default,,0,0,0,,ช่างแกะสลักที่สร้างแม่พิมพ์ธนบัตรปลอม\Nที่กำลังระบาดในสาธารณรัฐตอนนี้
Dialogue: 0,0:14:09.39,0:14:15.38,Default,,0,0,0,,ธนบัตรปลอมที่เขาทำนั้นได้ผลสำเร็จอย่างมาก \Nยากที่จะแยกแยะของจริงของปลอมได้
Dialogue: 0,0:14:16.26,0:14:20.29,Default,,0,0,0,,เขาซ่อนตัวอยู่ในโรงพิมพ์เล็ก ๆ แห่งหนึ่ง
Dialogue: 0,0:14:20.29,0:14:22.23,Default,,0,0,0,,จงแฝงตัวเข้าไปในโรงงาน
Dialogue: 0,0:14:22.23,0:14:24.84,Default,,0,0,0,,และตรวจสอบความจริงของข้อมูลซะ
Dialogue: 0,0:14:24.84,0:14:27.67,Default,,0,0,0,,นึกว่าช่วงนี้จะไม่มีภารกิจซะอีกค่ะ
Dialogue: 0,0:14:27.67,0:14:31.35,Default,,0,0,0,,ถ้าอย่างนั้นก็คิดซะว่าเป็นโอกาสที่จะล้างข้อสงสัย
Dialogue: 0,0:14:56.88,0:14:59.78,Default,,0,0,0,,แหม มาได้จังหวะพอดีเลยนะ
Dialogue: 0,0:14:59.78,0:15:03.19,Default,,0,0,0,,พวกคุณป้าที่เพิ่งออกไปทำฉันลำบากแย่เลย
Dialogue: 0,0:15:03.19,0:15:04.88,Default,,0,0,0,,ค-ค่ะ
Dialogue: 0,0:15:05.66,0:15:06.89,Default,,0,0,0,,ท่านประธาน!
Dialogue: 0,0:15:07.04,0:15:09.24,Default,,0,0,0,,ไปเอาไปรษณีย์มาให้แล้วค่ะ
Dialogue: 0,0:15:09.24,0:15:11.54,Default,,0,0,0,,มาพอดีเลย จะแนะนำให้รู้จัก
Dialogue: 0,0:15:11.54,0:15:13.67,Default,,0,0,0,,นี่อากาธา เสมียนของที่นี่
Dialogue: 0,0:15:13.67,0:15:14.89,Default,,0,0,0,,สวัสดี
Dialogue: 0,0:15:14.89,0:15:19.88,Default,,0,0,0,,ส่วนนี่เบียงก้า คนทำความสะอาดคนใหม่ \Nพวกเธอสองคนก็ทำความรู้จักกันไว้นะ
Dialogue: 0,0:15:28.91,0:15:31.36,Default,,0,0,0,,เดี๋ยวจะพาไปดูโรงงานทีหลัง
Dialogue: 0,0:15:31.36,0:15:32.57,Default,,0,0,0,,ไปรอข้างนอกก่อน
Dialogue: 0,0:15:33.08,0:15:34.91,Default,,0,0,0,,อากาธา เธอไปได้แล้ว
Dialogue: 0,0:15:34.91,0:15:36.29,Default,,0,0,0,,ค่ะ
Dialogue: 0,0:15:44.92,0:15:47.98,Default,,0,0,0,,แถวนี้เป็นหอพักของพนักงาน
Dialogue: 0,0:15:47.98,0:15:52.37,Default,,0,0,0,,เธอจะต้องทำความสะอาดกับทำงานจิปาถะของตึกนี้
Dialogue: 0,0:15:52.37,0:15:53.31,Default,,0,0,0,,ค่ะ
Dialogue: 0,0:15:54.55,0:15:56.63,Default,,0,0,0,,ที่นี่คือที่ทำงาน
Dialogue: 0,0:16:01.34,0:16:04.94,Default,,0,0,0,,ยัยนั่นก็คือไดอาน่า พนักงานที่เพิ่งเข้ามาใหม่เหมือนกัน
Dialogue: 0,0:16:05.19,0:16:08.69,Default,,0,0,0,,ดูภูมิฐานขนาดนั้น แต่อายุแค่ 16 เองนะ
Dialogue: 0,0:16:08.69,0:16:10.95,Default,,0,0,0,,คงจะลำบากมาน่าดูเลยนะ
Dialogue: 0,0:16:12.31,0:16:14.16,Default,,0,0,0,,อายุ 16...
Dialogue: 0,0:16:14.47,0:16:16.33,Default,,0,0,0,,เป็นอะไรไป รีบมาสิ
Dialogue: 0,0:16:16.33,0:16:17.65,Default,,0,0,0,,อ๊ะ ค่ะ!
Dialogue: 0,0:16:20.66,0:16:22.96,Default,,0,0,0,,นี่ เทอร์เนอร์ ตื่นอยู่รึเปล่า
Dialogue: 0,0:16:23.73,0:16:27.36,Default,,0,0,0,,ที่นี่เป็นห้องทำงานของคนทำเงินให้เราน่ะนะ
Dialogue: 0,0:16:27.36,0:16:31.37,Default,,0,0,0,,แต่เขาเป็นคนเก็บตัว\N นอกจากตอนกินข้าวกับเข้าห้องน้ำแล้วก็ไม่ค่อยออกมาหรอก
Dialogue: 0,0:16:31.70,0:16:33.34,Default,,0,0,0,,นี่ เทอร์เนอร์
Dialogue: 0,0:16:33.34,0:16:35.48,Default,,0,0,0,,มีจดหมายมาส่งนะ
Dialogue: 0,0:16:41.15,0:16:43.49,Default,,0,0,0,,อะไรกัน นอนอยู่เหรอ
Dialogue: 0,0:16:43.49,0:16:45.92,Default,,0,0,0,,นี่คือคนทำความสะอาดคนใหม่
Dialogue: 0,0:16:45.92,0:16:49.26,Default,,0,0,0,,ชื่อเบียงก้าค่ะ ฝากเนื้อฝากตัวด้วยนะคะ
Dialogue: 0,0:16:49.80,0:16:51.74,Default,,0,0,0,,จดหมายล่ะ
Dialogue: 0,0:16:51.74,0:16:53.83,Default,,0,0,0,,อ้อ ใช่แล้ว
Dialogue: 0,0:16:54.99,0:16:55.88,Default,,0,0,0,,นี่ไง
Dialogue: 0,0:16:59.00,0:17:02.62,Default,,0,0,0,,เขาอาจจะแปลกไปหน่อย แต่ก็ไม่ใช่คนเลวร้ายอะไรหรอก
Dialogue: 0,0:17:02.62,0:17:04.19,Default,,0,0,0,,ก็พยายามเข้ากันให้ได้นะ
Dialogue: 0,0:17:04.19,0:17:05.00,Default,,0,0,0,,ค่ะ
Dialogue: 0,0:17:13.75,0:17:15.57,Default,,0,0,0,,งั้นก็เหนื่อยหน่อยนะ
Dialogue: 0,0:17:15.57,0:17:17.45,Default,,0,0,0,,ขอบคุณที่เหนื่อยมาด้วยกันค่ะ
Dialogue: 0,0:18:29.99,0:18:31.56,Default,,0,0,0,,ดูเหมือนจะไปแล้วนะ
Dialogue: 0,0:18:31.56,0:18:32.41,Default,,0,0,0,,อื้ม
Dialogue: 0,0:18:36.23,0:18:37.10,Default,,0,0,0,,ฉันเอง
Dialogue: 0,0:18:40.09,0:18:41.10,Default,,0,0,0,,เหนื่อยหน่อยนะ
Dialogue: 0,0:18:41.10,0:18:42.02,Default,,0,0,0,,เป็นไงบ้าง
Dialogue: 0,0:18:42.02,0:18:45.10,Default,,0,0,0,,ผู้ชายสองคนคอยเฝ้าดูอยู่ แต่กลับไปแล้วล่ะ
Dialogue: 0,0:18:45.10,0:18:47.11,Default,,0,0,0,,เหมือนกับตอนพวกเราเลยนะ
Dialogue: 0,0:18:47.11,0:18:48.05,Default,,0,0,0,,อื้ม
Dialogue: 0,0:18:48.05,0:18:51.11,Default,,0,0,0,,พวกนั้นเคลื่อนไหวเหมือนมือสมัครเล่นเลย
Dialogue: 0,0:18:51.11,0:18:54.07,Default,,0,0,0,,ฉันควรทำยังไงดีคะ
Dialogue: 0,0:18:54.07,0:18:56.19,Default,,0,0,0,,ทำตัวตามปกติก็พอแล้วล่ะ
Dialogue: 0,0:18:56.19,0:18:57.52,Default,,0,0,0,,ฉากบังหน้าครั้งนี้
Dialogue: 0,0:18:57.52,0:18:59.64,Default,,0,0,0,,อิงจากประวัติของเบียโต้
Dialogue: 0,0:18:59.97,0:19:02.62,Default,,0,0,0,,ส่วนเรื่องภารกิจก็ปล่อยให้เป็นหน้าที่ของพวกเรา
Dialogue: 0,0:19:03.12,0:19:04.37,Default,,0,0,0,,ค่ะ
Dialogue: 0,0:19:31.45,0:19:32.61,Default,,0,0,0,,เอาล่ะ
Dialogue: 0,0:19:36.21,0:19:37.43,Default,,0,0,0,,เบียงก้าค่ะ
Dialogue: 0,0:19:37.43,0:19:39.16,Default,,0,0,0,,มาทำความสะอาดค่ะ
Dialogue: 0,0:19:41.99,0:19:43.86,Default,,0,0,0,,เอ่อ คุณเทอร์เนอร์คะ
Dialogue: 0,0:19:43.86,0:19:45.88,Default,,0,0,0,,ตื่นอยู่รึเปล่าคะ
Dialogue: 0,0:19:53.76,0:19:55.17,Default,,0,0,0,,ขออนุญาตนะคะ
Dialogue: 0,0:19:55.37,0:19:56.81,Default,,0,0,0,,คุณเทอร์เนอร์
Dialogue: 0,0:19:57.51,0:19:59.18,Default,,0,0,0,,เหม็นชะมัด!
Dialogue: 0,0:19:59.18,0:20:00.91,Default,,0,0,0,,อะไรกันเนี่ย
Dialogue: 0,0:20:04.08,0:20:05.69,Default,,0,0,0,,คุณเทอร์เนอร์
Dialogue: 0,0:20:06.07,0:20:07.82,Default,,0,0,0,,ไม่อยู่เหรอคะ
Dialogue: 0,0:20:32.01,0:20:33.59,Default,,0,0,0,,ล็อกเกต?
Dialogue: 0,0:20:35.21,0:20:37.56,Default,,0,0,0,,ไม่ได้การ
Dialogue: 0,0:20:38.23,0:20:40.29,Default,,0,0,0,,ต้องทำความสะอาด
Dialogue: 0,0:21:04.68,0:21:05.24,Default,,0,0,0,,เฮ้ย!
Dialogue: 0,0:21:05.44,0:21:07.25,Default,,0,0,0,,มาทำอะไรที่นี่
Dialogue: 0,0:21:07.90,0:21:10.16,Default,,0,0,0,,อย่ามาจับเครื่องมือของฉันตามใจชอบนะ!
Dialogue: 0,0:21:11.49,0:21:12.98,Default,,0,0,0,,เอ่อ คือ...
Dialogue: 0,0:21:14.44,0:21:16.27,Default,,0,0,0,,รีบออกไปซะ!
Dialogue: 0,0:21:19.58,0:21:21.26,Default,,0,0,0,,เอ่อ!
Dialogue: 0,0:21:56.51,0:21:57.30,Default,,0,0,0,,เฮ้ย!
Dialogue: 0,0:21:58.32,0:21:59.30,Default,,0,0,0,,ค่ะ
Dialogue: 0,0:21:59.30,0:22:00.69,Default,,0,0,0,,มีเรื่องจะคุยด้วย
Dialogue: 0,0:22:00.69,0:22:01.62,Default,,0,0,0,,กลับมา
Dialogue: 0,0:22:06.28,0:22:07.31,Default,,0,0,0,,ขอโทษค่ะ
Dialogue: 0,0:22:07.31,0:22:12.11,Default,,0,0,0,,เห็นว่ามีแต่ขยะกับฝุ่นก็เลยคิดว่าจะเช็ดให้สะอาดน่ะค่ะ...
Dialogue: 0,0:22:12.11,0:22:14.34,Default,,0,0,0,,เธอรู้เรื่องเครื่องมือดีเหรอ
Dialogue: 0,0:22:14.34,0:22:15.31,Default,,0,0,0,,คะ?
Dialogue: 0,0:22:15.52,0:22:17.07,Default,,0,0,0,,เธอทำความสะอาดมันสินะ
Dialogue: 0,0:22:17.32,0:22:19.01,Default,,0,0,0,,คนทำความสะอาดคนก่อน ๆ
Dialogue: 0,0:22:19.01,0:22:21.60,Default,,0,0,0,,ไม่เคยเอาน้ำมันมาทาใบมีดเลย
Dialogue: 0,0:22:21.60,0:22:23.32,Default,,0,0,0,,เอ่อ คือว่า...
Dialogue: 0,0:22:23.32,0:22:26.13,Default,,0,0,0,,ที่บ้านฉันก็มีของแบบนี้เหมือนกันค่ะ
Dialogue: 0,0:22:26.92,0:22:28.43,Default,,0,0,0,,งั้นเหรอ
Dialogue: 0,0:22:31.33,0:22:32.93,Default,,0,0,0,,เลิกทำงานที่นี่ซะ
Dialogue: 0,0:22:34.36,0:22:37.34,Default,,0,0,0,,ที่นี่ไม่ใช่ที่ที่เด็กผู้หญิงอย่างเธอจะมา
Dialogue: 0,0:22:39.71,0:22:41.34,Default,,0,0,0,,เจอแล้ว อยู่นี่เอง!
Dialogue: 0,0:22:41.34,0:22:43.34,Default,,0,0,0,,เด็กใหม่ มีงานให้เธอทำ
Dialogue: 0,0:22:43.34,0:22:45.34,Default,,0,0,0,,จะไปเอาของที่โกดัง
Dialogue: 0,0:22:45.34,0:22:47.35,Default,,0,0,0,,มาช่วยหน่อยสิ
Dialogue: 0,0:22:47.65,0:22:48.45,Default,,0,0,0,,ค่ะ!
Dialogue: 0,0:22:48.77,0:22:49.86,Default,,0,0,0,,ขอโทษค่ะ
Dialogue: 0,0:22:49.86,0:22:51.35,Default,,0,0,0,,ขอตัวก่อนนะคะ
Dialogue: 0,0:23:04.87,0:23:08.81,Default,,0,0,0,,น้ำมันสน น้ำมันวอลนัท...
Dialogue: 0,0:23:09.37,0:23:11.81,Default,,0,0,0,,กล่องไหนเป็นกล่องอะไรกันนะ...
Dialogue: 0,0:23:18.27,0:23:20.55,Default,,0,0,0,,เพิ่งจะมาเมื่อวานนี้เอง
Dialogue: 0,0:23:20.55,0:23:23.15,Default,,0,0,0,,จะไปรู้ได้ยังไงว่าอะไรอยู่ตรงไหน...
Dialogue: 0,0:23:26.03,0:23:26.79,Default,,0,0,0,,จับได้แล้ว!
Dialogue: 0,0:23:26.79,0:23:28.45,Default,,0,0,0,,อย่าส่งเสียงดังสิ!
Dialogue: 0,0:23:29.60,0:23:33.39,Default,,0,0,0,,ดันมาโยนงานน่ารำคาญให้ทำอยู่ได้!
Dialogue: 0,0:23:33.39,0:23:36.52,Default,,0,0,0,,ต้องเอาค่าล่วงเวลาของเมื่อวานมาให้ได้!
Dialogue: 0,0:23:36.52,0:23:39.40,Default,,0,0,0,,นั่นแหละ! อย่าหาว่าฉันใจร้ายก็แล้วกัน!
Dialogue: 0,0:23:40.37,0:23:42.59,Default,,0,0,0,,อย่าดิ้นสิ!
Dialogue: 0,0:23:42.59,0:23:44.04,Default,,0,0,0,,ว่าแล้วเชียว...
Dialogue: 0,0:23:44.04,0:23:45.86,Default,,0,0,0,,ไอ้พวกเลวทราม
Dialogue: 0,0:23:46.91,0:23:48.30,Default,,0,0,0,,อะไรน่ะ
Dialogue: 0,0:23:58.75,0:24:01.08,Default,,0,0,0,,ปล่อยเด็กผู้หญิงคนนั้นซะ
Dialogue: 0,0:24:01.08,0:24:02.49,Default,,0,0,0,,เทอร์เนอร์!
Dialogue: 0,0:24:03.64,0:24:05.42,Default,,0,0,0,,เดี๋ยว!
Dialogue: 0,0:24:09.09,0:24:12.30,Default,,0,0,0,,อย่ามาทำเป็นคนดีแล้วเสนอหน้าเข้ามานะเว้ย!
Dialogue: 0,0:24:12.30,0:24:13.13,Default,,0,0,0,,ใช่แล้ว!
Dialogue: 0,0:24:13.13,0:24:16.46,Default,,0,0,0,,เพราะแกนั่นแหละ พวกฉันถึงต้องมาซวยแบบนี้!
Dialogue: 0,0:24:17.67,0:24:19.44,Default,,0,0,0,,คุณเทอร์เนอร์!
Dialogue: 0,0:24:23.44,0:24:25.44,Default,,0,0,0,,เฮ้ย อะไรวะ
Dialogue: 0,0:24:27.66,0:24:28.82,Default,,0,0,0,,ยิงสิ!
Dialogue: 0,0:24:28.82,0:24:30.55,Default,,0,0,0,,ถ้าฉันทำงานไม่ได้
Dialogue: 0,0:24:30.55,0:24:32.41,Default,,0,0,0,,พวกแกนั่นแหละที่จะเดือดร้อน!
Dialogue: 0,0:24:34.59,0:24:36.41,Default,,0,0,0,,อย่าได้ใจไปหน่อยเลย!
Dialogue: 0,0:24:36.41,0:24:39.73,Default,,0,0,0,,คนที่จะมาแทนแกน่ะมีอีกเยอะแยะ!
Dialogue: 0,0:24:40.40,0:24:41.89,Default,,0,0,0,,งั้นเหรอ
Dialogue: 0,0:24:45.07,0:24:47.47,Default,,0,0,0,,ขอบคุณมากค่ะ
Dialogue: 0,0:24:50.75,0:24:52.57,Default,,0,0,0,,ทีนี้ก็เข้าใจแล้วสินะ
Dialogue: 0,0:24:52.57,0:24:54.76,Default,,0,0,0,,ถ้าจะทำงานก็ไปที่อื่นซะ
Dialogue: 0,0:24:58.69,0:25:00.20,Default,,0,0,0,,บ้าเอ๊ย!
Dialogue: 0,0:25:01.20,0:25:02.55,Default,,0,0,0,,เวรเอ๊ย!
Dialogue: 0,0:25:02.55,0:25:04.87,Default,,0,0,0,,เจ้านั่น ได้ใจใหญ่แล้ว!
Dialogue: 0,0:25:04.87,0:25:06.70,Default,,0,0,0,,อย่าไปหัวร้อนสิ!
Dialogue: 0,0:25:06.70,0:25:09.11,Default,,0,0,0,,เรารู้บ้านยัยนั่นอยู่แล้วนี่
Dialogue: 0,0:25:09.11,0:25:12.09,Default,,0,0,0,,แต่คนที่ฉันหงุดหงิดคือเทอร์เนอร์ต่างหาก!
Dialogue: 0,0:25:12.09,0:25:14.11,Default,,0,0,0,,รีบไปจัดการมันซะเถอะ!
Dialogue: 0,0:25:14.11,0:25:14.69,Default,,0,0,0,,เฮ้ย
Dialogue: 0,0:25:15.27,0:25:18.43,Default,,0,0,0,,ถ้าจัดการมัน เงินที่ส่งมาก็จะหยุดด้วยสิ!
Dialogue: 0,0:25:18.43,0:25:21.05,Default,,0,0,0,,แล้วจะไปรีดไถเงินจากไหนล่ะ!
Dialogue: 0,0:25:21.05,0:25:23.50,Default,,0,0,0,,อย่าทำอะไรไม่เข้าเรื่องนะ!
Dialogue: 0,0:25:23.72,0:25:24.38,Default,,0,0,0,,ชิ
Dialogue: 0,0:25:24.83,0:25:26.96,Default,,0,0,0,,รู้แล้วน่า ให้ตายสิ!
Dialogue: 0,0:25:32.79,0:25:35.51,Default,,0,0,0,,ถูกพวกผู้ชายที่โรงงานทำร้ายเหรอ
Dialogue: 0,0:25:35.51,0:25:36.65,Default,,0,0,0,,ค่ะ
Dialogue: 0,0:25:36.65,0:25:39.91,Default,,0,0,0,,แต่ว่าคุณเทอร์เนอร์ช่วยไว้ค่ะ
Dialogue: 0,0:25:39.91,0:25:43.32,Default,,0,0,0,,ขอโทษที ฉันน่าจะระวังให้มากกว่านี้
Dialogue: 0,0:25:43.32,0:25:44.37,Default,,0,0,0,,ไม่เป็นไร
Dialogue: 0,0:25:44.53,0:25:45.70,Default,,0,0,0,,เพราะฉันคอยดูอยู่แล้ว
Dialogue: 0,0:25:47.24,0:25:48.84,Default,,0,0,0,,แต่ว่าพวกผู้ชายพวกนั้นน่ะ
Dialogue: 0,0:25:49.08,0:25:52.53,Default,,0,0,0,,พูดเหมือนกับว่ากำลังแอบยักยอกเงินที่คุณเทอร์เนอร์ส่งไปให้อยู่
Dialogue: 0,0:25:52.53,0:25:53.54,Default,,0,0,0,,เงินที่ส่งไปให้เหรอ
Dialogue: 0,0:25:53.54,0:25:54.17,Default,,0,0,0,,ค่ะ
Dialogue: 0,0:25:54.55,0:25:58.75,Default,,0,0,0,,มีจดหมายส่งถึงคุณเทอร์เนอร์ \Nจากภรรยาที่อาศัยอยู่ในสาธารณรัฐส่งมาค่ะ
Dialogue: 0,0:25:59.12,0:25:59.87,Default,,0,0,0,,นั่น
Dialogue: 0,0:25:59.87,0:26:01.54,Default,,0,0,0,,จดหมายของเมื่อวานใช่ไหมคะ
Dialogue: 0,0:26:01.74,0:26:03.26,Default,,0,0,0,,เธอหยิบมาเหรอคะ
Dialogue: 0,0:26:03.26,0:26:04.03,Default,,0,0,0,,เปล่าค่ะ
Dialogue: 0,0:26:04.03,0:26:07.31,Default,,0,0,0,,เป็นฉบับที่ฉันคัดลอกไว้ก่อนจะเอาไปให้ท่านประธานค่ะ
Dialogue: 0,0:26:07.97,0:26:12.51,Default,,0,0,0,,เนื้อหาก็แค่ขอบคุณสำหรับเงินที่ส่งมาให้ เป็นเนื้อหาธรรมดา ๆ นะ
Dialogue: 0,0:26:12.87,0:26:15.55,Default,,0,0,0,,ที่รู้ก็มีแค่ที่อยู่กับชื่อสินะ
Dialogue: 0,0:26:15.55,0:26:16.85,Default,,0,0,0,,พวกผู้ชายพวกนั้น
Dialogue: 0,0:26:16.85,0:26:19.12,Default,,0,0,0,,เงินที่คุณเทอร์เนอร์ส่งไปให้ภรรยา
Dialogue: 0,0:26:19.12,0:26:20.90,Default,,0,0,0,,อาจจะเก็บเข้ากระเป๋าตัวเองก็ได้
Dialogue: 0,0:26:20.90,0:26:22.26,Default,,0,0,0,,แบบนั้นมัน!
Dialogue: 0,0:26:22.63,0:26:25.56,Default,,0,0,0,,ถ้าพวกนั้นกำลังหักหลังคุณเทอร์เนอร์อยู่ล่ะก็
Dialogue: 0,0:26:25.56,0:26:27.57,Default,,0,0,0,,ก็ไม่มีเหตุผลที่เราจะไม่ใช้ประโยชน์จากเรื่องนี้
Dialogue: 0,0:26:27.57,0:26:30.21,Default,,0,0,0,,เดี๋ยวฉันจะลองไปหาหลักฐานอื่นดู
Dialogue: 0,0:26:30.21,0:26:31.30,Default,,0,0,0,,เข้าใจแล้ว
Dialogue: 0,0:26:31.30,0:26:33.06,Default,,0,0,0,,เรื่องนั้นฝากด้วยนะ
Dialogue: 0,0:26:34.35,0:26:35.57,Default,,0,0,0,,เสร็จแล้ว!
Dialogue: 0,0:26:35.81,0:26:37.58,Default,,0,0,0,,ได้เวลากินข้าวแล้วจ้า!
Dialogue: 0,0:26:37.58,0:26:39.59,Default,,0,0,0,,โอ้! รออยู่เลย!
Dialogue: 0,0:26:39.59,0:26:41.58,Default,,0,0,0,,เป็นอาหารที่มีกลิ่นเป็นเอกลักษณ์นะ
Dialogue: 0,0:26:41.78,0:26:42.54,Default,,0,0,0,,อื้ม
Dialogue: 0,0:26:42.54,0:26:44.49,Default,,0,0,0,,เชิญลิ้มรสให้เต็มที่เลย
Dialogue: 0,0:26:44.49,0:26:45.97,Default,,0,0,0,,สุกี้ยากี้ไงล่ะ
Dialogue: 0,0:26:47.22,0:26:50.98,Default,,0,0,0,,ตีไข่ดิบแล้วเอาเนื้อจุ่มลงไปกิน
Dialogue: 0,0:26:51.59,0:26:53.09,Default,,0,0,0,,เดี๋ยวก็ท้องเสียหรอกค่ะ!
Dialogue: 0,0:27:15.61,0:27:17.62,Default,,0,0,0,,นี่ เบียงก้า
Dialogue: 0,0:27:17.62,0:27:19.09,Default,,0,0,0,,อ๊ะ ค่ะ
Dialogue: 0,0:27:19.09,0:27:22.34,Default,,0,0,0,,ตั้งแต่วันนี้ไป เธอต้องเป็นคนดูแลเทอร์เนอร์
Dialogue: 0,0:27:23.33,0:27:26.62,Default,,0,0,0,,ดูเหมือนเจ้านั่นจะถูกใจเธอนะ
Dialogue: 0,0:27:26.62,0:27:29.63,Default,,0,0,0,,เทอร์เนอร์เป็นคนทำเงินให้เรานะ
Dialogue: 0,0:27:29.63,0:27:32.51,Default,,0,0,0,,อย่าทำให้เขาอารมณ์เสียเด็ดขาดล่ะ
Dialogue: 0,0:27:32.51,0:27:36.51,Default,,0,0,0,,ให้ตายสิ ผู้หญิงนี่ดูจากภายนอกไม่ได้จริง ๆ
Dialogue: 0,0:27:40.50,0:27:42.79,Default,,0,0,0,,เอ่อ เบียงก้าค่ะ
Dialogue: 0,0:27:42.79,0:27:43.64,Default,,0,0,0,,เข้ามา
Dialogue: 0,0:27:44.71,0:27:46.27,Default,,0,0,0,,ขออนุญาตนะคะ
Dialogue: 0,0:27:54.90,0:27:55.65,Default,,0,0,0,,เอ่อ...
Dialogue: 0,0:27:55.65,0:27:57.34,Default,,0,0,0,,ทำไมถึงกลับมา
Dialogue: 0,0:27:58.12,0:28:00.44,Default,,0,0,0,,ฉันบอกให้ไปที่อื่นแล้วไม่ใช่เหรอ
Dialogue: 0,0:28:00.44,0:28:02.92,Default,,0,0,0,,ทำไมถึงไม่ลาออก แล้วทําไมยังกลับมาอีกล่ะ
Dialogue: 0,0:28:03.25,0:28:07.31,Default,,0,0,0,,เอ่อ คือว่า... ไม่มีที่อื่นให้ไปแล้วน่ะค่ะ...
Dialogue: 0,0:28:09.67,0:28:12.37,Default,,0,0,0,,เอ่อ ฉันต้องทำอะไรบ้างคะ
Dialogue: 0,0:28:12.37,0:28:14.38,Default,,0,0,0,,ไม่ต้องทำอะไรทั้งนั้น
Dialogue: 0,0:28:14.38,0:28:16.76,Default,,0,0,0,,แล้วก็อย่าไปคุยกับพวกข้างนอกด้วย
Dialogue: 0,0:28:17.68,0:28:19.68,Default,,0,0,0,,เธออ่านหนังสือออกไหม
Dialogue: 0,0:28:20.20,0:28:21.23,Default,,0,0,0,,อ๊ะ ค่ะ
Dialogue: 0,0:28:21.23,0:28:22.87,Default,,0,0,0,,งั้นจนกว่าจะถึงเวลาเลิกงาน
Dialogue: 0,0:28:22.87,0:28:25.31,Default,,0,0,0,,ก็ไปหาหนังสือแถว ๆ นั้นอ่านซะ
Dialogue: 0,0:28:25.31,0:28:27.36,Default,,0,0,0,,ถ้าจะทำงานต่อล่ะก็
Dialogue: 0,0:28:27.36,0:28:30.78,Default,,0,0,0,,พรุ่งนี้ก็หาอะไรมาทำฆ่าเวลาเองก็แล้วกัน
Dialogue: 0,0:28:49.71,0:28:51.21,Default,,0,0,0,,ไม่เป็นไรหรอก
Dialogue: 0,0:28:51.21,0:28:53.22,Default,,0,0,0,,วันนี้ไม่มีคนสะกดรอยตาม
Dialogue: 0,0:28:53.22,0:28:54.70,Default,,0,0,0,,คุณจิเสะ!
Dialogue: 0,0:28:54.70,0:28:57.51,Default,,0,0,0,,อย่าทำให้ตกใจสิคะ!
Dialogue: 0,0:28:57.51,0:28:59.04,Default,,0,0,0,,โทษที โทษที
Dialogue: 0,0:29:07.91,0:29:09.73,Default,,0,0,0,,โอเค เยี่ยมมาก!
Dialogue: 0,0:29:09.73,0:29:12.77,Default,,0,0,0,,ทำให้เสร็จตามจำนวนที่กำหนดภายในพรุ่งนี้นะ!
Dialogue: 0,0:29:58.57,0:29:59.78,Default,,0,0,0,,จดหมายเหรอ
Dialogue: 0,0:29:59.78,0:30:00.60,Default,,0,0,0,,ใช่
Dialogue: 0,0:30:00.60,0:30:05.19,Default,,0,0,0,,ดูเหมือนคุณเทอร์เนอร์จะส่งเงินให้ภรรยาที่อยู่สาธารณรัฐจริง ๆ ด้วย
Dialogue: 0,0:30:05.19,0:30:07.79,Default,,0,0,0,,แต่ว่า จดหมายที่คุณเทอร์เนอร์ส่ง
Dialogue: 0,0:30:07.79,0:30:09.87,Default,,0,0,0,,ถูกเก็บไว้ในตู้เซฟของท่านประธาน
Dialogue: 0,0:30:09.95,0:30:10.65,Default,,0,0,0,,เอ๊ะ!?
Dialogue: 0,0:30:10.70,0:30:15.45,Default,,0,0,0,,งั้นก็แสดงว่าไม่ได้ส่งจดหมายแล้วก็ยักยอกเงินไปสินะ
Dialogue: 0,0:30:15.45,0:30:17.24,Default,,0,0,0,,พวกเลวทรามอะไรกันนี่!
Dialogue: 0,0:30:17.24,0:30:20.34,Default,,0,0,0,,แค่ฟังก็รู้สึกคลื่นไส้แล้ว!
Dialogue: 0,0:30:20.34,0:30:21.80,Default,,0,0,0,,จดหมายตอบกลับจากภรรยาก็ด้วย
Dialogue: 0,0:30:21.99,0:30:25.60,Default,,0,0,0,,ดูเหมือนจะปลอมแปลงขึ้นมาเพื่อไม่ให้การส่งเงินหยุดชะงัก
Dialogue: 0,0:30:25.60,0:30:29.82,Default,,0,0,0,,เอาเป็นว่าเรื่องภรรยาของเขาให้คอนโทรลไปสืบก็แล้วกัน
Dialogue: 0,0:30:29.82,0:30:32.71,Default,,0,0,0,,ส่วนเรื่องคุณเทอร์เนอร์จะทำยังไงก็รอคำสั่ง
Dialogue: 0,0:30:33.57,0:30:35.49,Default,,0,0,0,,จะไม่บอกเขาเหรอคะ
Dialogue: 0,0:30:35.49,0:30:39.61,Default,,0,0,0,,งานของพวกเราไม่ใช่การไปช่วยคุณเทอร์เนอร์นะ
Dialogue: 0,0:30:39.61,0:30:40.77,Default,,0,0,0,,ยิ่งไปกว่านั้น
Dialogue: 0,0:30:40.77,0:30:43.33,Default,,0,0,0,,ตอนนี้สถานะของพวกเราก็ล่อแหลมอยู่แล้ว
Dialogue: 0,0:30:43.82,0:30:44.82,Default,,0,0,0,,แต่ว่า...
Dialogue: 0,0:30:45.13,0:30:47.83,Default,,0,0,0,,ถ้าตอนนี้ปล่อยให้อารมณ์มาอยู่เหนือเหตุผลแล้วทำพลาดไปล่ะก็
Dialogue: 0,0:30:47.83,0:30:49.83,Default,,0,0,0,,ชีวิตของพรินเซสจะตกอยู่ในอันตราย
Dialogue: 0,0:30:50.39,0:30:53.83,Default,,0,0,0,,ภารกิจนี้ทั้งดยุกนอร์มังดีและสาธารณรัฐ
Dialogue: 0,0:30:53.83,0:30:57.84,Default,,0,0,0,,ต่างก็จับตาดูอยู่ว่าพวกเราจะภักดีต่อฝ่ายไหน
Dialogue: 0,0:30:58.62,0:31:00.09,Default,,0,0,0,,เพราะงั้นอย่าประมาท
Dialogue: 0,0:31:21.85,0:31:25.86,Default,,0,0,0,,ถ้าเทียบกับมือสมัครเล่นแล้วก็ถือว่าทำได้ดีนะ
Dialogue: 0,0:31:26.08,0:31:29.03,Default,,0,0,0,,ถึงกับลากลูกสาวคนรองมาเป็นสปายด้วย
Dialogue: 0,0:31:29.03,0:31:30.80,Default,,0,0,0,,เธอนี่ก็ช่าง
Dialogue: 0,0:31:30.80,0:31:33.27,Default,,0,0,0,,ร้ายกาจจริง ๆ นะ ชาร์ล็อตต์
Dialogue: 0,0:31:36.32,0:31:39.35,Default,,0,0,0,,ทางสาธารณรัฐจะยอมตกลงด้วยเหรอคะ
Dialogue: 0,0:31:39.35,0:31:42.82,Default,,0,0,0,,ก็คงต้องบอกว่าขึ้นอยู่กับทางกระทรวงการต่างประเทศล่ะนะ
Dialogue: 0,0:31:42.82,0:31:47.89,Default,,0,0,0,,แต่ว่าการที่ส่งทีมของพวกเธอมาทำภารกิจนี้
Dialogue: 0,0:31:48.19,0:31:51.89,Default,,0,0,0,,ดูเหมือนทางนี้ก็จะถูกคานอำนาจเอาไว้เหมือนกัน
Dialogue: 0,0:31:52.75,0:31:55.89,Default,,0,0,0,,น่าสนุกขึ้นมาแล้วสิ ชาร์ล็อตต์
Dialogue: 0,0:31:56.59,0:31:57.90,Default,,0,0,0,,ไม่มีทาง!
Dialogue: 0,0:31:57.90,0:32:00.17,Default,,0,0,0,,จะให้ส่งตัวจอห์นสัน คาร์เตอร์ไป
Dialogue: 0,0:32:00.17,0:32:01.90,Default,,0,0,0,,มันไม่สมน้ำสมเนื้อกันเลย!
Dialogue: 0,0:32:01.90,0:32:03.90,Default,,0,0,0,,จอห์นสัน คาร์เตอร์เป็นชื่อปลอมค่ะ
Dialogue: 0,0:32:04.07,0:32:05.90,Default,,0,0,0,,จะอะไรก็ช่างเถอะ!?
Dialogue: 0,0:32:05.90,0:32:09.11,Default,,0,0,0,,ยังไงซะเจ้านั่นก็รู้เรื่องระเบิดมากเกินไปแล้ว!
Dialogue: 0,0:32:09.11,0:32:11.23,Default,,0,0,0,,ไม่มีทางยอมรับข้อตกลงได้หรอก!
Dialogue: 0,0:32:11.23,0:32:14.40,Default,,0,0,0,,แต่ในฐานะรัฐบาลแล้วจะเป็นยังไงกันนะ
Dialogue: 0,0:32:14.40,0:32:15.47,Default,,0,0,0,,พูดตามตรง
Dialogue: 0,0:32:15.47,0:32:17.41,Default,,0,0,0,,คนร้ายที่ลอบสังหารราชวงศ์น่ะ
Dialogue: 0,0:32:17.41,0:32:19.46,Default,,0,0,0,,ก็เหมือนตัวปัญหานะครับ
Dialogue: 0,0:32:19.46,0:32:21.38,Default,,0,0,0,,ถ้าจะสร้างบุญคุณกับราชอาณาจักรได้
Dialogue: 0,0:32:21.38,0:32:23.30,Default,,0,0,0,,ก็เหมือนยิงปืนนัดเดียวได้นกสองตัวนะ
Dialogue: 0,0:32:23.30,0:32:27.41,Default,,0,0,0,,ทั้งที่นายเป็นช่างเทคนิคแท้ ๆ แต่ดันไปเข้าข้างใครกันแน่!
Dialogue: 0,0:32:27.41,0:32:29.26,Default,,0,0,0,,จากรายงานของประเทศเรา
Dialogue: 0,0:32:29.26,0:32:32.19,Default,,0,0,0,,ยืนยันที่อยู่ของภรรยาคุณเทอร์เนอร์ได้แล้วค่ะ
Dialogue: 0,0:32:47.29,0:32:49.34,Default,,0,0,0,,หมายความว่ายังไง
Dialogue: 0,0:32:49.34,0:32:50.84,Default,,0,0,0,,ค่ะ
Dialogue: 0,0:32:57.64,0:32:59.96,Default,,0,0,0,,รู้ที่อยู่ของภรรยาคุณเทอร์เนอร์แล้ว
Dialogue: 0,0:33:00.17,0:33:01.60,Default,,0,0,0,,จริงเหรอคะ
Dialogue: 0,0:33:01.60,0:33:02.57,Default,,0,0,0,,อื้ม
Dialogue: 0,0:33:02.57,0:33:05.47,Default,,0,0,0,,ตอนนี้อยู่ที่สถานสงเคราะห์ในเบอร์มิงแฮม
Dialogue: 0,0:33:05.47,0:33:07.68,Default,,0,0,0,,ดูเหมือนจะป่วยเป็นวัณโรค
Dialogue: 0,0:33:08.29,0:33:10.74,Default,,0,0,0,,วัณโรคเหรอคะ
Dialogue: 0,0:33:10.74,0:33:13.77,Default,,0,0,0,,ได้ยินว่าร่างกายอ่อนแอมาตั้งแต่เกิด
Dialogue: 0,0:33:13.77,0:33:15.13,Default,,0,0,0,,หลังจากแต่งงาน
Dialogue: 0,0:33:15.13,0:33:17.98,Default,,0,0,0,,ตอนที่คุณเทอร์เนอร์มาทำงานที่โรงงานนี้
Dialogue: 0,0:33:17.98,0:33:20.53,Default,,0,0,0,,ก็ต้องพลัดพรากกันเพราะการปฏิวัติ
Dialogue: 0,0:33:20.53,0:33:22.89,Default,,0,0,0,,คุณเทอร์เนอร์ก็เป็นห่วงภรรยา
Dialogue: 0,0:33:22.89,0:33:24.97,Default,,0,0,0,,เลยส่งเงินไปให้ตลอดสินะ
Dialogue: 0,0:33:24.97,0:33:27.20,Default,,0,0,0,,หน่วยข่าวกรองได้ติดต่อกับภรรยาของเขา
Dialogue: 0,0:33:27.20,0:33:29.99,Default,,0,0,0,,และบอกสถานการณ์ของคุณเทอร์เนอร์ให้แล้ว
Dialogue: 0,0:33:29.99,0:33:33.28,Default,,0,0,0,,ภรรยาของเขาก็เชื่อว่าสักวันคุณเทอร์เนอร์จะกลับมา
Dialogue: 0,0:33:33.28,0:33:35.30,Default,,0,0,0,,และรอมาโดยตลอด
Dialogue: 0,0:33:35.30,0:33:37.31,Default,,0,0,0,,ถึงจะรักกันมากขนาดนั้น
Dialogue: 0,0:33:37.31,0:33:40.01,Default,,0,0,0,,แต่ก็ข้ามพรมแดนไม่ได้สินะ
Dialogue: 0,0:33:40.01,0:33:41.65,Default,,0,0,0,,ตราบใดที่ยังมีกำแพงอยู่
Dialogue: 0,0:33:41.65,0:33:44.00,Default,,0,0,0,,เรื่องแบบนี้ก็มีอยู่ถมไป
Dialogue: 0,0:33:46.39,0:33:48.52,Default,,0,0,0,,นี่เป็นคำสั่งจากคอนโทรล
Dialogue: 0,0:33:48.52,0:33:50.49,Default,,0,0,0,,อยากจะฝากให้เบียโต้ทำ
Dialogue: 0,0:33:50.89,0:33:52.50,Default,,0,0,0,,ฉันเหรอคะ
Dialogue: 0,0:33:54.01,0:33:56.41,Default,,0,0,0,,อยากให้เอาอันนี้ไปให้คุณเทอร์เนอร์
Dialogue: 0,0:33:56.93,0:33:58.02,Default,,0,0,0,,ภรรยาของเขา
Dialogue: 0,0:33:58.02,0:34:01.40,Default,,0,0,0,,บอกว่าอยากจะใช้ชีวิตที่เหลืออยู่กับคุณเทอร์เนอร์
Dialogue: 0,0:34:01.40,0:34:04.83,Default,,0,0,0,,อยากให้ช่วยไปยืนยันเจตจำนงในการลี้ภัยของคุณเทอร์เนอร์
Dialogue: 0,0:34:04.83,0:34:07.55,Default,,0,0,0,,ให้ฉันไปถามเหรอคะ
Dialogue: 0,0:34:07.55,0:34:11.75,Default,,0,0,0,,เขาจะเชื่อเหรอคะว่าจดหมายฉบับนี้ภรรยาของเขาเป็นคนเขียน
Dialogue: 0,0:34:11.75,0:34:13.01,Default,,0,0,0,,ไม่เป็นไร
Dialogue: 0,0:34:13.01,0:34:15.62,Default,,0,0,0,,เอาอันนี้ไปให้พร้อมกับจดหมาย
Dialogue: 0,0:34:18.04,0:34:19.29,Default,,0,0,0,,นั่นมัน...
Dialogue: 0,0:34:20.53,0:34:22.93,Default,,0,0,0,,รับมาจากภรรยาของคุณเทอร์เนอร์
Dialogue: 0,0:34:22.93,0:34:25.70,Default,,0,0,0,,ได้ยินว่าคุณเทอร์เนอร์ก็มีเหมือนกัน
Dialogue: 0,0:34:27.58,0:34:29.36,Default,,0,0,0,,ดูเหมือนจะจัดการได้นะ
Dialogue: 0,0:34:30.05,0:34:32.72,Default,,0,0,0,,พอได้รับการยืนยันแล้วจะเริ่มแผนการทันที
Dialogue: 0,0:34:54.38,0:34:55.45,Default,,0,0,0,,เข้ามา
Dialogue: 0,0:34:58.89,0:35:01.25,Default,,0,0,0,,วันนี้มาช้านะ
Dialogue: 0,0:35:01.25,0:35:03.13,Default,,0,0,0,,นึกว่าลาออกไปแล้วซะอีก
Dialogue: 0,0:35:06.50,0:35:08.84,Default,,0,0,0,,คุณเทอร์เนอร์
Dialogue: 0,0:35:08.84,0:35:10.09,Default,,0,0,0,,เอ่อ...
Dialogue: 0,0:35:10.24,0:35:11.44,Default,,0,0,0,,นี่ค่ะ
Dialogue: 0,0:35:20.64,0:35:22.10,Default,,0,0,0,,เคลื่อนไหวแล้วเหรอ
Dialogue: 0,0:35:22.26,0:35:23.34,Default,,0,0,0,,อะไรนะ!?
Dialogue: 0,0:35:23.34,0:35:26.36,Default,,0,0,0,,เทอร์เนอร์พาคนทำความสะอาดหนีไปแล้วเหรอ!?
Dialogue: 0,0:35:26.36,0:35:29.65,Default,,0,0,0,,เฮอะ! เครื่องมือทำงานก็หายไปหมดเลย...
Dialogue: 0,0:35:30.58,0:35:31.71,Default,,0,0,0,,ไปเร็ว!
Dialogue: 0,0:35:39.60,0:35:41.53,Default,,0,0,0,,เจอแล้ว! ตรงนั้นไง!
Dialogue: 0,0:35:42.12,0:35:44.12,Default,,0,0,0,,คนไล่ตามมาแล้ว!
Dialogue: 0,0:35:44.65,0:35:45.80,Default,,0,0,0,,ทางนี้!
Dialogue: 0,0:35:47.60,0:35:48.73,Default,,0,0,0,,ถ้าเกิดอะไรขึ้น
Dialogue: 0,0:35:48.73,0:35:50.98,Default,,0,0,0,,ฉันจะให้เธอหนีไปคนเดียว
Dialogue: 0,0:35:50.98,0:35:53.88,Default,,0,0,0,,เอ่อ ทำไมถึงช่วยฉันด้วยล่ะคะ
Dialogue: 0,0:35:53.88,0:35:56.13,Default,,0,0,0,,ถึงเธอจะทำงานที่นั่นต่อไป
Dialogue: 0,0:35:56.13,0:35:57.67,Default,,0,0,0,,ก็ไม่มีอะไรดีขึ้นหรอก
Dialogue: 0,0:35:58.14,0:36:00.14,Default,,0,0,0,,ฉันจะไปสาธารณรัฐ
Dialogue: 0,0:36:00.54,0:36:03.72,Default,,0,0,0,,เธอเองก็อย่ามาทิ้งชีวิตไว้ที่นี่เลย
Dialogue: 0,0:36:15.33,0:36:16.57,Default,,0,0,0,,จนมุมแล้วสินะ
Dialogue: 0,0:36:19.51,0:36:20.71,Default,,0,0,0,,คุณเทอร์เนอร์
Dialogue: 0,0:36:20.71,0:36:22.49,Default,,0,0,0,,รอสักครู่นะคะ
Dialogue: 0,0:36:34.50,0:36:39.84,Default,,0,0,0,,เฮ้ย ฉันอยู่นี่! แค่ออกไปซื้อของแป๊บเดียวเอง!
Dialogue: 0,0:36:39.84,0:36:43.25,Default,,0,0,0,,เดี๋ยวก็กลับแล้ว พวกนายก็กลับไปที่โรงงานซะ!
Dialogue: 0,0:36:43.25,0:36:44.75,Default,,0,0,0,,ทางนั้น!
Dialogue: 0,0:36:46.68,0:36:48.93,Default,,0,0,0,,ฉันไม่ได้หนีไปไหนทั้งนั้น!
Dialogue: 0,0:36:51.85,0:36:54.91,Default,,0,0,0,,ได้ยินมาจากแถวนี้ มันหายไปไหนแล้ว
Dialogue: 0,0:36:55.25,0:36:56.50,Default,,0,0,0,,เมื่อกี้นี้?
Dialogue: 0,0:36:56.50,0:36:58.74,Default,,0,0,0,,คุณเทอร์เนอร์ ตอนนี้แหละค่ะ!
Dialogue: 0,0:36:58.74,0:37:00.20,Default,,0,0,0,,เร็วเข้า!
Dialogue: 0,0:37:08.81,0:37:11.22,Default,,0,0,0,,แค่นี้ก็คงไม่เป็นไรไปสักพักแล้วค่ะ
Dialogue: 0,0:37:12.21,0:37:14.79,Default,,0,0,0,,เธอ... เมื่อกี้ทำได้ยังไงน่ะ
Dialogue: 0,0:37:15.91,0:37:17.26,Default,,0,0,0,,เอ่อ คือว่า...
Dialogue: 0,0:37:17.26,0:37:20.60,Default,,0,0,0,,ฉันถนัดเรื่องเลียนเสียงน่ะค่ะ...
Dialogue: 0,0:37:20.60,0:37:22.56,Default,,0,0,0,,ดูเหมือนจะสลัดหลุดแล้วสินะ
Dialogue: 0,0:37:27.27,0:37:29.14,Default,,0,0,0,,แกเป็นใคร
Dialogue: 0,0:37:29.14,0:37:30.87,Default,,0,0,0,,วางใจเถอะ
Dialogue: 0,0:37:31.91,0:37:33.37,Default,,0,0,0,,พวกเราไม่ใช่ศัตรู
Dialogue: 0,0:37:34.47,0:37:37.53,Default,,0,0,0,,เอ่อ พวกเขาไม่เป็นไรหรอกค่ะ
Dialogue: 0,0:37:38.24,0:37:39.71,Default,,0,0,0,,คนรู้จักของเธอเหรอ
Dialogue: 0,0:37:39.71,0:37:40.50,Default,,0,0,0,,ค่ะ
Dialogue: 0,0:37:40.50,0:37:43.96,Default,,0,0,0,,พวกเราเป็นคนฝากจดหมายให้เด็กคนนั้นเอง
Dialogue: 0,0:37:43.96,0:37:45.39,Default,,0,0,0,,หมายความว่ายังไง
Dialogue: 0,0:37:45.39,0:37:47.96,Default,,0,0,0,,รู้เรื่องภรรยาของฉันด้วยเหรอ
Dialogue: 0,0:37:47.96,0:37:51.64,Default,,0,0,0,,พวกเรากำลังสืบหาที่มาของธนบัตรปลอมที่ระบาดในสาธารณรัฐอยู่
Dialogue: 0,0:37:51.64,0:37:53.57,Default,,0,0,0,,ก็เลยมาเจอนาย
Dialogue: 0,0:37:53.57,0:37:54.91,Default,,0,0,0,,ส่วนเรื่องภรรยาของนาย
Dialogue: 0,0:37:54.91,0:37:57.84,Default,,0,0,0,,รู้มาจากจดหมายที่ท่านประธานเก็บไว้ในตู้เซฟ
Dialogue: 0,0:37:58.61,0:37:59.97,Default,,0,0,0,,ถ้าเป็นพวกเราล่ะก็
Dialogue: 0,0:37:59.97,0:38:02.95,Default,,0,0,0,,สามารถพานายออกไปนอกกำแพงได้
Dialogue: 0,0:38:03.27,0:38:06.26,Default,,0,0,0,,แต่ก็ขึ้นอยู่กับว่านายมีความตั้งใจที่จะลี้ภัยหรือเปล่า
Dialogue: 0,0:38:06.26,0:38:08.27,Default,,0,0,0,,พวกแกเป็นใครกันแน่
Dialogue: 0,0:38:09.06,0:38:11.03,Default,,0,0,0,,พวกเราคือสปาย
Dialogue: 0,0:38:11.85,0:38:13.43,Default,,0,0,0,,ของสาธารณรัฐ
Dialogue: 0,0:38:15.68,0:38:18.28,Default,,0,0,0,,พวกคาคามาจิกิกำลังตามมา! ไปกันเถอะ!
Dialogue: 0,0:38:20.28,0:38:21.56,Default,,0,0,0,,คุณเทอร์เนอร์!
Dialogue: 0,0:38:21.56,0:38:25.32,Default,,0,0,0,,พวกเราจะทำให้คุณได้เจอภรรยาแน่นอนค่ะ!
Dialogue: 0,0:38:37.42,0:38:40.09,Default,,0,0,0,,เกรแฮม เทอร์เนอร์ยอมตกลงที่จะลี้ภัยแล้วค่ะ
Dialogue: 0,0:38:40.09,0:38:41.58,Default,,0,0,0,,จดหมายของภรรยาเขา
Dialogue: 0,0:38:41.58,0:38:43.51,Default,,0,0,0,,ได้ผลชะงัดเลยนะ
Dialogue: 0,0:38:43.51,0:38:45.03,Default,,0,0,0,,ว่าแต่เรื่องนี้
Dialogue: 0,0:38:45.03,0:38:47.20,Default,,0,0,0,,มันเป็นเรื่องที่มาจากไหนกันแน่
Dialogue: 0,0:38:47.20,0:38:50.31,Default,,0,0,0,,ไม่เข้าใจเหตุผลที่ต้องยึดติดกับผู้ชายคนนี้เลย
Dialogue: 0,0:38:50.31,0:38:50.93,Default,,0,0,0,,ไม่รู้สิ
Dialogue: 0,0:38:51.12,0:38:53.53,Default,,0,0,0,,เป็นเรื่องที่มาจากเบื้องบนค่ะ
Dialogue: 0,0:38:53.53,0:38:56.03,Default,,0,0,0,,รายงานสถานการณ์ให้เบื้องบนทราบ
Dialogue: 0,0:38:56.03,0:38:58.32,Default,,0,0,0,,ทันทีที่ประสานงานกับกองทัพเสร็จ
Dialogue: 0,0:38:58.32,0:39:00.32,Default,,0,0,0,,ก็จะเริ่มปฏิบัติการ
Dialogue: 0,0:39:00.50,0:39:01.88,Default,,0,0,0,,รับทราบค่ะ
Dialogue: 0,0:39:22.86,0:39:24.34,Default,,0,0,0,,ถึงแล้ว
Dialogue: 0,0:39:25.06,0:39:26.97,Default,,0,0,0,,จนกว่าจะได้รับการติดต่อจากสาธารณรัฐ
Dialogue: 0,0:39:26.97,0:39:28.35,Default,,0,0,0,,ก็ให้รออยู่ที่นี่
Dialogue: 0,0:39:28.53,0:39:30.35,Default,,0,0,0,,เพื่อความปลอดภัยของนาย
Dialogue: 0,0:39:30.56,0:39:32.35,Default,,0,0,0,,ห้ามออกไปข้างนอกเด็ดขาด
Dialogue: 0,0:39:32.35,0:39:34.35,Default,,0,0,0,,บอกเหตุผลมาที
Dialogue: 0,0:39:34.57,0:39:36.35,Default,,0,0,0,,ทำไมถึงช่วยฉัน
Dialogue: 0,0:39:38.53,0:39:41.33,Default,,0,0,0,,เพราะว่านายคือนักปลอมแปลงในตำนาน
Dialogue: 0,0:39:42.36,0:39:43.99,Default,,0,0,0,,เดี๋ยวสิคะ คุณแองเจ!
Dialogue: 0,0:39:43.99,0:39:45.66,Default,,0,0,0,,ฉันไม่ได้โกหก
Dialogue: 0,0:39:46.05,0:39:49.54,Default,,0,0,0,,ฝ่ายเราก็ได้ตัวนักปลอมแปลงที่สร้างปัญหาให้สาธารณรัฐ
Dialogue: 0,0:39:49.54,0:39:51.88,Default,,0,0,0,,ส่วนเขาเองก็ได้เจอภรรยา
Dialogue: 0,0:39:52.37,0:39:54.11,Default,,0,0,0,,ไม่ใช่เรื่องที่แย่เลยใช่ไหมล่ะ
Dialogue: 0,0:39:56.37,0:39:57.90,Default,,0,0,0,,นั่นสินะ
Dialogue: 0,0:40:03.05,0:40:04.79,Default,,0,0,0,,ของที่อยู่ในห้องนี้
Dialogue: 0,0:40:04.79,0:40:06.74,Default,,0,0,0,,ใช้ได้ตามสบายเลยนะคะ
Dialogue: 0,0:40:06.74,0:40:09.18,Default,,0,0,0,,พรุ่งนี้เราจะข้ามกำแพงกันแล้ว
Dialogue: 0,0:40:09.18,0:40:11.80,Default,,0,0,0,,วันนี้ก็พักผ่อนให้เต็มที่นะคะ
Dialogue: 0,0:40:11.80,0:40:13.05,Default,,0,0,0,,เบียงก้า
Dialogue: 0,0:40:14.00,0:40:16.39,Default,,0,0,0,,เธอก็เป็นสปายด้วยเหรอ
Dialogue: 0,0:40:17.56,0:40:18.88,Default,,0,0,0,,ค่ะ
Dialogue: 0,0:40:18.88,0:40:20.40,Default,,0,0,0,,ก็ประมาณนั้นค่ะ
Dialogue: 0,0:40:21.31,0:40:23.75,Default,,0,0,0,,ที่เธอเลียนเสียงฉันเมื่อตอนกลางวัน
Dialogue: 0,0:40:23.75,0:40:25.54,Default,,0,0,0,,ก็เป็นฝีมือของสปายสินะ
Dialogue: 0,0:40:26.64,0:40:29.04,Default,,0,0,0,,เปล่าค่ะ อันนั้นน่ะ
Dialogue: 0,0:40:29.04,0:40:31.37,Default,,0,0,0,,ฉันเปลี่ยนเสียงด้วยเจ้านี่ค่ะ
Dialogue: 0,0:40:33.00,0:40:35.49,Default,,0,0,0,,เฮ้ย ฉันอยู่นี่!
Dialogue: 0,0:40:35.49,0:40:38.95,Default,,0,0,0,,จนกว่าจะถึงเวลาเลิกงานก็ไปหาหนังสือแถว ๆ นั้นอ่านซะ
Dialogue: 0,0:40:39.98,0:40:41.98,Default,,0,0,0,,ก็ประมาณนี้แหละค่ะ
Dialogue: 0,0:40:41.98,0:40:44.68,Default,,0,0,0,,ฝังเครื่องจักรไว้ในคอเหรอ
Dialogue: 0,0:40:44.68,0:40:45.92,Default,,0,0,0,,ค่ะ
Dialogue: 0,0:40:45.92,0:40:47.86,Default,,0,0,0,,ตอนที่ฉันยังเด็ก
Dialogue: 0,0:40:47.86,0:40:49.90,Default,,0,0,0,,พ่อเป็นคนติดให้ค่ะ
Dialogue: 0,0:40:50.66,0:40:54.80,Default,,0,0,0,,พ่อของฉันเป็นคนที่คลั่งไคล้เครื่องจักร\Nจนมีชื่อเสียงในราชอาณาจักรค่ะ
Dialogue: 0,0:40:55.19,0:40:57.27,Default,,0,0,0,,พอคิดอะไรขึ้นมาได้
Dialogue: 0,0:40:57.27,0:40:59.89,Default,,0,0,0,,ก็จะเป็นคนที่ไม่เลือกวิธีการน่ะค่ะ
Dialogue: 0,0:41:00.44,0:41:01.43,Default,,0,0,0,,ขอโทษด้วย
Dialogue: 0,0:41:01.43,0:41:03.35,Default,,0,0,0,,ที่ถามเรื่องไม่ดีไปซะได้
Dialogue: 0,0:41:03.35,0:41:04.44,Default,,0,0,0,,ไม่เป็นไรค่ะ
Dialogue: 0,0:41:04.67,0:41:05.46,Default,,0,0,0,,แต่ว่า
Dialogue: 0,0:41:05.46,0:41:08.45,Default,,0,0,0,,ถ้าไม่มีสิ่งนั้นก็คงไม่มีฉันในตอนนี้
Dialogue: 0,0:41:08.45,0:41:10.45,Default,,0,0,0,,ก็เลยไม่ได้ใส่ใจอะไรเป็นพิเศษค่ะ
Dialogue: 0,0:41:10.45,0:41:12.05,Default,,0,0,0,,งั้นเหรอ
Dialogue: 0,0:41:13.92,0:41:15.02,Default,,0,0,0,,แล้วก็
Dialogue: 0,0:41:15.02,0:41:18.96,Default,,0,0,0,,ชื่อจริงของฉันคือเบียทริซค่ะ
Dialogue: 0,0:41:18.96,0:41:20.01,Default,,0,0,0,,ขอโทษนะคะ
Dialogue: 0,0:41:20.01,0:41:22.46,Default,,0,0,0,,เบียงก้าเป็นชื่อปลอมค่ะ
Dialogue: 0,0:41:22.82,0:41:24.46,Default,,0,0,0,,จะจำไว้
Dialogue: 0,0:41:25.21,0:41:28.47,Default,,0,0,0,,งั้นถ้าอาหารเสร็จแล้วจะมาเรียกอีกทีนะคะ
Dialogue: 0,0:41:30.64,0:41:32.10,Default,,0,0,0,,เบียทริซ
Dialogue: 0,0:41:33.52,0:41:34.98,Default,,0,0,0,,ขอบใจนะ
Dialogue: 0,0:41:34.98,0:41:37.32,Default,,0,0,0,,ที่บอกเรื่องภรรยาให้ฉันรู้
Dialogue: 0,0:41:37.79,0:41:41.21,Default,,0,0,0,,ฉันแค่รับจดหมายมาเท่านั้นเองค่ะ
Dialogue: 0,0:41:59.94,0:42:02.50,Default,,0,0,0,,นึกว่ามาถึงสาธารณรัฐแล้ว
Dialogue: 0,0:42:02.50,0:42:05.22,Default,,0,0,0,,คราวนี้ต้องกลับราชอาณาจักรอีกแล้วเหรอ
Dialogue: 0,0:42:05.22,0:42:07.37,Default,,0,0,0,,แล้วลูกน้องของฉันจะเป็นยังไง
Dialogue: 0,0:42:08.51,0:42:10.79,Default,,0,0,0,,ลูกน้องของนายก็จะตามไปเร็ว ๆ นี้
Dialogue: 0,0:42:10.79,0:42:12.49,Default,,0,0,0,,รีบขึ้นรถซะ
Dialogue: 0,0:42:20.26,0:42:22.84,Default,,0,0,0,,จอห์นสัน คาร์เตอร์ถูกฆ่าแล้ว
Dialogue: 0,0:42:22.84,0:42:26.19,Default,,0,0,0,,มีรายงานว่าถูกลอบยิงระหว่างปฏิบัติการย้ายตัว
Dialogue: 0,0:42:26.19,0:42:27.37,Default,,0,0,0,,เป็นไปได้ยังไงกัน!
Dialogue: 0,0:42:27.37,0:42:29.89,Default,,0,0,0,,เป็นฝีมือของสปายราชอาณาจักรหรือเปล่านะ
Dialogue: 0,0:42:29.89,0:42:33.44,Default,,0,0,0,,ทั้งที่ตกลงกันแล้ว ไม่มีเหตุผลที่จะต้องฆ่าเลยค่ะ
Dialogue: 0,0:42:33.44,0:42:37.62,Default,,0,0,0,,ถ้าอย่างนั้นก็ต้องเป็นใครสักคนในราชอาณาจักรที่ไม่พอใจข้อตกลงสิ
Dialogue: 0,0:42:37.62,0:42:41.14,Default,,0,0,0,,คนที่คัดค้านการย้ายตัวคาร์เตอร์มากที่สุดคือกองทัพค่ะ
Dialogue: 0,0:42:41.14,0:42:44.29,Default,,0,0,0,,เรื่องนี้ควรสงสัยว่าเป็นการกระทำของคนในค่ะ
Dialogue: 0,0:42:44.29,0:42:46.54,Default,,0,0,0,,โดยมีเงื่อนไขเป็นการแลกเปลี่ยนตัวประกัน
Dialogue: 0,0:42:46.54,0:42:48.55,Default,,0,0,0,,เราได้ข้อมูลของนักปลอมแปลงมาแล้วแท้ ๆ
Dialogue: 0,0:42:48.70,0:42:52.55,Default,,0,0,0,,แบบนี้จะไม่ถูกมองว่าเราผิดสัญญาเหรอ
Dialogue: 0,0:42:52.55,0:42:55.24,Default,,0,0,0,,นักปลอมแปลงคนนั้นก็ยังน่าสงสัยอยู่ว่าจะเป็นตัวจริงหรือเปล่า
Dialogue: 0,0:42:55.24,0:42:57.06,Default,,0,0,0,,จะเป็นอะไรไป!
Dialogue: 0,0:42:57.54,0:42:59.89,Default,,0,0,0,,ทำกันได้นะ
Dialogue: 0,0:43:00.56,0:43:03.71,Default,,0,0,0,,ได้ยินว่าถูกยิงระหว่างที่กองทัพกำลังคุ้มกันอยู่ค่ะ
Dialogue: 0,0:43:05.05,0:43:07.38,Default,,0,0,0,,พลาดโอกาสไปซะแล้ว
Dialogue: 0,0:43:07.38,0:43:10.11,Default,,0,0,0,,จะทำยังไงกับเกรแฮม เทอร์เนอร์ดีคะ
Dialogue: 0,0:43:10.11,0:43:12.93,Default,,0,0,0,,ไม่มีเหตุผลที่จะต้องยกให้แล้ว
Dialogue: 0,0:43:12.93,0:43:15.82,Default,,0,0,0,,ไปบอกให้กำจัดผู้ชายคนนั้นซะ
Dialogue: 0,0:43:15.82,0:43:16.87,Default,,0,0,0,,ค่ะ!
Dialogue: 0,0:43:21.02,0:43:23.31,Default,,0,0,0,,ทำหน้าไม่สบายใจเลยนะ
Dialogue: 0,0:43:23.31,0:43:26.31,Default,,0,0,0,,เป็นห่วงเรื่องการกำจัดผู้ชายคนนั้นเหรอ
Dialogue: 0,0:43:26.31,0:43:28.59,Default,,0,0,0,,หรือว่าเป็นห่วงเพื่อนของเธอ
Dialogue: 0,0:43:29.10,0:43:32.37,Default,,0,0,0,,ไม่ว่าจะทางไหนก็ห้ามเข้าข้างเด็ดขาด
Dialogue: 0,0:43:32.89,0:43:37.74,Default,,0,0,0,,ถ้ามัวแต่คิดถึงเรื่องของคนอื่นก็จะลืมตัวตนของตัวเองไป
Dialogue: 0,0:43:37.74,0:43:42.19,Default,,0,0,0,,พวกเราควรจะสร้างประเทศเพื่อความสุขของผู้คนค่ะ
Dialogue: 0,0:43:42.60,0:43:46.20,Default,,0,0,0,,ฉันไม่เคยเสียใจกับการกระทำของตัวเองค่ะ
Dialogue: 0,0:43:50.62,0:43:53.70,Default,,0,0,0,,ดูเหมือนฉันกับเธอจะเข้ากันไม่ได้จริง ๆ
Dialogue: 0,0:43:54.24,0:43:55.49,Default,,0,0,0,,ชาร์ล็อตต์
Dialogue: 0,0:43:55.90,0:43:58.62,Default,,0,0,0,,คำว่าผู้คนน่ะ หมายถึงใครบ้าง
Dialogue: 0,0:43:58.62,0:44:00.90,Default,,0,0,0,,แล้วความสุขคืออะไร
Dialogue: 0,0:44:01.33,0:44:06.29,Default,,0,0,0,,ถ้าเพื่อสิ่งนั้นแล้วต้องสละบางสิ่งบางอย่างไปล่ะก็ เธอน่ะ
Dialogue: 0,0:44:06.29,0:44:08.95,Default,,0,0,0,,จะยอมสละได้ถึงขนาดไหนกัน
Dialogue: 0,0:44:26.64,0:44:27.61,Default,,0,0,0,,คนไล่ตามเหรอ
Dialogue: 0,0:44:27.61,0:44:29.93,Default,,0,0,0,,ไม่สิ ท่าทางแปลก ๆ
Dialogue: 0,0:44:31.32,0:44:32.44,Default,,0,0,0,,กาเซล!
Dialogue: 0,0:44:33.41,0:44:34.65,Default,,0,0,0,,ไม่ได้อยู่ในแผน
Dialogue: 0,0:44:34.65,0:44:36.65,Default,,0,0,0,,จะไปฟังเรื่องราวดู
Dialogue: 0,0:44:37.14,0:44:40.37,Default,,0,0,0,,คุณโดโรธี หมายความว่าไงคะ
Dialogue: 0,0:44:48.11,0:44:49.66,Default,,0,0,0,,ตกใจหมดเลย
Dialogue: 0,0:44:49.66,0:44:52.29,Default,,0,0,0,,ไม่นึกว่าท่านสารวัตรจะอุตส่าห์มาตรวจการณ์ด้วยตัวเอง
Dialogue: 0,0:44:52.29,0:44:54.26,Default,,0,0,0,,แผนเปลี่ยนไปแล้ว
Dialogue: 0,0:44:54.26,0:44:55.90,Default,,0,0,0,,ยกเลิกการต่อรอง
Dialogue: 0,0:44:58.94,0:45:01.28,Default,,0,0,0,,หมายความว่ายังไง
Dialogue: 0,0:45:01.28,0:45:03.87,Default,,0,0,0,,มีคำสั่งให้ลี้ภัยมาจากสาธารณรัฐ
Dialogue: 0,0:45:03.87,0:45:05.87,Default,,0,0,0,,ก็เป็นการต่อรองที่พวกเธอตัดสินใจเองไม่ใช่เหรอ!
Dialogue: 0,0:45:05.87,0:45:06.68,Default,,0,0,0,,ใช่แล้ว
Dialogue: 0,0:45:06.68,0:45:11.10,Default,,0,0,0,,แต่ว่าผู้ต้องสงสัยถูกลอบสังหารระหว่างการคุ้มกันในสาธารณรัฐ
Dialogue: 0,0:45:11.85,0:45:13.92,Default,,0,0,0,,ในเมื่อการต่อรองไม่สำเร็จ
Dialogue: 0,0:45:13.92,0:45:16.98,Default,,0,0,0,,ทางนี้ก็ไม่คิดจะยกให้เปล่า ๆ เหมือนกัน
Dialogue: 0,0:45:16.98,0:45:19.58,Default,,0,0,0,,ฆ่าเกรแฮม เทอร์เนอร์ซะ
Dialogue: 0,0:45:23.84,0:45:27.92,Default,,0,0,0,,ถ้าต่อรองไม่ได้ก็แค่ยกเลิกการลี้ภัยก็สิ้นเรื่องแล้วนี่!
Dialogue: 0,0:45:27.92,0:45:29.91,Default,,0,0,0,,ตราบใดที่คุณเทอร์เนอร์ยังมีชีวิตอยู่
Dialogue: 0,0:45:29.91,0:45:33.12,Default,,0,0,0,,พวกเราก็ต้องระวังการลักพาตัว
Dialogue: 0,0:45:33.12,0:45:36.71,Default,,0,0,0,,ตั้งแต่ตอนที่สาธารณรัฐรู้เรื่องของคุณเทอร์เนอร์
Dialogue: 0,0:45:36.71,0:45:38.19,Default,,0,0,0,,ชะตากรรมของเขา
Dialogue: 0,0:45:38.19,0:45:41.16,Default,,0,0,0,,ไม่ว่าจะกลายเป็นเครื่องสังเวย\Nเพื่อผลประโยชน์ของราชอาณาจักร
Dialogue: 0,0:45:41.16,0:45:43.48,Default,,0,0,0,,หรือว่าจะถูกกำจัดทิ้งไปทั้งหมด
Dialogue: 0,0:45:43.48,0:45:45.26,Default,,0,0,0,,ก็มีอยู่แค่สองทางเท่านั้น
Dialogue: 0,0:45:45.26,0:45:48.73,Default,,0,0,0,,อย่ามาล้อเล่นนะ! คิดว่าชีวิตคนเป็นอะไรกันแน่!
Dialogue: 0,0:45:49.45,0:45:53.29,Default,,0,0,0,,พวกเธอก็เคยฆ่าคนอื่นเพื่อ\Nความสะดวกของตัวเองเหมือนกันไม่ใช่เหรอ
Dialogue: 0,0:45:53.29,0:45:55.65,Default,,0,0,0,,คำถามนั้นมีความหมายอะไรเหรอ
Dialogue: 0,0:45:58.45,0:46:03.02,Default,,0,0,0,,อีก 10 นาทีจากนี้ คนที่ไล่ตามเทอร์เนอร์จะมาบุกที่นี่
Dialogue: 0,0:46:03.02,0:46:08.06,Default,,0,0,0,,ก็บอกสาธารณรัฐไปสิว่าภารกิจล้มเหลวแล้วเทอร์เนอร์ถูกฆ่า
Dialogue: 0,0:46:08.06,0:46:11.36,Default,,0,0,0,,เพื่อไม่ให้ถูกสงสัยก็จะคืนเครื่องมือทำงานให้ด้วย
Dialogue: 0,0:46:11.36,0:46:14.01,Default,,0,0,0,,ถ้าจำเป็นก็จะช่วยเตี๊ยมให้ด้วย
Dialogue: 0,0:46:15.14,0:46:16.75,Default,,0,0,0,,ถ้าภารกิจล้มเหลว
Dialogue: 0,0:46:16.75,0:46:19.49,Default,,0,0,0,,พวกเราก็จะกำจัดพรินเซสด้วย
Dialogue: 0,0:46:19.49,0:46:22.39,Default,,0,0,0,,ถ้าผู้ชายคนนั้นสำคัญกว่าพรินเซส
Dialogue: 0,0:46:22.39,0:46:24.15,Default,,0,0,0,,จะทำตามใจก็ได้นะ
Dialogue: 0,0:46:29.58,0:46:31.23,Default,,0,0,0,,คุณโดโรธี
Dialogue: 0,0:46:31.23,0:46:33.38,Default,,0,0,0,,จะทำยังไงดีคะ
Dialogue: 0,0:46:33.38,0:46:36.77,Default,,0,0,0,,ยังไม่มีการติดต่อเรื่องยกเลิกแผนการจากคอนโทรล
Dialogue: 0,0:46:36.77,0:46:37.63,Default,,0,0,0,,ถ้างั้นก็...
Dialogue: 0,0:46:37.89,0:46:38.55,Default,,0,0,0,,ไม่ได้
Dialogue: 0,0:46:39.67,0:46:42.54,Default,,0,0,0,,ดยุกนอร์มังดีกุมชะตาของพรินเซสเอาไว้
Dialogue: 0,0:46:42.96,0:46:44.79,Default,,0,0,0,,ควรจะยกเลิกการลี้ภัย
Dialogue: 0,0:46:44.79,0:46:46.06,Default,,0,0,0,,ในภารกิจนี้
Dialogue: 0,0:46:46.06,0:46:49.51,Default,,0,0,0,,คอนโทรลกำลังดูอยู่ว่าพวกเราเป็นสปายสองหน้าหรือเปล่านะ!
Dialogue: 0,0:46:49.51,0:46:51.38,Default,,0,0,0,,เรื่องนั้นฉันรู้แล้ว
Dialogue: 0,0:46:51.38,0:46:54.79,Default,,0,0,0,,ทั้งที่ดยุกนอร์มังดีรู้ข้อมูลเรื่องการยกเลิกข้อตกลงแล้ว
Dialogue: 0,0:46:54.79,0:46:58.80,Default,,0,0,0,,แต่กลับไม่มีการติดต่อมาทางนี้ \Nก็มีความเป็นไปได้ว่าเรากำลังถูกหยั่งเชิงอยู่
Dialogue: 0,0:46:58.80,0:47:00.80,Default,,0,0,0,,ถ้ายกเลิกการลี้ภัยโดยพลการ
Dialogue: 0,0:47:00.80,0:47:02.55,Default,,0,0,0,,จะถูกมองว่าทรยศนะ!
Dialogue: 0,0:47:02.55,0:47:04.80,Default,,0,0,0,,ก็แค่ความเป็นไปได้
Dialogue: 0,0:47:04.80,0:47:06.00,Default,,0,0,0,,ก็อย่างที่กาเซลบอก
Dialogue: 0,0:47:06.00,0:47:08.15,Default,,0,0,0,,ก็แค่ทำเป็นว่าล้มเหลวก็พอ
Dialogue: 0,0:47:13.46,0:47:14.81,Default,,0,0,0,,เข้าใจแล้ว
Dialogue: 0,0:47:15.34,0:47:18.21,Default,,0,0,0,,ตอนนี้ก็ทำตามแผนไปก่อน
Dialogue: 0,0:47:18.21,0:47:21.55,Default,,0,0,0,,ถ้าไปไม่ทันเวลานัดรวมพลกับทีมที่กำแพง
Dialogue: 0,0:47:21.55,0:47:25.10,Default,,0,0,0,,ทางเลือกที่จะลี้ภัยในยามฉุกเฉินก็จะหายไป
Dialogue: 0,0:47:25.75,0:47:28.14,Default,,0,0,0,,การตัดสินใจสุดท้ายฉันจะเป็นคนทำเอง
Dialogue: 0,0:47:28.14,0:47:29.10,Default,,0,0,0,,เข้าใจนะ
Dialogue: 0,0:47:34.61,0:47:36.52,Default,,0,0,0,,กระท่อมหลังนั้นแหละ
Dialogue: 0,0:47:48.18,0:47:50.85,Default,,0,0,0,,อยู่นั่นไง! เทอร์เนอร์! ตามไป!
Dialogue: 0,0:47:59.23,0:48:00.56,Default,,0,0,0,,ตามมาแล้ว!
Dialogue: 0,0:48:00.56,0:48:01.94,Default,,0,0,0,,คุณเทอร์เนอร์!
Dialogue: 0,0:48:01.94,0:48:03.86,Default,,0,0,0,,พวกเราจะปกป้องคุณเอง!
Dialogue: 0,0:48:03.86,0:48:06.09,Default,,0,0,0,,เราจะข้ามกำแพงไปให้ได้!
Dialogue: 0,0:48:09.33,0:48:10.55,Default,,0,0,0,,เฮ้ย! ยิงมัน!
Dialogue: 0,0:48:19.98,0:48:21.57,Default,,0,0,0,,หนีไม่รอดหรอก!
Dialogue: 0,0:48:25.22,0:48:27.68,Default,,0,0,0,,บ้าเอ๊ย! ถึงกับพกอาวุธมายิงด้วยเลยเหรอ
Dialogue: 0,0:48:27.68,0:48:28.89,Default,,0,0,0,,หายไปคันหนึ่ง
Dialogue: 0,0:48:28.89,0:48:29.99,Default,,0,0,0,,อะไรนะ!?
Dialogue: 0,0:48:33.06,0:48:34.43,Default,,0,0,0,,เทอร์เนอร์!
Dialogue: 0,0:48:34.89,0:48:36.64,Default,,0,0,0,,ไม่นะ
Dialogue: 0,0:48:37.19,0:48:38.59,Default,,0,0,0,,ยัยบ้าหลบเร็ว!
Dialogue: 0,0:48:45.30,0:48:46.90,Default,,0,0,0,,จัดการไปได้หนึ่งคัน
Dialogue: 0,0:48:56.91,0:48:58.10,Default,,0,0,0,,เรียบร้อย
Dialogue: 0,0:48:58.10,0:48:59.40,Default,,0,0,0,,ทุกคนปลอดภัยไหม
Dialogue: 0,0:48:59.40,0:49:00.60,Default,,0,0,0,,ค-ค่ะ!
Dialogue: 0,0:49:00.60,0:49:02.28,Default,,0,0,0,,ทำไมถึงปกป้องฉัน
Dialogue: 0,0:49:02.28,0:49:04.32,Default,,0,0,0,,อย่าทิ้งชีวิตตัวเองสิ!
Dialogue: 0,0:49:06.49,0:49:08.93,Default,,0,0,0,,คุณเทอร์เนอร์ บาดแผลนั่น...
Dialogue: 0,0:49:09.77,0:49:12.63,Default,,0,0,0,,คุณโดโรธี! คุณเทอร์เนอร์เขา!
Dialogue: 0,0:49:31.16,0:49:32.95,Default,,0,0,0,,ขอดูแผลหน่อย
Dialogue: 0,0:49:48.50,0:49:52.60,Default,,0,0,0,,ถ้าไม่รีบรักษา เลือดจะออกเยอะกว่านี้อีกนะ
Dialogue: 0,0:49:57.64,0:49:58.98,Default,,0,0,0,,โดโรธี ถอยไป
Dialogue: 0,0:49:58.98,0:49:59.70,Default,,0,0,0,,เฮ้ย!
Dialogue: 0,0:50:03.57,0:50:04.46,Default,,0,0,0,,คุณแองเจ
Dialogue: 0,0:50:04.46,0:50:05.99,Default,,0,0,0,,ทำบ้าอะไรของเธอน่ะแองเจ!
Dialogue: 0,0:50:06.98,0:50:08.47,Default,,0,0,0,,ปล่อยมือ
Dialogue: 0,0:50:08.47,0:50:10.42,Default,,0,0,0,,ฉันจะฆ่าเทอร์เนอร์
Dialogue: 0,0:50:10.42,0:50:12.99,Default,,0,0,0,,พูดเรื่องตลกให้มันดีกว่านี้หน่อยไม่ได้เหรอ
Dialogue: 0,0:50:12.99,0:50:15.45,Default,,0,0,0,,ไม่ใช่เรื่องตลกแล้วก็ไม่ได้โกหก
Dialogue: 0,0:50:15.45,0:50:19.55,Default,,0,0,0,,ชีวิตของพรินเซสอยู่ในกำมือของดยุกนอร์มังดี
Dialogue: 0,0:50:19.55,0:50:22.27,Default,,0,0,0,,เราส่งตัวคุณเทอร์เนอร์ให้สาธารณรัฐไม่ได้
Dialogue: 0,0:50:22.27,0:50:24.24,Default,,0,0,0,,เธอพูดจริงเหรอ
Dialogue: 0,0:50:24.24,0:50:25.88,Default,,0,0,0,,แล้วจะทำไม
Dialogue: 0,0:50:28.29,0:50:29.44,Default,,0,0,0,,คุณแองเจ!
Dialogue: 0,0:50:29.44,0:50:34.33,Default,,0,0,0,,องค์หญิงยอมเสี่ยงชีวิตเพื่อช่วยคนที่ถูกกำแพงพรากจากกันไปนะคะ!
Dialogue: 0,0:50:34.33,0:50:36.18,Default,,0,0,0,,ถ้าทำแบบนี้องค์หญิงก็...
Dialogue: 0,0:50:36.18,0:50:37.92,Default,,0,0,0,,อย่ามาทำเป็นรู้ดีหน่อยเลย!
Dialogue: 0,0:50:39.20,0:50:41.33,Default,,0,0,0,,ถ้าพรินเซสไม่อยากมือเปื้อนเลือดล่ะก็
Dialogue: 0,0:50:41.33,0:50:43.55,Default,,0,0,0,,ฉันจะเป็นคนทำให้มือเปื้อนเอง
Dialogue: 0,0:50:43.55,0:50:46.41,Default,,0,0,0,,ถ้าไม่มีความตั้งใจขนาดนั้นก็อย่ามายุ่ง
Dialogue: 0,0:50:50.33,0:50:51.68,Default,,0,0,0,,พอได้แล้ว
Dialogue: 0,0:50:55.20,0:50:56.45,Default,,0,0,0,,ที่เซฟเฮาส์
Dialogue: 0,0:50:56.45,0:51:01.04,Default,,0,0,0,,ฉันได้ยินผู้หญิงใส่แว่นคนนั้นบอกให้ฆ่าฉัน
Dialogue: 0,0:51:01.68,0:51:03.04,Default,,0,0,0,,พอมาคิดดูแล้ว
Dialogue: 0,0:51:03.27,0:51:05.97,Default,,0,0,0,,มันเป็นเรื่องที่ดีเกินจริง
Dialogue: 0,0:51:07.99,0:51:11.42,Default,,0,0,0,,ได้ยินถึงขนาดนั้นแล้วทำไมถึงไม่หนีไปล่ะ
Dialogue: 0,0:51:21.31,0:51:23.06,Default,,0,0,0,,ไม่ว่าจะยังไงก็ตาม
Dialogue: 0,0:51:23.06,0:51:25.06,Default,,0,0,0,,ฉันก็อยากจะเจอภรรยา
Dialogue: 0,0:51:29.07,0:51:30.21,Default,,0,0,0,,แล้วอีกอย่าง
Dialogue: 0,0:51:30.21,0:51:31.63,Default,,0,0,0,,ถึงจะหนีไปได้
Dialogue: 0,0:51:31.63,0:51:35.07,Default,,0,0,0,,ก็คิดวิธีอื่นที่จะข้ามกำแพงไปไม่ได้แล้ว
Dialogue: 0,0:51:43.25,0:51:45.08,Default,,0,0,0,,ถ้าไม่ฆ่าฉัน
Dialogue: 0,0:51:45.08,0:51:46.80,Default,,0,0,0,,ก็จะมีคนต้องตาย
Dialogue: 0,0:51:48.82,0:51:51.09,Default,,0,0,0,,เทอร์เนอร์ จะทำอะไรน่ะ
Dialogue: 0,0:51:53.43,0:51:54.84,Default,,0,0,0,,ถ้าอย่างนั้น
Dialogue: 0,0:51:57.77,0:51:59.31,Default,,0,0,0,,หยุดนะ เทอร์เนอร์
Dialogue: 0,0:52:01.82,0:52:03.10,Default,,0,0,0,,คุณเทอร์เนอร์
Dialogue: 0,0:52:04.44,0:52:07.55,Default,,0,0,0,,ทำบ้าอะไรน่ะ! ปล่อยมีดซะ!
Dialogue: 0,0:52:15.52,0:52:19.12,Default,,0,0,0,,เท่านี้ตัวฉันในฐานะช่างแกะสลักก็ตายไปแล้ว
Dialogue: 0,0:52:20.13,0:52:21.53,Default,,0,0,0,,พวกเธอ
Dialogue: 0,0:52:21.53,0:52:25.50,Default,,0,0,0,,จงตัดแขนขวาข้างนี้แล้วเอากลับไปซะ
Dialogue: 0,0:52:25.50,0:52:26.73,Default,,0,0,0,,ทำแบบนั้น!
Dialogue: 0,0:52:26.73,0:52:30.50,Default,,0,0,0,,ถ้าทำแบบนี้พวกเธอก็จะรักษาหน้าไว้ได้
Dialogue: 0,0:52:30.90,0:52:33.38,Default,,0,0,0,,และฉันก็จะได้ไปเจอภรรยา
Dialogue: 0,0:52:38.75,0:52:40.05,Default,,0,0,0,,ขอโทษนะ แต่ว่า
Dialogue: 0,0:52:40.05,0:52:41.54,Default,,0,0,0,,ช่วยฉันที
Dialogue: 0,0:52:41.54,0:52:44.53,Default,,0,0,0,,ฉันคงตัดเองไม่ไหว
Dialogue: 0,0:52:45.14,0:52:46.89,Default,,0,0,0,,ฉันจะทำให้เอง
Dialogue: 0,0:53:03.38,0:53:05.16,Default,,0,0,0,,แน่ใจแล้วนะ
Dialogue: 0,0:53:06.95,0:53:08.27,Default,,0,0,0,,ทำเถอะ
Dialogue: 0,0:53:17.90,0:53:19.73,Default,,0,0,0,,งั้นฉันเอาล่ะนะ
Dialogue: 0,0:53:37.42,0:53:39.47,Default,,0,0,0,,นี่มันอะไรกัน
Dialogue: 0,0:53:39.47,0:53:41.45,Default,,0,0,0,,เกรแฮม เทอร์เนอร์ค่ะ
Dialogue: 0,0:53:42.02,0:53:43.81,Default,,0,0,0,,เขาที่เป็นช่างแกะสลัก
Dialogue: 0,0:53:43.81,0:53:45.20,Default,,0,0,0,,ไม่อยู่แล้วค่ะ
Dialogue: 0,0:53:48.54,0:53:50.96,Default,,0,0,0,,แสดงความเมตตางั้นเหรอ
Dialogue: 0,0:53:50.96,0:53:52.82,Default,,0,0,0,,ไม่ถูกใจเลยนะ
Dialogue: 0,0:53:56.05,0:53:57.99,Default,,0,0,0,,รายงานของคุณเทอร์เนอร์ค่ะ
Dialogue: 0,0:53:58.83,0:54:01.97,Default,,0,0,0,,ได้ยินว่าการผ่าตัดแขนขวาของเขาเสร็จสิ้นเรียบร้อยดีค่ะ
Dialogue: 0,0:54:01.97,0:54:03.65,Default,,0,0,0,,หลังจากนี้จะรอให้เขาฟื้นตัว
Dialogue: 0,0:54:03.65,0:54:06.68,Default,,0,0,0,,แล้วมีกำหนดการจะพาไปพบกับภรรยาของคุณเทอร์เนอร์ค่ะ
Dialogue: 0,0:54:07.91,0:54:09.59,Default,,0,0,0,,แล้วเธอเรื่องคราวนี้
Dialogue: 0,0:54:09.59,0:54:11.21,Default,,0,0,0,,มองว่ายังไง
Dialogue: 0,0:54:11.55,0:54:14.18,Default,,0,0,0,,ถึงการต่อรองจะล้มเหลว
Dialogue: 0,0:54:14.18,0:54:17.23,Default,,0,0,0,,แต่ก็จบลงด้วยผลลัพธ์ที่ไม่ทำร้ายทั้งสองฝ่ายค่ะ
Dialogue: 0,0:54:17.44,0:54:19.72,Default,,0,0,0,,มันลงล็อกเกินไป
Dialogue: 0,0:54:21.24,0:54:23.68,Default,,0,0,0,,เรื่องการลอบสังหารจอห์นสัน คาร์เตอร์
Dialogue: 0,0:54:23.68,0:54:28.38,Default,,0,0,0,,ฉันปล่อยข่าวผ่านหนอนบ่อนไส้ในกองทัพให้ไปถึงราชอาณาจักรแล้ว
Dialogue: 0,0:54:28.38,0:54:31.82,Default,,0,0,0,,แต่ไม่ได้บอกทีมของพรินซิเพิล
Dialogue: 0,0:54:31.82,0:54:36.98,Default,,0,0,0,,งั้นก็หมายความว่าพรินซิเพิล\Nเป็นคนจัดการให้จบลงด้วยดีสำหรับทั้งสองฝ่ายเหรอคะ
Dialogue: 0,0:54:36.98,0:54:38.25,Default,,0,0,0,,อย่างน้อยก็
Dialogue: 0,0:54:38.25,0:54:42.85,Default,,0,0,0,,มีหลักฐานเพียงพอที่จะสืบหาความจริงแล้ว
Dialogue: 0,0:54:44.24,0:54:47.66,Default,,0,0,0,,ตอนนั้นฉันควรจะทำยังไงดีคะ
Dialogue: 0,0:54:48.04,0:54:49.73,Default,,0,0,0,,ในฐานะคนคนหนึ่งเหรอ
Dialogue: 0,0:54:49.73,0:54:51.59,Default,,0,0,0,,หรือว่าในฐานะสปาย
Dialogue: 0,0:54:51.59,0:54:53.27,Default,,0,0,0,,เอ่อ นั่นมัน...
Dialogue: 0,0:54:53.88,0:54:55.27,Default,,0,0,0,,ครั้งนี้พูดตามตรงนะ
Dialogue: 0,0:54:55.51,0:54:58.13,Default,,0,0,0,,การตัดสินใจของคุณเทอร์เนอร์ช่วยไว้แท้ ๆ
Dialogue: 0,0:54:58.13,0:55:01.64,Default,,0,0,0,,ในใจของเธอก็คิดว่าควรจะฆ่าเขาเหมือนกันเหรอ
Dialogue: 0,0:55:03.02,0:55:06.95,Default,,0,0,0,,สิ่งที่ปรารถนาใช่ว่าจะได้มาในรูปแบบที่ปรารถนาเสมอไป
Dialogue: 0,0:55:08.97,0:55:09.94,Default,,0,0,0,,บิชอป
Dialogue: 0,0:55:10.50,0:55:11.29,Default,,0,0,0,,ไม่สิ
Dialogue: 0,0:55:11.45,0:55:13.68,Default,,0,0,0,,ในวันที่วินสตันถูกฆ่า
Dialogue: 0,0:55:13.68,0:55:15.29,Default,,0,0,0,,เป็นคำพูดที่เขาพูดกับฉัน
Dialogue: 0,0:55:16.24,0:55:18.82,Default,,0,0,0,,ตราบใดที่ยังเป็นสปายสองหน้าต่อไป
Dialogue: 0,0:55:18.82,0:55:21.73,Default,,0,0,0,,สักวันหนึ่งจะต้องถูกบีบให้เลือกอีกครั้งแน่นอน
Dialogue: 0,0:55:22.48,0:55:24.02,Default,,0,0,0,,จะเลือกประเทศ
Dialogue: 0,0:55:24.34,0:55:26.01,Default,,0,0,0,,หรือจะเลือกพรรคพวก
Dialogue: 0,0:55:26.45,0:55:28.20,Default,,0,0,0,,หรือจะเลือกตัวเอง
Dialogue: 0,0:55:30.41,0:55:31.75,Default,,0,0,0,,ตัดสินใจไว้ซะ
Dialogue: 0,0:55:32.08,0:55:34.13,Default,,0,0,0,,เมื่อถึงเวลานั้น
Dialogue: 0,0:55:34.13,0:55:36.29,Default,,0,0,0,,เส้นทางที่พวกเราจะเลือก
Dialogue: 0,0:56:08.93,0:56:10.46,Default,,0,0,0,,มาช้าหน่อยนะครับ
Dialogue: 0,0:56:10.46,0:56:14.63,Default,,0,0,0,,โธ่ นึกว่าลืมกันไปแล้วซะอีก
Dialogue: 0,0:56:18.87,0:56:21.76,Default,,0,0,0,,ดูเหมือนจะเล่นใหญ่กันน่าดูเลยนะ
Dialogue: 0,0:56:22.68,0:56:25.05,Default,,0,0,0,,ทุกอย่างเป็นไปตามแผนค่ะ
Dialogue: 0,0:56:26.17,0:56:27.83,Default,,0,0,0,,ผลไม้สุกงอมแล้วค่ะ
Dialogue: 0,0:56:27.83,0:56:31.74,Default,,0,0,0,,บัดนี้คือเวลาที่ฝ่าบาทจะกลายเป็นบุคคลแห่งยุคสมัยแล้วค่ะ
Dialogue: 0,0:56:31.74,0:56:33.79,Default,,0,0,0,,ไม่เอาน่า
Dialogue: 0,0:56:33.79,0:56:36.97,Default,,0,0,0,,ผมไม่ได้อยากจะเด่นอะไรสักหน่อย
Dialogue: 0,0:56:36.97,0:56:38.60,Default,,0,0,0,,เอาล่ะค่ะ ฝ่าบาท
Dialogue: 0,0:56:38.60,0:56:40.49,Default,,0,0,0,,โปรดออกคำสั่งต่อไปด้วยค่ะ
Dialogue: 0,0:56:41.87,0:56:45.05,Default,,0,0,0,,งั้นก็มาเริ่มกันเลยดีกว่า
Dialogue: 0,0:56:46.28,0:56:47.89,Default,,0,0,0,,การปฏิวัติ
